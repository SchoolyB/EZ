# Vendored — exclude from language stats
grayc/src/vendor/** linguist-vendored

# Auto-generated — exclude from stats + collapse in PR diffs
ERRORS.md linguist-generated
go.sum linguist-generated

# Binary files — don't diff
*.o binary
*.a binary
*.wasm binary

# Enforce LF line endings
* text=auto
*.s text eol=lf
*.c text eol=lf
*.h text eol=lf
*.go text eol=lf
*.gray text eol=lf
*.sh text eol=lf
Makefile text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf
