# Binaries and compiled files
*.bin
*.exe
*.so
*.dll
*.dylib
*.o
*.a
*.d
/gray
/grayc/grayc
/grayc/libgrayrt.a
/grayc/tests/test_lexer
/grayc/tests/test_parser
/grayc/tests/test_typechecker
/grayc/tests/test_codegen
/grayc/tests/test_util
/grayc/tests/*_san
/grayc/tests/*_asan
*.dSYM/

# Build directories
dist/
bin/
build/
out/

# Coverage and profiling
*.out
*.html
*.prof
*.test

# IDE and editors
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Temp and logs
tmp/
*.log
*.tmp

# Environment and secrets
.env
.env.*
*.pem
*.key

# Compiled test output at repo root (extensionless binaries from manual testing)
/maps_c
/random_c
/server_c
/std_c
/threads_c
/time_c
/test_*
/main

# Block any Mach-O / ELF binaries accidentally placed at repo root
# (catch-all for stray compiled outputs)
*_c
!/grayc/src/**/*.c
!/grayc/src/**/*.h

# Project specific
context/
*.txt

# Ignore all .gray files by default (for local scratch/testing)
*.gray

# Keep integration tests and project scaffolder templates tracked
!integration-tests/
!integration-tests/**
!integration-tests/**/*.gray
!cli/templates/
!cli/templates/**
!cli/templates/**/*.gray
!cli/tests.gray
!scripts/**/*.gray

# Embedded compiler runtime — generated by `make build`.
# The files exist so //go:embed resolves; their binary content is
# never committed. Fresh clones get empty stubs from `make stubs`.
/internal/driver/runtime/grayc
/internal/driver/runtime/libgrayrt.a
/internal/driver/runtime/src/
*.stub
*.md
.claude/


# Ignore local Grayscale playground env
/playground
