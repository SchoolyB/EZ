# Binaries and compiled files
*.bin
*.exe
*.so
*.dll
*.dylib
*.o
*.a
*.d
/ez
/ezc/ezc
/ezc/libezrt.a
/ezc/tests/test_lexer
/ezc/tests/test_parser
/ezc/tests/test_typechecker
/ezc/tests/test_codegen
/ezc/tests/*_san
/ezc/tests/*_asan
*.dSYM/

# Build directories
dist/
bin/
build/
out/

# Coverage and profiling
*.out
*.html
*.prof
*.test

# IDE and editors
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Temp and logs
tmp/
*.log
*.tmp

# Environment and secrets
.env
.env.*
*.pem
*.key

# Compiled test output at repo root (extensionless binaries from manual testing)
/maps_c
/random_c
/server_c
/std_c
/threads_c
/time_c
/test_*
/main

# Block any Mach-O / ELF binaries accidentally placed at repo root
# (catch-all for stray compiled outputs)
*_c
!/ezc/src/**/*.c
!/ezc/src/**/*.h

# Project specific
context/
*.txt
*.ezdb

# Ignore JSON files
*.json

# Ignore all .ez files by default (for local scratch/testing)
*.ez

# Keep integration tests and pz scaffolder templates tracked
!integration-tests/
!integration-tests/**
!integration-tests/**/*.ez
!cmd/ez/templates/
!cmd/ez/templates/**
!cmd/ez/templates/**/*.ez

# Embedded compiler runtime — generated by `make build` (#1461).
# The files exist so //go:embed resolves; their binary content is
# never committed. Fresh clones get empty stubs from `make stubs`.
/internal/ezc/runtime/ezc
/internal/ezc/runtime/libezrt.a
/internal/ezc/runtime/src/
*.md
.claude/


# Ignore local EZ playground env
/playground
