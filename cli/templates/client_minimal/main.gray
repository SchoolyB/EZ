// main.gray - Minimal HTTP client.
//
// http.get(url, headers) returns (HttpResponse, Error).
// Check err against nil; on success, read .status / .body / .headers.

import @http

do main() {
    mut headers map[string:string] = {:}
    mut resp, err = http.get("http://httpbin.org/get", headers)
    if err != nil {
        println("Request failed.")
        exit(1)
    }
    println("Status: ${resp.status}")
    println("Body: ${resp.body}")
}
