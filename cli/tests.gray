/*
 * tests.gray - Grayscale language verification test suite
 *
 * Covers: primitives, strings, control flow, loops, functions,
 * structs, enums, arrays, maps, casting, pointers, @math, @strings,
 * @arrays, @maps, @json, @time, @random, @encoding, @fmt, @strconv,
 * @crypto, @regex, @binary, @bytes, @uuid, @mem.
 *
 * Every test prints [PASS] or [FAIL] with the actual value on failure.
 * Exits non-zero if any assertion fails.
 *
 * Run with:
 *   gray verify
 *   ./grayc/grayc cli/tests.gray -o /tmp/out && /tmp/out
 */

import @math, @strings, @arrays, @maps, @json, @time, @random, @encoding, @fmt, @strconv, @crypto, @regex, @binary, @bytes, @uuid, @mem

// ─── Enums ───────────────────────────────────────────────────────────────────

const Direction enum {
    NORTH
    EAST
    SOUTH
    WEST
}

#flags
const Permission enum {
    READ
    WRITE
    EXECUTE
}

const Status enum {
    TODO   = "todo"
    ACTIVE = "active"
    DONE   = "done"
}

// ─── Structs ─────────────────────────────────────────────────────────────────

const Point struct {
    x int
    y int

    do create(x int, y int) -> Point {
        return Point{x: x, y: y}
    }

    do sum(p Point) -> int {
        return p.x + p.y
    }
}

// ─── Top-level helpers ───────────────────────────────────────────────────────

do add(a int, b int) -> int {
    return a + b
}

do greet(name string, prefix string = "Hello") -> string {
    return "${prefix}, ${name}!"
}

do coords(x int, y int, z int = 0) -> string {
    return "${x},${y},${z}"
}

do multi() -> (n int, s string) {
    mut n int = 7
    mut s string = "seven"
    return n, s
}

// ─── Main ────────────────────────────────────────────────────────────────────

do main() {
    mut passed int = 0
    mut failed int = 0

    // =========================================================================
    println("=== 1. Primitive Arithmetic ===")
    // =========================================================================

    if 1 + 1 == 2 {
        println("  [PASS] 1 + 1 = 2")
        passed++
    } otherwise {
        println("  [FAIL] 1 + 1: expected 2")
        failed++
    }

    if 10 - 3 == 7 {
        println("  [PASS] 10 - 3 = 7")
        passed++
    } otherwise {
        println("  [FAIL] 10 - 3: expected 7")
        failed++
    }

    if 6 * 7 == 42 {
        println("  [PASS] 6 * 7 = 42")
        passed++
    } otherwise {
        println("  [FAIL] 6 * 7: expected 42")
        failed++
    }

    if 20 / 4 == 5 {
        println("  [PASS] 20 / 4 = 5")
        passed++
    } otherwise {
        println("  [FAIL] 20 / 4: expected 5")
        failed++
    }

    if 17 % 5 == 2 {
        println("  [PASS] 17 % 5 = 2")
        passed++
    } otherwise {
        println("  [FAIL] 17 % 5: expected 2")
        failed++
    }

    if -5 + 5 == 0 {
        println("  [PASS] -5 + 5 = 0")
        passed++
    } otherwise {
        println("  [FAIL] -5 + 5: expected 0")
        failed++
    }

    mut flt float = 1.5 + 2.5
    if flt == 4.0 {
        println("  [PASS] 1.5 + 2.5 = 4.0")
        passed++
    } otherwise {
        println("  [FAIL] 1.5 + 2.5: expected 4.0, got ${flt}")
        failed++
    }

    mut bv bool = true && !false
    if bv {
        println("  [PASS] true && !false = true")
        passed++
    } otherwise {
        println("  [FAIL] true && !false: expected true")
        failed++
    }

    mut cv char = 'Z'
    if cv == 'Z' {
        println("  [PASS] char literal 'Z'")
        passed++
    } otherwise {
        println("  [FAIL] char literal: expected 'Z'")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 2. String Interpolation ===")
    // =========================================================================

    mut num int = 42
    mut interp string = "answer=${num}"
    if interp == "answer=42" {
        println("  [PASS] \"answer=${num}\" = \"answer=42\"")
        passed++
    } otherwise {
        println("  [FAIL] int interpolation: got \"${interp}\"")
        failed++
    }

    mut lang string = "Grayscale"
    mut hello string = "Hello ${lang}"
    if hello == "Hello Grayscale" {
        println("  [PASS] \"Hello ${lang}\" = \"Hello Grayscale\"")
        passed++
    } otherwise {
        println("  [FAIL] string interpolation: got \"${hello}\"")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 3. Control Flow ===")
    // =========================================================================

    println("  -- if / otherwise --")

    mut x int = 10
    mut lbl string = ""
    if x > 5 {
        lbl = "big"
    } otherwise {
        lbl = "small"
    }
    if lbl == "big" {
        println("  [PASS] x(10) > 5 → \"big\"")
        passed++
    } otherwise {
        println("  [FAIL] if branch: expected \"big\", got \"${lbl}\"")
        failed++
    }

    mut y int = 2
    mut lbl2 string = ""
    if y > 5 {
        lbl2 = "big"
    } otherwise {
        lbl2 = "small"
    }
    if lbl2 == "small" {
        println("  [PASS] y(2) > 5 is false → otherwise → \"small\"")
        passed++
    } otherwise {
        println("  [FAIL] otherwise branch: expected \"small\", got \"${lbl2}\"")
        failed++
    }

    println("  -- when / is (range) --")

    mut score int = 85
    mut grade string = ""
    when score {
        is range(90, 101) { grade = "A" }
        is range(80, 90)  { grade = "B" }
        is range(70, 80)  { grade = "C" }
        default           { grade = "F" }
    }
    if grade == "B" {
        println("  [PASS] score=85 falls in range(80,90) → grade \"B\"")
        passed++
    } otherwise {
        println("  [FAIL] when range: expected \"B\", got \"${grade}\"")
        failed++
    }

    println("  -- when / is (string) --")

    mut col string = "green"
    mut sig string = ""
    when col {
        is "red"   { sig = "stop" }
        is "green" { sig = "go" }
        default    { sig = "unknown" }
    }
    if sig == "go" {
        println("  [PASS] color=\"green\" → signal \"go\"")
        passed++
    } otherwise {
        println("  [FAIL] when string: expected \"go\", got \"${sig}\"")
        failed++
    }

    println("  -- when / is (enum) --")

    mut dv = Direction.WEST
    mut dir_name string = ""
    when dv {
        is Direction.NORTH { dir_name = "north" }
        is Direction.EAST  { dir_name = "east" }
        is Direction.SOUTH { dir_name = "south" }
        is Direction.WEST  { dir_name = "west" }
        default            { dir_name = "unknown" }
    }
    if dir_name == "west" {
        println("  [PASS] Direction.WEST → \"west\"")
        passed++
    } otherwise {
        println("  [FAIL] when enum: expected \"west\", got \"${dir_name}\"")
        failed++
    }

    println("  -- #strict when (all variants covered, no default needed) --")

    mut sd = Direction.EAST
    mut strict_r string = ""
    #strict
    when sd {
        is Direction.NORTH { strict_r = "n" }
        is Direction.EAST  { strict_r = "e" }
        is Direction.SOUTH { strict_r = "s" }
        is Direction.WEST  { strict_r = "w" }
    }
    if strict_r == "e" {
        println("  [PASS] #strict when Direction.EAST → \"e\"")
        passed++
    } otherwise {
        println("  [FAIL] #strict when: expected \"e\", got \"${strict_r}\"")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 4. Loops ===")
    // =========================================================================

    println("  -- for / range --")

    mut rsum int = 0
    for ri in range(1, 6) {
        rsum += ri
    }
    if rsum == 15 {
        println("  [PASS] sum of range(1,6): 1+2+3+4+5 = 15")
        passed++
    } otherwise {
        println("  [FAIL] for/range sum: expected 15, got ${rsum}")
        failed++
    }

    println("  -- for_each (values) --")

    mut fe_total int = 0
    mut fe_arr [int] = {10, 20, 30, 40}
    for_each fe_v in fe_arr {
        fe_total += fe_v
    }
    if fe_total == 100 {
        println("  [PASS] for_each {10,20,30,40} → sum = 100")
        passed++
    } otherwise {
        println("  [FAIL] for_each sum: expected 100, got ${fe_total}")
        failed++
    }

    println("  -- for_each (index + value) --")

    mut idx_sum int = 0
    for_each fe_i, fe_v in fe_arr {
        idx_sum += fe_i
    }
    if idx_sum == 6 {
        println("  [PASS] for_each index sum: 0+1+2+3 = 6")
        passed++
    } otherwise {
        println("  [FAIL] for_each index sum: expected 6, got ${idx_sum}")
        failed++
    }

    println("  -- as_long_as --")

    mut alas int = 0
    as_long_as alas < 5 {
        alas++
    }
    if alas == 5 {
        println("  [PASS] as_long_as count < 5: increments to 5")
        passed++
    } otherwise {
        println("  [FAIL] as_long_as: expected 5, got ${alas}")
        failed++
    }

    println("  -- loop + break --")

    mut lcount int = 0
    loop {
        if lcount == 3 {
            break
        }
        lcount++
    }
    if lcount == 3 {
        println("  [PASS] loop breaks when lcount == 3")
        passed++
    } otherwise {
        println("  [FAIL] loop + break: expected 3, got ${lcount}")
        failed++
    }

    println("  -- continue (skip odd numbers) --")

    mut even_sum int = 0
    for ci in range(1, 11) {
        if ci % 2 != 0 {
            continue
        }
        even_sum += ci
    }
    if even_sum == 30 {
        println("  [PASS] continue skips odds → 2+4+6+8+10 = 30")
        passed++
    } otherwise {
        println("  [FAIL] continue even sum: expected 30, got ${even_sum}")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 5. Functions ===")
    // =========================================================================

    println("  -- positional args --")

    mut pos_result int = add(3, 4)
    if pos_result == 7 {
        println("  [PASS] add(3, 4) = 7")
        passed++
    } otherwise {
        println("  [FAIL] add(3, 4): expected 7, got ${pos_result}")
        failed++
    }

    println("  -- named args --")

    mut named_result int = add(a: 10, b: 5)
    if named_result == 15 {
        println("  [PASS] add(a: 10, b: 5) = 15")
        passed++
    } otherwise {
        println("  [FAIL] named args: expected 15, got ${named_result}")
        failed++
    }

    println("  -- default params --")

    mut g1 string = greet("Alice")
    if g1 == "Hello, Alice!" {
        println("  [PASS] greet(\"Alice\") = \"Hello, Alice!\"  (prefix defaults to \"Hello\")")
        passed++
    } otherwise {
        println("  [FAIL] default prefix: expected \"Hello, Alice!\", got \"${g1}\"")
        failed++
    }

    mut g2 string = greet("Bob", "Hi")
    if g2 == "Hi, Bob!" {
        println("  [PASS] greet(\"Bob\", \"Hi\") = \"Hi, Bob!\"  (explicit prefix)")
        passed++
    } otherwise {
        println("  [FAIL] explicit prefix: expected \"Hi, Bob!\", got \"${g2}\"")
        failed++
    }

    mut c1 string = coords(1, 2)
    if c1 == "1,2,0" {
        println("  [PASS] coords(1, 2) = \"1,2,0\"  (z defaults to 0)")
        passed++
    } otherwise {
        println("  [FAIL] default z: expected \"1,2,0\", got \"${c1}\"")
        failed++
    }

    mut c2 string = coords(1, 2, 3)
    if c2 == "1,2,3" {
        println("  [PASS] coords(1, 2, 3) = \"1,2,3\"")
        passed++
    } otherwise {
        println("  [FAIL] explicit z: expected \"1,2,3\", got \"${c2}\"")
        failed++
    }

    println("  -- multi-return --")

    mut mret_n int, mret_s string = multi()
    if mret_n == 7 {
        println("  [PASS] multi() → n = 7")
        passed++
    } otherwise {
        println("  [FAIL] multi() n: expected 7, got ${mret_n}")
        failed++
    }
    if mret_s == "seven" {
        println("  [PASS] multi() → s = \"seven\"")
        passed++
    } otherwise {
        println("  [FAIL] multi() s: expected \"seven\", got \"${mret_s}\"")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 6. Structs ===")
    // =========================================================================

    mut pt = Point.create(3, 4)
    if pt.x == 3 {
        println("  [PASS] Point.create(3, 4).x = 3")
        passed++
    } otherwise {
        println("  [FAIL] struct field x: expected 3, got ${pt.x}")
        failed++
    }
    if pt.y == 4 {
        println("  [PASS] Point.create(3, 4).y = 4")
        passed++
    } otherwise {
        println("  [FAIL] struct field y: expected 4, got ${pt.y}")
        failed++
    }

    mut pt_sum int = Point.sum(pt)
    if pt_sum == 7 {
        println("  [PASS] Point.sum({x:3, y:4}) = 3 + 4 = 7")
        passed++
    } otherwise {
        println("  [FAIL] Point.sum: expected 7, got ${pt_sum}")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 7. Enums ===")
    // =========================================================================

    println("  -- int enum (auto-increment from 0) --")

    mut north int = Direction.NORTH
    mut east_v int = Direction.EAST
    mut south_v int = Direction.SOUTH
    mut west_v int = Direction.WEST

    if north == 0 {
        println("  [PASS] Direction.NORTH = 0")
        passed++
    } otherwise {
        println("  [FAIL] Direction.NORTH: expected 0, got ${north}")
        failed++
    }
    if east_v == 1 {
        println("  [PASS] Direction.EAST = 1")
        passed++
    } otherwise {
        println("  [FAIL] Direction.EAST: expected 1, got ${east_v}")
        failed++
    }
    if south_v == 2 {
        println("  [PASS] Direction.SOUTH = 2")
        passed++
    } otherwise {
        println("  [FAIL] Direction.SOUTH: expected 2, got ${south_v}")
        failed++
    }
    if west_v == 3 {
        println("  [PASS] Direction.WEST = 3")
        passed++
    } otherwise {
        println("  [FAIL] Direction.WEST: expected 3, got ${west_v}")
        failed++
    }

    println("  -- flags enum (power-of-2) --")

    mut r_perm int = Permission.READ
    mut w_perm int = Permission.WRITE
    mut e_perm int = Permission.EXECUTE

    if r_perm == 1 {
        println("  [PASS] Permission.READ = 1")
        passed++
    } otherwise {
        println("  [FAIL] Permission.READ: expected 1, got ${r_perm}")
        failed++
    }
    if w_perm == 2 {
        println("  [PASS] Permission.WRITE = 2")
        passed++
    } otherwise {
        println("  [FAIL] Permission.WRITE: expected 2, got ${w_perm}")
        failed++
    }
    if e_perm == 4 {
        println("  [PASS] Permission.EXECUTE = 4")
        passed++
    } otherwise {
        println("  [FAIL] Permission.EXECUTE: expected 4, got ${e_perm}")
        failed++
    }

    println("  -- string enum --")

    if Status.TODO == "todo" {
        println("  [PASS] Status.TODO = \"todo\"")
        passed++
    } otherwise {
        println("  [FAIL] Status.TODO: expected \"todo\", got \"${Status.TODO}\"")
        failed++
    }
    if Status.ACTIVE == "active" {
        println("  [PASS] Status.ACTIVE = \"active\"")
        passed++
    } otherwise {
        println("  [FAIL] Status.ACTIVE: expected \"active\", got \"${Status.ACTIVE}\"")
        failed++
    }
    if Status.DONE == "done" {
        println("  [PASS] Status.DONE = \"done\"")
        passed++
    } otherwise {
        println("  [FAIL] Status.DONE: expected \"done\", got \"${Status.DONE}\"")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 8. Arrays ===")
    // =========================================================================

    println("  -- literals + indexing --")

    mut arr [int] = {1, 2, 3, 4, 5}
    if len(arr) == 5 {
        println("  [PASS] {1,2,3,4,5} → len = 5")
        passed++
    } otherwise {
        println("  [FAIL] array length: expected 5, got ${len(arr)}")
        failed++
    }
    if arr[0] == 1 {
        println("  [PASS] arr[0] = 1")
        passed++
    } otherwise {
        println("  [FAIL] arr[0]: expected 1, got ${arr[0]}")
        failed++
    }
    if arr[4] == 5 {
        println("  [PASS] arr[4] = 5")
        passed++
    } otherwise {
        println("  [FAIL] arr[4]: expected 5, got ${arr[4]}")
        failed++
    }

    println("  -- element assignment --")

    arr[2] = 99
    if arr[2] == 99 {
        println("  [PASS] arr[2] = 99  (write then read back)")
        passed++
    } otherwise {
        println("  [FAIL] arr[2] assignment: expected 99, got ${arr[2]}")
        failed++
    }

    println("  -- in operator --")

    mut in_arr [int] = {1, 2, 3, 4, 5}
    if 3 in in_arr {
        println("  [PASS] 3 in {1,2,3,4,5} = true")
        passed++
    } otherwise {
        println("  [FAIL] 3 in array: expected true")
        failed++
    }
    if !(9 in in_arr) {
        println("  [PASS] 9 in {1,2,3,4,5} = false")
        passed++
    } otherwise {
        println("  [FAIL] 9 not in array: expected false")
        failed++
    }

    println("  -- arrays.append --")

    mut grow [int] = {10, 20}
    arrays.append(grow, 30)
    if len(grow) == 3 {
        println("  [PASS] append(30) → len = 3")
        passed++
    } otherwise {
        println("  [FAIL] append length: expected 3, got ${len(grow)}")
        failed++
    }
    if grow[2] == 30 {
        println("  [PASS] grow[2] = 30  (appended value)")
        passed++
    } otherwise {
        println("  [FAIL] appended value: expected 30, got ${grow[2]}")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 9. Maps ===")
    // =========================================================================

    println("  -- literal + access --")

    mut ages map[string:int] = {
        "alice": 30,
        "bob":   25
    }
    if len(ages) == 2 {
        println("  [PASS] {\"alice\":30, \"bob\":25} → len = 2")
        passed++
    } otherwise {
        println("  [FAIL] map length: expected 2, got ${len(ages)}")
        failed++
    }
    if ages["alice"] == 30 {
        println("  [PASS] ages[\"alice\"] = 30")
        passed++
    } otherwise {
        println("  [FAIL] map access: expected 30")
        failed++
    }

    println("  -- insert + update --")

    ages["charlie"] = 40
    if len(ages) == 3 && ages["charlie"] == 40 {
        println("  [PASS] ages[\"charlie\"] = 40  (inserted, len now 3)")
        passed++
    } otherwise {
        println("  [FAIL] map insert: expected charlie=40 and len=3")
        failed++
    }

    ages["alice"] = 31
    if ages["alice"] == 31 {
        println("  [PASS] ages[\"alice\"] updated 30 → 31")
        passed++
    } otherwise {
        println("  [FAIL] map update: expected 31")
        failed++
    }

    println("  -- in operator --")

    if "bob" in ages {
        println("  [PASS] \"bob\" in ages = true")
        passed++
    } otherwise {
        println("  [FAIL] \"bob\" in ages: expected true")
        failed++
    }
    if !("zed" in ages) {
        println("  [PASS] \"zed\" in ages = false")
        passed++
    } otherwise {
        println("  [FAIL] \"zed\" not in ages: expected false")
        failed++
    }

    println("  -- maps.has_key / maps.get_keys --")

    if maps.has_key(ages, "bob") {
        println("  [PASS] maps.has_key(ages, \"bob\") = true")
        passed++
    } otherwise {
        println("  [FAIL] maps.has_key: expected true for \"bob\"")
        failed++
    }
    if !maps.has_key(ages, "nobody") {
        println("  [PASS] maps.has_key(ages, \"nobody\") = false")
        passed++
    } otherwise {
        println("  [FAIL] maps.has_key: expected false for \"nobody\"")
        failed++
    }

    mut mkeys [string] = maps.get_keys(ages)
    if len(mkeys) == 3 {
        println("  [PASS] maps.get_keys(ages) → 3 keys")
        passed++
    } otherwise {
        println("  [FAIL] maps.get_keys: expected 3, got ${len(mkeys)}")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 10. Casting ===")
    // =========================================================================

    mut cf float = cast(42, float)
    if cf == 42.0 {
        println("  [PASS] cast(42, float) = 42.0")
        passed++
    } otherwise {
        println("  [FAIL] cast int->float: expected 42.0, got ${cf}")
        failed++
    }

    mut ci int = cast(3.9, int)
    if ci == 3 {
        println("  [PASS] cast(3.9, int) = 3  (truncated toward zero)")
        passed++
    } otherwise {
        println("  [FAIL] cast float->int: expected 3, got ${ci}")
        failed++
    }

    mut cs2 string = cast(123, string)
    if cs2 == "123" {
        println("  [PASS] cast(123, string) = \"123\"")
        passed++
    } otherwise {
        println("  [FAIL] cast int->string: expected \"123\", got \"${cs2}\"")
        failed++
    }

    mut cb string = cast(true, string)
    if cb == "true" {
        println("  [PASS] cast(true, string) = \"true\"")
        passed++
    } otherwise {
        println("  [FAIL] cast bool->string: expected \"true\", got \"${cb}\"")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 11. Pointers ===")
    // =========================================================================

    mut pval int = 42
    mut ptr ^int = addr(pval)
    if ptr^ == 42 {
        println("  [PASS] addr(pval)^ = 42  (read through pointer)")
        passed++
    } otherwise {
        println("  [FAIL] pointer deref: expected 42, got ${ptr^}")
        failed++
    }

    ptr^ = 100
    if pval == 100 {
        println("  [PASS] ptr^ = 100 → pval is now 100  (write-back)")
        passed++
    } otherwise {
        println("  [FAIL] pointer write-back: expected 100, got ${pval}")
        failed++
    }

    mut pt2 = Point.create(5, 6)
    mut ptp ^Point = addr(pt2)
    if ptp^.x == 5 {
        println("  [PASS] addr(pt2)^.x = 5  (struct field through pointer)")
        passed++
    } otherwise {
        println("  [FAIL] pointer struct field: expected 5, got ${ptp^.x}")
        failed++
    }

    ptp^.y = 99
    if pt2.y == 99 {
        println("  [PASS] ptp^.y = 99 → pt2.y is now 99  (write-back)")
        passed++
    } otherwise {
        println("  [FAIL] pointer struct write-back: expected 99, got ${pt2.y}")
        failed++
    }

    // =========================================================================
    println("")
    println("=== 12. @math ===")
    // =========================================================================

    mut abs_r int = math.abs(-7)
    if abs_r == 7 {
        println("  [PASS] math.abs(-7) = 7")
        passed++
    } otherwise {
        println("  [FAIL] math.abs(-7): expected 7, got ${abs_r}")
        failed++
    }

    mut min_r int = math.min(3, 8)
    if min_r == 3 {
        println("  [PASS] math.min(3, 8) = 3")
        passed++
    } otherwise {
        println("  [FAIL] math.min(3, 8): expected 3, got ${min_r}")
        failed++
    }

    mut max_r int = math.max(3, 8)
    if max_r == 8 {
        println("  [PASS] math.max(3, 8) = 8")
        passed++
    } otherwise {
        println("  [FAIL] math.max(3, 8): expected 8, got ${max_r}")
        failed++
    }

    mut sqrt_r float = math.sqrt(9.0)
