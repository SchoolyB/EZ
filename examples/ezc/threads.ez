/*
 * threads.ez - Threading with spawn, join, mutex, and channels
 *
 * Compile with: ezc examples/ezc/threads.ez -o threads
 * Run with: ./threads
 *
 * NOTE: This example requires the EZC compiler (not the interpreter).
 * The @threads, @sync, and @channels modules are EZC-only.
 */

import @threads, @sync, @channels

// ---- Worker function that runs on its own thread ----

do worker(id int) {
    println("[Thread ${id}] Starting work...")
    sleep_ms(200)
    println("[Thread ${id}] Done!")
}

// ---- Main ----

do main() {
    println("=== EZ Threading Demo ===")
    println("")

    // Spawn 4 worker threads
    println("Spawning 4 workers...")
    mut t1 = threads.spawn(()worker, 1)
    mut t2 = threads.spawn(()worker, 2)
    mut t3 = threads.spawn(()worker, 3)
    mut t4 = threads.spawn(()worker, 4)

    // Wait for all threads to finish
    threads.join(t1)
    threads.join(t2)
    threads.join(t3)
    threads.join(t4)
    println("")
    println("All workers finished!")

    // Channel demo — send values between threads
    println("")
    println("--- Channel Demo ---")
    mut ch = channels.open(8)

    // Send some values
    channels.send(ch, 42)
    channels.send(ch, 100)
    channels.send(ch, 7)

    // Receive them
    mut a = channels.receive(ch)
    mut b = channels.receive(ch)
    mut c = channels.receive(ch)
    println("Channel received: ${a}, ${b}, ${c}")

    channels.close(ch)
    println("")
    println("Done.")
}
