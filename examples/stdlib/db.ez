import @db
import @std
import @json
using std

const User struct {
	name string
	age  int
}

do main() {
    mut store Database, err Error = db.open("mydb.ezdb")
    if err != nil {
        println("Failed: ${err.message}")
        return
    }
    
    // Write data
		mut user1 User = User{name: "Alice", age: 30}
		mut user1data, _ = json.encode(user1)
    db.set(store, "user:1", user1data)

		mut user2 User = User{name: "Bob", age: 25}
		mut user2data, _ = json.encode(user2)
    db.set(store, "user:2", user2data)

    db.set(store, "config:theme", "dark")
    
    // Read data
    mut data, found = db.get(store, "user:1")
		if found {
				mut user, _ = json.decode(data, User)
				println("Name: ${user.name}")
		}
    
    // Check existence
    if db.has(store, "user:3") {
        println("User 3 exists")
    } otherwise {
        println("User 3 not found")
    }

		mut keys [string] = db.keys(store)
		println("Keys: ${keys}")
    
    // List keys by prefix
    mut users [string] = db.prefix(store, "user:")
    println("User keys: ${users}")
    
    // Stats
    println("Total keys: " + string(db.count(store)))
    
    // Manual save (optional - auto-saves on close)
		mut _ = db.save(store)

    // Cleanup
    mut _ = db.close(store)
}
