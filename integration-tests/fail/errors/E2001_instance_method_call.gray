/*
 * Error Test: E2001 - struct function syntax parsed as instance call
 * Expected: E2001 unexpected symbol (parser rejects instance.func() syntax)
 */

const Foo struct {
    value int
}

do Foo.bar() -> int {
    return 42
}

do main() {
    mut f Foo = Foo{value: 1}
    mut result int = f.bar()
}
