/*
 * Error Test: E2002 - struct func called on instance instead of type (uses old 'struct' syntax)
 * Expected: E2002 unexpected symbol
 */

struct Vec2 {
    x int,
    y int,
}

do Vec2.zero() Vec2 {
    return Vec2{x: 0, y: 0}
}

do main() {
    mut v Vec2 = Vec2.zero()
    mut w Vec2 = v.zero()
}
