/* E2002: type keywords cannot be used as when/is binding names */
/* expect: E2002 */

const Wrapper enum {
    Value(int)
    Empty
}

do main() {
    mut w = Wrapper.Value(42)
    when w {
        is Wrapper.Value(int) {
            println("got: ${int}")
        }
        is Wrapper.Empty {
            println("empty")
        }
    }
}
