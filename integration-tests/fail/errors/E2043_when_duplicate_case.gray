/*
 * Error Test: E2043 - duplicate case value in when statement
 * Expected: compiler should reject this with E2043
 */

do main() {
    mut x = 1
    when x {
        is 1 { println("one") }
        is 2 { println("two") }
        is 1 { println("one again") }
        default { println("other") }
    }
}
