/* Test: E2060 — too many return values (exceeds 16 limit)
 * Expected: compiler error E2060
 */

import @std
using std

do too_many() -> (a int, b int, c int, d int, e int, f int, g int, h int, i int, j int, k int, l int, m int, n int, o int, p int, q int) {
    return a, b, c, d, e, f, g, h, i, j, k, l, m, n, o, p, q
}

do main() {
    mut a, b, c, d, e, f, g, h, i, j, k, l, m, n, o, p, q = too_many()
    println(a)
}
