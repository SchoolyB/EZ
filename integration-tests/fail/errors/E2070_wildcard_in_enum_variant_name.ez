/*
 * Error Test: E2070 - wildcard '?' as an enum variant name
 *
 * Regression for the #1481 follow-up (9d175d9): enum variant name
 * slots previously read cur_token.literal without filtering
 * TOK_QUESTION, so `?` was embedded verbatim in the generated C
 * enum constant and leaked to clang. Parser now emits E2070 at the
 * variant-name read site matching the existing type-position check.
 */

const E enum {
    ?
}

do main() {}
