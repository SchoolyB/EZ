/*
 * Error Test: E2070 - wildcard '?' as a struct field type
 *
 * Wildcard types are only allowed in function parameter and return
 * types. Using '?' as a struct field type must be rejected.
 *
 * Expected: E2070
 */

const Bad struct {
    x ?
    y int
}

do main() {
    mut b = Bad{x: 42, y: 10}
    println("${b.x}")
}
