/*
 * Error Test: E2071 - empty string interpolation ${}
 *
 * `"value: ${}"` used to produce
 * "unexpected token 'EOF'" anchored at line 1:1 of the file,
 * because the empty expression text was handed to a fresh
 * sub-parser that hit EOF with stale position tracking. Parser
 * now checks for empty expression text before spinning up the
 * sub-parser and emits E2071 anchored at the string literal.
 */

do main() {
    mut s string = "value: ${}"
}
