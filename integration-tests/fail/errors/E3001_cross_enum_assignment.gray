/*
 * Error Test: E3001 - cross-enum assignment rejected
 * Expected: "cannot assign enum 'Size' to enum 'Color'" error
 * Regression for #1471
 */

const Color enum {
    RED
    GREEN
    BLUE
}

const Size enum {
    SMALL
    MEDIUM
    LARGE
}

do main() {
    mut c Color = Size.SMALL
    println("${c}")
}
