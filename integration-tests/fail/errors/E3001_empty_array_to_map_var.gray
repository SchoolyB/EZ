/*
 * Error Test: E3001 - empty array literal {} assigned to a map variable
 *
 * {} is an array literal; {:} is the empty map
 * literal. The typechecker previously let {} through because an empty
 * array has no elements to infer a concrete type from, then codegen
 * emitted gray_array_new and the C compiler choked on the type mismatch.
 * Now rejected at var_decl time with a hint pointing at {:}.
 */

do main() {
    mut m map[string:int] = {}
}
