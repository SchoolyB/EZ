/*
 * Error Test: E3001 - int literal returned from function with enum return type
 *
 * Regression for #1472: the return-statement type-mismatch check used
 * to allow int literals through a function whose declared return type
 * was an enum. Now rejected so callers can trust the enum contract.
 */

const Color enum {
    RED,
    GREEN,
    BLUE
}

do bad() -> Color {
    return 42
}

do main() {
    mut c Color = bad()
}
