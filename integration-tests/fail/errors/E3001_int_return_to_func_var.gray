/*
 * Error Test: E3001 - int-returning call assigned to a func-typed variable
 *
 * the bug was not return-type specific. The fix
 * rejects every non-func initializer at the `mut f func = ...` site,
 * regardless of the call's return type. This test locks in the int
 * shape alongside the string shape.
 */

do answer() -> int {
    return 42
}

do main() {
    mut f func() -> int = answer()
}
