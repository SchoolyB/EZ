/*
 * Error Test: E3001 - int literal assigned to enum-typed variable
 *
 * Regression for #1472: the var_decl type-mismatch check used to
 * carve out enum ↔ int in both directions. int → enum is unsound
 * (any int could be assigned to any enum variable, bypassing the
 * enum's valid-value contract) and is now rejected. enum → int
 * still works because enums are int-backed.
 */

const Color enum {
    RED,
    GREEN,
    BLUE
}

do main() {
    mut c Color = 5
}
