/*
 * Error Test: E3001 - returning ^^int from a -> ^int function
 *
 * both sides are TK_POINTER so the kind
 * check passed, but the pointer depths differ. Typechecker now
 * compares element_type strings to catch the mismatch.
 */

do bad() -> ^int {
    mut x int = 42
    mut p ^int = addr(x)
    mut pp ^^int = addr(p)
    return pp
}

do main() {
    mut r ^int = bad()
    println(r^)
}
