/*
 * Error Test: E3001 - struct type mismatch in nested struct literal
 * assigning a wrong struct type as a field value
 * in a struct literal was silently accepted by the typechecker.
 * Expected: E3001
 */

const Vec2 struct {
    x float
    y float
}

const Vec3 struct {
    x float
    y float
    z float
}

const Player struct {
    pos Vec2
}

do main() {
    mut wrong = Vec3{x: 1.0, y: 2.0, z: 3.0}
    mut p = Player{pos: wrong}  // Should produce E3001 — Vec3 != Vec2
    println(p.pos.x)
}
