/*
 * Error Test: E3001 - returning ^^^int from a -> ^int function
 *
 * Regression for #1514: same check at deeper nesting.
 */

do bad() -> ^int {
    mut x int = 42
    mut p ^int = addr(x)
    mut pp ^^int = addr(p)
    mut ppp ^^^int = addr(pp)
    return ppp
}

do main() {
    mut r ^int = bad()
    println(r^)
}
