/*
 * Error Test: E3001 - returning wrong enum type from function
 * Expected: type mismatch error for cross-enum return
 */

const Color enum {
    RED
    GREEN
}

const Dir enum {
    NORTH
    SOUTH
}

do get_color() -> Color {
    return Dir.NORTH
}

do main() {
    mut c Color = get_color()
}
