/*
 * Error Test: E3001 - wrong enum type passed as function argument
 * Expected: "expected enum 'Color', got enum 'Size'" error
 */

const Color enum {
    RED
    GREEN
    BLUE
}

const Size enum {
    SMALL
    MEDIUM
    LARGE
}

do take_color(c Color) {
    println("got color")
}

do main() {
    take_color(Size.SMALL)
}
