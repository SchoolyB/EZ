/*
 * Error Test: E3002 - bool + int produces exactly one error, not two
 *
 * used to fire both E3002 at the operator
 * and a cascading E3001 "cannot assign bool to int" at the
 * var_decl. Infix resolver now collapses to TK_UNKNOWN after any
 * op-level error so downstream checks skip the cascade.
 */

do main() {
    mut x int = true + 1
}
