/*
 * Error Test: E3002 - nil used as operand of '+' in var_decl
 *
 * Regression for #1487: used to fire the misleading "cannot
 * assign nil to int" because the infix resolver returned nil
 * as the expression type. Now reports the real issue (nil as
 * '+' operand) and the cascade suppressor (#1488) prevents a
 * second assignment-mismatch diagnostic.
 */

do main() {
    mut x int = nil + 1
}
