/*
 * Error Test: E3003 - negative literal index on a string
 *
 * Regression for #1500: `s[-1]` used to compile clean and panic
 * at runtime while the analogous `a[-1]` on an array was caught
 * at compile time. The negative-index guard in NODE_INDEX_EXPR
 * now matches TK_STRING in addition to TK_ARRAY.
 */

do main() {
    mut s string = "hello"
    println(s[-1])
}
