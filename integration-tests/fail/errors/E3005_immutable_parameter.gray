/*
 * Error Test: E3005 - immutable-parameter
 * Expected: "cannot modify constant; declare with 'mut' to make it mutable"
 */

const Person struct {
    name string
    age int
}

do try_modify(p Person) {
    p.age = p.age + 1  // ERROR: cannot modify non-& param
}

do main() {
    mut bob Person = Person{name: "Bob", age: 30}
    try_modify(bob)
}
