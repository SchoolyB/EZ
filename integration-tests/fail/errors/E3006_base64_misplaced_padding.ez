/*
 * Error Test: E16001 - base64 input has '=' in non-padding position
 * Expected: "invalid base64"
 *
 * '=' is only valid at the end. Anywhere else means the encoder lost
 * data; the decoder must reject rather than silently produce garbage.
 */

import @encoding

do main() {
    mut result string, err Error = encoding.base64_decode("ab=dEFGH")
    if err != nil {
        panic("${err}")
    }
}
