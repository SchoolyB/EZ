/*
 * Error Test: E3027 - literal passed to mutable (&) param of struct function
 * Expected: "cannot pass a literal or expression to mutable parameter" error
 * Regression for #1494
 */

const Calculator struct {
    _pad int

    do double(&x int) {
        x = x * 2
    }
}

do main() {
    Calculator.double(42)
}
