/*
 * Error Test: E3036 - integer range overflow on struct field assignment
 *
 * struct field assignment wasn't range-checked.
 * Uses new() to initialize (sidesteps a pre-existing E3001 on
 * sized-int literals in struct literal field initializers).
 */

const Person struct {
    name string
    age u8
}

do main() {
    mut p = new(Person)
    p^.age = 1000
}
