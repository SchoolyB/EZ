/*
 * Error Test: E17003 - db-write-failed
 * Expected: "failed to write database file"
 */

 import @db, @io

 do main() {
    mut store, _ = db.open("mydb.ezdb")
    mut _, _ = io.write_file("mydb.ezdb", "{}", io.READ_ONLY)
    mut err = db.close(store) // attempting to write to a read only file
 }
