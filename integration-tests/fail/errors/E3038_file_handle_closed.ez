/*
 * Error Test: E7050 - file-handle-closed
 * Expected: "file handle" or "closed"
 */

import @io

do main() {
    // Create a mut file
    mut wok, werr = io.write_file("ez_test_e7050_temp.txt", "test data")

    // Open, close, then try to read
    mut handle, oerr = io.open("ez_test_e7050_temp.txt")
    mut cerr = io.close(handle)

    // Try to read from closed handle
    mut data, rerr = io.read_all(handle)

    // Clean up
    mut dok, derr = io.delete_file("ez_test_e7050_temp.txt")

    if rerr != nil {
        panic("${rerr}")
    }
}
