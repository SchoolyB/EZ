/*
 * Error Test: E3038 - void function call used as a map literal value
 *
 * Regression for #1483: `{"k": nothing()}` used to leak to clang
 * as "initializing int64_t with an expression of incompatible type
 * 'void'". Typechecker now rejects void at map literal value slots.
 */

do nothing() {}

do main() {
    mut m map[string:int] = {"k": nothing()}
}
