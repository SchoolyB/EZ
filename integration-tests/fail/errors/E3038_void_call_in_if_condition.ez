/*
 * Error Test: E3038 - void function call used as an if condition
 *
 * Regression for #1476: `if nothing() { }` used to sail through the
 * typechecker and leak to clang as "statement requires expression of
 * scalar type ('void' invalid)". Now caught at compile time.
 */

do nothing() {
}

do main() {
    if nothing() {
        println("unreachable")
    }
}
