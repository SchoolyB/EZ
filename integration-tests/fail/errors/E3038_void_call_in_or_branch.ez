/*
 * Error Test: E3038 - void function call used as an 'or' branch condition
 *
 * Regression for #1476: the 'or' branch of an if chain parses as a
 * nested NODE_IF_STMT, so the same check must fire for conditions on
 * subsequent branches.
 */

do nothing() {
}

do main() {
    mut x int = 0
    if x > 0 {
        println("pos")
    } or nothing() {
        println("unreachable")
    }
}
