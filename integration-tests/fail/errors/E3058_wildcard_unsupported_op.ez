/*
 * Error Test: E3058 - wildcard instantiation fails when concrete type
 * doesn't support an operator used in the generic body.
 *
 * Per #1443 spec: "the compiler must error at the call site, not inside
 * the wildcard function." This verifies the body re-check emits the
 * instantiation-failure error pointing at the offending call.
 *
 * max(?, ?) uses '>' in its body. Strings don't support '>', so passing
 * strings must error at the max(...) call, not inside max.
 */

do max(a ?, b ?) -> ? {
    if a > b { return a }
    return b
}

do main() {
    mut s string = max("apple", "banana")
}
