/*
 * Error Test: E3098 - struct type mismatch through pointer dereference
 * ptrA^ = ptrB^ where ptrA and ptrB point to
 * different struct types was silently allowed by the typechecker.
 * Expected: E3098
 */

const Vec2 struct {
    x int
    y int
}

const Vec3 struct {
    x int
    y int
    z int
}

do main() {
    mut v2 = new(Vec2)
    mut v3 = new(Vec3)
    v3^ = v2^
}
