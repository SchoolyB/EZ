/*
 * Error Test: E4005 - typo'd call on the @strings stdlib module
 *
 * Regression for #1497: used to fall through the strings dispatch's
 * catchall else and silently invent a string return type, which
 * cascaded into a misleading E3001 "cannot assign string to int"
 * at the use site. Now emits E4005 at the offending member access.
 */

import @strings

do main() {
    mut x int = strings.totally_fake_function("abc")
    println(x)
}
