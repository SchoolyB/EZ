/*
 * Error Test: E4016 - HttpRequest not available with only @http import
 * Expected: E4016 "undefined type 'HttpRequest'"
 * Covers: HttpRequest scoped to server module only (#1585)
 */

import @http

do handler(req HttpRequest) {
    println("should not compile")
}

do main() {
    println("should not reach here")
}
