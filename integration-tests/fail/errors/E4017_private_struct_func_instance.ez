/*
 * Error Test: E4017 - private struct function called via instance dispatch
 * Expected: "private and cannot be called from outside the struct"
 */

const Vec struct {
    x int
    y int

    private do secret(v Vec) -> int {
        return v.x + v.y
    }
}

do main() {
    mut a Vec = Vec{x: 3, y: 4}
    mut r int = a.secret()
}
