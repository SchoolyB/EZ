/*
 * Error Test: E5008 - struct function called with too many arguments
 * Expected: E5008 "function 'Math.zero' expects 0 argument(s), got 2"
 * Covers: struct function arg count validation
 */

const Math struct {
    _pad int

    do zero() -> int {
        return 0
    }
}

do main() {
    mut r int = Math.zero(10, 20)
    println("${r}")
}
