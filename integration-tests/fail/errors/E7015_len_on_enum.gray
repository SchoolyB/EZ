/*
 * Error Test: E7015 - len() on an enum value
 *
 * Regression for #1490: enum values used to leak to clang as
 * "member reference base type 'int' is not a structure or union"
 * because enums compile to int. Now rejected at typecheck time.
 */

const Color enum {
    RED,
    GREEN
}

do main() {
    println(len(Color.RED))
}
