/*
 * Error Test: E7023 - directory-not-empty
 * Expected: "not empty" or "directory"
 */

import @io

do main() {
    // Create a directory with a file in it
    mut ok1, err1 = io.mkdir("ez_test_e7023_temp_dir")
    mut ok2, err2 = io.write_file(io.path_join("ez_test_e7023_temp_dir", "file.txt"), "data")

    // Try to remove the non-empty directory (should fail)
    mut rok, rerr = io.remove_dir("ez_test_e7023_temp_dir")

    // Clean up
    mut c1, c2 = io.remove(io.path_join("ez_test_e7023_temp_dir", "file.txt"))
    mut c3, c4 = io.remove_dir("ez_test_e7023_temp_dir")

    if rerr != nil {
        panic("${rerr}")
    }
}
