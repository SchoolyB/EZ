/*
 * Panic Test: P0004 - range loop step increment overflows int
 *
 * When the step addition in a range loop overflows int, EZ must panic
 * rather than silently wrapping the iterator to a negative value and
 * looping forever.
 */

do main() {
    for i in range(9223372036854775806, 9223372036854775807, 2) {
        println(i)
    }
}
