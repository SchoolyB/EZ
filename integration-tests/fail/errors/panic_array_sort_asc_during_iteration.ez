/*
 * Test: E9006 - Cannot modify array during for_each iteration
 * Expected: Runtime panic from arrays.sort_asc during a for_each.
 */

import and use @arrays

do main() {
    mut arr [int] = {3, 1, 4, 1, 5}
    for_each item in arr {
        if item == 1 {
            arrays.sort_asc(arr)
        }
    }
}
