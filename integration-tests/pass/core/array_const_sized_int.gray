// Test: sized integer types as fixed-size array size specifiers

const S_I8 i8 = 3
const S_I16 i16 = 3
const S_I32 i32 = 3
const S_I64 i64 = 3
const S_U8 u8 = 3
const S_U16 u16 = 3
const S_U32 u32 = 3
const S_U64 u64 = 3

const a_i8 [string, S_I8] = {"a", "b", "c"}
const a_i16 [string, S_I16] = {"a", "b", "c"}
const a_i32 [string, S_I32] = {"a", "b", "c"}
const a_i64 [string, S_I64] = {"a", "b", "c"}
const a_u8 [string, S_U8] = {"a", "b", "c"}
const a_u16 [string, S_U16] = {"a", "b", "c"}
const a_u32 [string, S_U32] = {"a", "b", "c"}
const a_u64 [string, S_U64] = {"a", "b", "c"}

do main() {
    if a_i8[0] == "a" && a_i8[2] == "c" {
        println("  [PASS] const i8 array size")
    } else {
        println("  [FAIL] const i8 array size")
    }

    if a_i16[0] == "a" && a_i16[2] == "c" {
        println("  [PASS] const i16 array size")
    } else {
        println("  [FAIL] const i16 array size")
    }

    if a_i32[0] == "a" && a_i32[2] == "c" {
        println("  [PASS] const i32 array size")
    } else {
        println("  [FAIL] const i32 array size")
    }

    if a_i64[0] == "a" && a_i64[2] == "c" {
        println("  [PASS] const i64 array size")
    } else {
        println("  [FAIL] const i64 array size")
    }

    if a_u8[0] == "a" && a_u8[2] == "c" {
        println("  [PASS] const u8 array size")
    } else {
        println("  [FAIL] const u8 array size")
    }

    if a_u16[0] == "a" && a_u16[2] == "c" {
        println("  [PASS] const u16 array size")
    } else {
        println("  [FAIL] const u16 array size")
    }

    if a_u32[0] == "a" && a_u32[2] == "c" {
        println("  [PASS] const u32 array size")
    } else {
        println("  [FAIL] const u32 array size")
    }

    if a_u64[0] == "a" && a_u64[2] == "c" {
        println("  [PASS] const u64 array size")
    } else {
        println("  [FAIL] const u64 array size")
    }
}
