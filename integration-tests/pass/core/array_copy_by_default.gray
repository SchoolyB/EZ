/*
 * array_copy_by_default.ez - Test array copy-by-default semantics
 *
 * Verifies that array assignment creates deep copies, not shallow
 * references. Modifying the copy should not affect the original.
 */


do main() {
    println("=== Array Copy-by-Default Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: basic array copy on declaration
    mut arr1 [int] = {1, 2, 3}
    mut arr2 [int] = arr1
    arr2[0] = 999
    if arr1[0] == 1 && arr2[0] == 999 {
        println("  [PASS] declaration copy is independent")
        passed += 1
    } otherwise {
        println("  [FAIL] arr1[0]=${arr1[0]}, arr2[0]=${arr2[0]}")
        failed += 1
    }

    // Test 2: array copy on reassignment
    mut a [int] = {10, 20, 30}
    mut b [int] = {0, 0, 0}
    b = a
    b[1] = 999
    if a[1] == 20 && b[1] == 999 {
        println("  [PASS] reassignment copy is independent")
        passed += 1
    } otherwise {
        println("  [FAIL] a[1]=${a[1]}, b[1]=${b[1]}")
        failed += 1
    }

    // Test 3: original unchanged after copy modification
    mut orig [int] = {5, 10, 15}
    mut dup [int] = orig
    dup[0] = 0
    dup[1] = 0
    dup[2] = 0
    if orig[0] == 5 && orig[1] == 10 && orig[2] == 15 {
        println("  [PASS] original fully unchanged after copy zeroed")
        passed += 1
    } otherwise {
        println("  [FAIL] original was modified")
        failed += 1
    }

    // Test 4: copy preserves length
    mut src [int] = {1, 2, 3, 4, 5}
    mut dst [int] = src
    if len(dst) == 5 {
        println("  [PASS] copy preserves length")
        passed += 1
    } otherwise {
        println("  [FAIL] len(dst)=${len(dst)}, expected 5")
        failed += 1
    }

    // Test 5: string array copy
    mut names1 [string] = {"Alice", "Bob"}
    mut names2 [string] = names1
    names2[0] = "Charlie"
    if names1[0] == "Alice" && names2[0] == "Charlie" {
        println("  [PASS] string array copy is independent")
        passed += 1
    } otherwise {
        println("  [FAIL] string array copy")
        failed += 1
    }

    // Test 6: copy vs ref — copy is independent, ref is shared
    mut data [int] = {100, 200}
    mut copied [int] = data
    mut shared = ref(data)
    copied[0] = 0
    shared[0] = 999
    if data[0] == 999 && copied[0] == 0 {
        println("  [PASS] copy independent, ref shared")
        passed += 1
    } otherwise {
        println("  [FAIL] copy vs ref behavior")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
