/*
 * bigint-overflow-checks.ez - Test that bigint checked arithmetic
 * works correctly within bounds (#1320).
 *
 * Verifies that overflow-checked add/sub/mul for i128, u128, i256, u256
 * produce correct results when values are within valid range.
 */

import @std
using std

do main() {
    println("=== BigInt Overflow Checks (Within Bounds) ===")
    mut passed int = 0
    mut failed int = 0

    // --- i128 checked arithmetic ---

    // Test 1: i128 add within bounds
    mut a i128 = i128(1000000) + i128(2000000)
    if a == i128(3000000) {
        println("  [PASS] i128 checked add within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 checked add within bounds")
        failed += 1
    }

    // Test 2: i128 sub within bounds
    mut b i128 = i128(5000000) - i128(3000000)
    if b == i128(2000000) {
        println("  [PASS] i128 checked sub within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 checked sub within bounds")
        failed += 1
    }

    // Test 3: i128 mul within bounds
    mut c i128 = i128(100000) * i128(100000)
    if c == i128(10000000000) {
        println("  [PASS] i128 checked mul within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 checked mul within bounds")
        failed += 1
    }

    // Test 4: i128 negative arithmetic
    mut d i128 = i128(-500) + i128(200)
    if d == i128(-300) {
        println("  [PASS] i128 checked add with negatives")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 checked add with negatives")
        failed += 1
    }

    // Test 5: i128 sub resulting in negative
    mut e i128 = i128(100) - i128(500)
    if e == i128(-400) {
        println("  [PASS] i128 checked sub to negative")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 checked sub to negative")
        failed += 1
    }

    // --- u128 checked arithmetic ---

    // Test 6: u128 add within bounds
    mut f u128 = u128(1000000) + u128(2000000)
    if f == u128(3000000) {
        println("  [PASS] u128 checked add within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 checked add within bounds")
        failed += 1
    }

    // Test 7: u128 sub within bounds
    mut g u128 = u128(5000000) - u128(3000000)
    if g == u128(2000000) {
        println("  [PASS] u128 checked sub within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 checked sub within bounds")
        failed += 1
    }

    // Test 8: u128 mul within bounds
    mut h u128 = u128(100000) * u128(100000)
    if h == u128(10000000000) {
        println("  [PASS] u128 checked mul within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 checked mul within bounds")
        failed += 1
    }

    // --- i256 checked arithmetic ---

    // Test 9: i256 add within bounds
    mut i i256 = i256(999999) + i256(1)
    if i == i256(1000000) {
        println("  [PASS] i256 checked add within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] i256 checked add within bounds")
        failed += 1
    }

    // Test 10: i256 sub within bounds
    mut j i256 = i256(1000000) - i256(999999)
    if j == i256(1) {
        println("  [PASS] i256 checked sub within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] i256 checked sub within bounds")
        failed += 1
    }

    // Test 11: i256 mul within bounds
    mut k i256 = i256(12345) * i256(67890)
    if k == i256(838102050) {
        println("  [PASS] i256 checked mul within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] i256 checked mul within bounds")
        failed += 1
    }

    // Test 12: i256 negative arithmetic
    mut l i256 = i256(-1000) + i256(500)
    if l == i256(-500) {
        println("  [PASS] i256 checked add with negatives")
        passed += 1
    } otherwise {
        println("  [FAIL] i256 checked add with negatives")
        failed += 1
    }

    // --- u256 checked arithmetic ---

    // Test 13: u256 add within bounds
    mut m u256 = u256(1000000) + u256(2000000)
    if m == u256(3000000) {
        println("  [PASS] u256 checked add within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] u256 checked add within bounds")
        failed += 1
    }

    // Test 14: u256 sub within bounds
    mut n u256 = u256(5000000) - u256(3000000)
    if n == u256(2000000) {
        println("  [PASS] u256 checked sub within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] u256 checked sub within bounds")
        failed += 1
    }

    // Test 15: u256 mul within bounds
    mut o u256 = u256(100000) * u256(100000)
    if o == u256(10000000000) {
        println("  [PASS] u256 checked mul within bounds")
        passed += 1
    } otherwise {
        println("  [FAIL] u256 checked mul within bounds")
        failed += 1
    }

    // Test 16: zero multiplication (edge case for checked mul)
    mut p i128 = i128(0) * i128(999999)
    if p == i128(0) {
        println("  [PASS] i128 checked mul by zero")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 checked mul by zero")
        failed += 1
    }

    // Test 17: multiply by one (identity, edge case)
    mut q u256 = u256(42) * u256(1)
    if q == u256(42) {
        println("  [PASS] u256 checked mul by one")
        passed += 1
    } otherwise {
        println("  [FAIL] u256 checked mul by one")
        failed += 1
    }

    // Test 18: subtract to zero
    mut r u128 = u128(12345) - u128(12345)
    if r == u128(0) {
        println("  [PASS] u128 checked sub to zero")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 checked sub to zero")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
