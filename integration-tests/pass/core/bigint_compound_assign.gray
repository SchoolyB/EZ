/*
 * bigint_compound_assign.gray - Test compound assignment operators on wide integers
 *
 * Covers: +=, -=, *=, /=, %= on i128, u128, i256, u256.
 */

do main() {
    println("=== Wide Integer Compound Assignment Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: i128 +=
    mut a i128 = i128(10)
    a += i128(5)
    if a == i128(15) {
        println("  [PASS] i128 +=")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 +=: got ${a}")
        failed += 1
    }

    // Test 2: i128 -=
    mut b i128 = i128(100)
    b -= i128(30)
    if b == i128(70) {
        println("  [PASS] i128 -=")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 -=: got ${b}")
        failed += 1
    }

    // Test 3: i128 *=
    mut c i128 = i128(7)
    c *= i128(6)
    if c == i128(42) {
        println("  [PASS] i128 *=")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 *=: got ${c}")
        failed += 1
    }

    // Test 4: i128 /=
    mut d i128 = i128(100)
    d /= i128(4)
    if d == i128(25) {
        println("  [PASS] i128 /=")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 /=: got ${d}")
        failed += 1
    }

    // Test 5: i128 %=
    mut e i128 = i128(17)
    e %= i128(5)
    if e == i128(2) {
        println("  [PASS] i128 %=")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 %=: got ${e}")
        failed += 1
    }

    // Test 6: u128 +=
    mut f u128 = u128(50)
    f += u128(25)
    if f == u128(75) {
        println("  [PASS] u128 +=")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 +=: got ${f}")
        failed += 1
    }

    // Test 7: u128 -=
    mut g u128 = u128(200)
    g -= u128(80)
    if g == u128(120) {
        println("  [PASS] u128 -=")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 -=: got ${g}")
        failed += 1
    }

    // Test 8: u128 *=
    mut h u128 = u128(12)
    h *= u128(3)
    if h == u128(36) {
        println("  [PASS] u128 *=")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 *=: got ${h}")
        failed += 1
    }

    // Test 9: i256 +=
    mut p i256 = i256(1000)
    p += i256(500)
    if p == i256(1500) {
        println("  [PASS] i256 +=")
        passed += 1
    } otherwise {
        println("  [FAIL] i256 +=: got ${p}")
        failed += 1
    }

    // Test 10: u256 *=
    mut q u256 = u256(7)
    q *= u256(11)
    if q == u256(77) {
        println("  [PASS] u256 *=")
        passed += 1
    } otherwise {
        println("  [FAIL] u256 *=: got ${q}")
        failed += 1
    }

    // Test 11: chained compound assignments
    mut r i128 = i128(1)
    r += i128(9)   // 10
    r *= i128(3)   // 30
    r -= i128(5)   // 25
    if r == i128(25) {
        println("  [PASS] chained compound assignments")
        passed += 1
    } otherwise {
        println("  [FAIL] chained compound assignments: got ${r}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
