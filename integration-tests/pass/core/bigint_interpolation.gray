/*
 * bigint-interpolation.gray - Test string interpolation with bigint types
 *
 * Verifies that i128, u128, i256, u256 values can be used directly
 * in string interpolation via their to_string functions.
 */


do main() {
    println("=== BigInt String Interpolation ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: i128 variable interpolation
    mut a i128 = i128(42)
    mut s1 string = "value: ${a}"
    if s1 == "value: 42" {
        println("  [PASS] i128 variable interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 variable interpolation, got '${s1}'")
        failed += 1
    }

    // Test 2: u128 variable interpolation
    mut b u128 = u128(999)
    mut s2 string = "value: ${b}"
    if s2 == "value: 999" {
        println("  [PASS] u128 variable interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 variable interpolation, got '${s2}'")
        failed += 1
    }

    // Test 3: i256 variable interpolation
    mut c i256 = i256(12345)
    mut s3 string = "value: ${c}"
    if s3 == "value: 12345" {
        println("  [PASS] i256 variable interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] i256 variable interpolation, got '${s3}'")
        failed += 1
    }

    // Test 4: u256 variable interpolation
    mut d u256 = u256(67890)
    mut s4 string = "value: ${d}"
    if s4 == "value: 67890" {
        println("  [PASS] u256 variable interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] u256 variable interpolation, got '${s4}'")
        failed += 1
    }

    // Test 5: bigint expression interpolation
    mut e i128 = i128(100) + i128(200)
    mut s5 string = "sum: ${e}"
    if s5 == "sum: 300" {
        println("  [PASS] i128 expression result interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 expression result interpolation, got '${s5}'")
        failed += 1
    }

    // Test 6: negative i128 interpolation
    mut f i128 = i128(-500)
    mut s6 string = "neg: ${f}"
    if s6 == "neg: -500" {
        println("  [PASS] negative i128 interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] negative i128 interpolation, got '${s6}'")
        failed += 1
    }

    // Test 7: i128 zero interpolation
    mut g i128 = i128(0)
    mut s7 string = "${g}"
    if s7 == "0" {
        println("  [PASS] i128 zero interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 zero interpolation, got '${s7}'")
        failed += 1
    }

    // Test 8: bigint mixed with other types in interpolation
    mut h u256 = u256(42)
    mut name string = "answer"
    mut s8 string = "the ${name} is ${h}"
    if s8 == "the answer is 42" {
        println("  [PASS] bigint mixed interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] bigint mixed interpolation, got '${s8}'")
        failed += 1
    }

    // Test 9: multiple bigints in one interpolation
    mut x i128 = i128(10)
    mut y u128 = u128(20)
    mut s9 string = "${x} and ${y}"
    if s9 == "10 and 20" {
        println("  [PASS] multiple bigints interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] multiple bigints interpolation, got '${s9}'")
        failed += 1
    }

    // Test 10: println with direct bigint interpolation
    mut z i256 = i256(7777)
    println("  [INFO] direct println interpolation: ${z}")

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
