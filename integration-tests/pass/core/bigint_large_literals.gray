/*
 * bigint_large_literals.gray - Test large literal parsing for bigint types
 *
 * Verifies that integer literals exceeding int64 max are accepted for
 * i128/u128/i256/u256 types and parsed via from_decimal() constructors.
 */


do main() {
    println("=== BigInt Large Literal Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: u128 literal at uint64 max
    mut u_max u128 = 18446744073709551615
    if u_max == u128(18446744073709551615) {
        println("  [PASS] u128 uint64 max literal")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 uint64 max literal")
        failed += 1
    }

    // Test 2: i128 literal above int64 max
    mut big i128 = 10000000000000000000
    mut expected i128 = i128(1000000000) * i128(10000000000)
    if big == expected {
        println("  [PASS] i128 literal 10^19")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 literal 10^19")
        failed += 1
    }

    // Test 3: negative i128 literal beyond int64 min
    mut neg i128 = -9223372036854775808
    mut neg_check i128 = i128(0) - i128(9223372036854775807) - i128(1)
    if neg == neg_check {
        println("  [PASS] negative i128 literal at int64 min")
        passed += 1
    } otherwise {
        println("  [FAIL] negative i128 literal at int64 min")
        failed += 1
    }

    // Test 4: arithmetic with large literals
    mut a i128 = 9223372036854775808
    mut b i128 = a + i128(1)
    mut c i128 = i128(9223372036854775807) + i128(2)
    if b == c {
        println("  [PASS] arithmetic with large i128 literal")
        passed += 1
    } otherwise {
        println("  [FAIL] arithmetic with large i128 literal")
        failed += 1
    }

    // Test 5: u64 max literal (also overflows int64)
    mut u64_max u64 = 18446744073709551615
    if u64_max > 0 {
        println("  [PASS] u64 max literal accepted")
        passed += 1
    } otherwise {
        println("  [FAIL] u64 max literal")
        failed += 1
    }

    // Test 6: i128 comparison with large literal
    mut val i128 = 10000000000000000000
    if val > i128(9223372036854775807) {
        println("  [PASS] i128 large literal > int64 max")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 large literal comparison")
        failed += 1
    }

    // Test 7: u128 addition beyond uint64 max
    mut x u128 = 18446744073709551615
    mut y u128 = x + u128(1)
    // Verify by subtracting back
    mut check u128 = y - u128(18446744073709551615)
    if check == u128(1) {
        println("  [PASS] u128 addition beyond uint64 max")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 addition beyond uint64 max")
        failed += 1
    }

    // Test 8: i128 multiplication producing large result
    mut m i128 = 10000000000000000000
    mut n i128 = m * i128(10)
    mut expect i128 = 100000000000000000000
    if n == expect {
        println("  [PASS] i128 mul to 10^20 with large literal check")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 mul large result")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
