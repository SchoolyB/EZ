/*
 * bigint_when_is.ez - Test wide integers in when/is blocks (#1804)
 *
 * Covers: i128, u128, i256, u256 as when subjects, arithmetic
 * expressions in is arms, default branch.
 */

do classify_i128(n i128) -> string {
    when n {
        is i128(0)   { return "zero" }
        is i128(1)   { return "one" }
        is i128(42)  { return "answer" }
        is i128(100) { return "hundred" }
        default      { return "other" }
    }
}

do classify_u128(n u128) -> string {
    when n {
        is u128(0)    { return "zero" }
        is u128(1000) { return "thousand" }
        default       { return "other" }
    }
}

do main() {
    println("=== Wide Integer when/is Test (#1804) ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: i128 when/is matches first arm
    if classify_i128(i128(0)) == "zero" {
        println("  [PASS] i128 when/is: zero")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 when/is: zero")
        failed += 1
    }

    // Test 2: i128 when/is matches second arm
    if classify_i128(i128(42)) == "answer" {
        println("  [PASS] i128 when/is: answer")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 when/is: answer")
        failed += 1
    }

    // Test 3: i128 when/is falls to default
    if classify_i128(i128(999)) == "other" {
        println("  [PASS] i128 when/is: default branch")
        passed += 1
    } otherwise {
        println("  [FAIL] i128 when/is: default branch")
        failed += 1
    }

    // Test 4: u128 when/is matches
    if classify_u128(u128(1000)) == "thousand" {
        println("  [PASS] u128 when/is: thousand")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 when/is: thousand")
        failed += 1
    }

    // Test 5: u128 when/is default
    if classify_u128(u128(7)) == "other" {
        println("  [PASS] u128 when/is: default")
        passed += 1
    } otherwise {
        println("  [FAIL] u128 when/is: default")
        failed += 1
    }

    // Test 6: inline when/is with i256
    mut big i256 = i256(999)
    mut label string = "unknown"
    when big {
        is i256(0)   { label = "zero" }
        is i256(999) { label = "nine-nine-nine" }
        default      { label = "other" }
    }
    if label == "nine-nine-nine" {
        println("  [PASS] i256 when/is inline")
        passed += 1
    } otherwise {
        println("  [FAIL] i256 when/is inline: got ${label}")
        failed += 1
    }

    // Test 7: when/is with expression that doesn't match → default
    mut x u256 = u256(123456)
    mut result string = "none"
    when x {
        is u256(1) { result = "one" }
        is u256(2) { result = "two" }
        default    { result = "large" }
    }
    if result == "large" {
        println("  [PASS] u256 when/is default for unmatched value")
        passed += 1
    } otherwise {
        println("  [FAIL] u256 when/is default: got ${result}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
