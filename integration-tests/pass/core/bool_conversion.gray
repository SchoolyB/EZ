/*
 * Test: bool() builtin conversion
 * bool(0) -> false, bool(nonzero) -> true
 */

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: bool(0) -> false
    mut a bool = bool(0)
    if a == false {
        println("  [PASS] bool(0) == false")
        passed += 1
    } otherwise {
        println("  [FAIL] bool(0): expected false, got true")
        failed += 1
    }

    // Test 2: bool(1) -> true
    mut b bool = bool(1)
    if b == true {
        println("  [PASS] bool(1) == true")
        passed += 1
    } otherwise {
        println("  [FAIL] bool(1): expected true, got false")
        failed += 1
    }

    // Test 3: bool(42) -> true
    mut c bool = bool(42)
    if c == true {
        println("  [PASS] bool(42) == true")
        passed += 1
    } otherwise {
        println("  [FAIL] bool(42): expected true, got false")
        failed += 1
    }

    // Test 4: bool from int variable
    mut x int = 0
    mut d bool = bool(x)
    if d == false {
        println("  [PASS] bool(int 0) == false")
        passed += 1
    } otherwise {
        println("  [FAIL] bool(int 0): expected false")
        failed += 1
    }

    // Test 5: bool from float
    mut e bool = bool(1.5)
    if e == true {
        println("  [PASS] bool(1.5) == true")
        passed += 1
    } otherwise {
        println("  [FAIL] bool(1.5): expected true")
        failed += 1
    }

    // Test 6: bool(false) -> false (identity)
    mut f bool = bool(false)
    if f == false {
        println("  [PASS] bool(false) == false")
        passed += 1
    } otherwise {
        println("  [FAIL] bool(false): expected false")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
