/*
 * c_interop.gray - Test C interop via import c"header.h"
 *
 * Covers: calling C functions, accessing C constants,
 * multiple C header imports.
 */

import c "stdio.h"
import c "stdlib.h"

do main() {
    println("=== C Interop Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: call C function
    c.puts("  hello from c.puts")
    passed += 1

    // Test 2: access C constants
    if c.EXIT_SUCCESS == 0 {
        println("  [PASS] c.EXIT_SUCCESS == 0")
        passed += 1
    } otherwise {
        println("  [FAIL] c.EXIT_SUCCESS")
        failed += 1
    }

    if c.EXIT_FAILURE == 1 {
        println("  [PASS] c.EXIT_FAILURE == 1")
        passed += 1
    } otherwise {
        println("  [FAIL] c.EXIT_FAILURE")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
