/*
 * cast_conversions.ez - Test cast() conversion functions (#1329)
 *
 * Verifies that cast() dispatches to proper conversion functions
 * for string/bool/float/int conversions instead of raw C casts.
 */


do main() {
    println("=== Cast Conversion Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: int → string
    mut s1 string = cast(42, string)
    if s1 == "42" {
        println("  [PASS] cast(42, string) == '42'")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(42, string) got '${s1}'")
        failed += 1
    }

    // Test 2: negative int → string
    mut s2 string = cast(-99, string)
    if s2 == "-99" {
        println("  [PASS] cast(-99, string) == '-99'")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(-99, string) got '${s2}'")
        failed += 1
    }

    // Test 3: float → string
    mut s3 string = cast(3.14, string)
    if s3 == "3.14" {
        println("  [PASS] cast(3.14, string) == '3.14'")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(3.14, string) got '${s3}'")
        failed += 1
    }

    // Test 4: bool → string
    mut s4 string = cast(true, string)
    if s4 == "true" {
        println("  [PASS] cast(true, string) == 'true'")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(true, string) got '${s4}'")
        failed += 1
    }

    // Test 5: bool false → string
    mut s5 string = cast(false, string)
    if s5 == "false" {
        println("  [PASS] cast(false, string) == 'false'")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(false, string) got '${s5}'")
        failed += 1
    }

    // Test 6: float → int (truncation)
    mut i3 int = cast(9.99, int)
    if i3 == 9 {
        println("  [PASS] cast(9.99, int) == 9 (truncated)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(9.99, int) got ${i3}")
        failed += 1
    }

    // Test 10: int → float
    mut f2 float = cast(42, float)
    if f2 > 41.99 && f2 < 42.01 {
        println("  [PASS] cast(42, float) == 42.0")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(42, float) got ${f2}")
        failed += 1
    }

    // Test 11: zero → string
    mut s6 string = cast(0, string)
    if s6 == "0" {
        println("  [PASS] cast(0, string) == '0'")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(0, string) got '${s6}'")
        failed += 1
    }

    // Test 10: int variable → string
    mut num int = 777
    mut s7 string = cast(num, string)
    if s7 == "777" {
        println("  [PASS] cast(variable, string) == '777'")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(variable, string) got '${s7}'")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
