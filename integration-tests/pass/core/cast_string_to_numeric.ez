/*
 * cast_string_to_numeric.ez - Test cast(string, <numeric>) for all targets (#1598)
 *
 * Verifies that string-to-numeric casts work for all numeric types,
 * not just int/float. Previously, targets like uint, i8, u16, etc.
 * crashed at C compilation.
 */

do main() {
    println("=== Cast String to Numeric Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: string → uint
    mut u uint = cast("42", uint)
    if u == 42 {
        println("  [PASS] cast(string, uint)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, uint)")
        failed += 1
    }

    // Test 2: string → i8
    mut i8v i8 = cast("100", i8)
    if i8v == 100 {
        println("  [PASS] cast(string, i8)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, i8)")
        failed += 1
    }

    // Test 3: string → i16
    mut i16v i16 = cast("1000", i16)
    if i16v == 1000 {
        println("  [PASS] cast(string, i16)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, i16)")
        failed += 1
    }

    // Test 4: string → i32
    mut i32v i32 = cast("50000", i32)
    if i32v == 50000 {
        println("  [PASS] cast(string, i32)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, i32)")
        failed += 1
    }

    // Test 5: string → u8
    mut u8v u8 = cast("200", u8)
    if u8v == 200 {
        println("  [PASS] cast(string, u8)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, u8)")
        failed += 1
    }

    // Test 6: string → u16
    mut u16v u16 = cast("60000", u16)
    if u16v == 60000 {
        println("  [PASS] cast(string, u16)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, u16)")
        failed += 1
    }

    // Test 7: string → u32
    mut u32v u32 = cast("3000000", u32)
    if u32v == 3000000 {
        println("  [PASS] cast(string, u32)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, u32)")
        failed += 1
    }

    // Test 8: string → f32
    mut f32v f32 = cast("3.14", f32)
    if f32v > 3.13 && f32v < 3.15 {
        println("  [PASS] cast(string, f32)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, f32)")
        failed += 1
    }

    // Test 9: string → u64
    mut u64v u64 = cast("999", u64)
    if u64v == 999 {
        println("  [PASS] cast(string, u64)")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(string, u64)")
        failed += 1
    }

    // Test 10: char → string (should produce character, not ASCII value)
    mut c char = 'A'
    mut s string = cast(c, string)
    if s == "A" {
        println("  [PASS] cast(char, string) == 'A'")
        passed += 1
    } otherwise {
        println("  [FAIL] cast(char, string) got '${s}'")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
