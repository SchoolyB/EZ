/*
 * Pass Test: circular value-type struct references with multi-return
 *
 * Verifies that the compiler does not segfault when a multi-return function
 * returns a struct involved in a circular value-type reference chain.
 * Previously crashed in emit_struct_deep_copy / type_needs_deep_copy due to
 * missing cycle detection. (#1784)
 *
 * Covers:
 *  - Two-way cycle: Parent has [Child], Child has Parent value
 *  - Three-way cycle: Alpha has [Beta], Beta has Gamma, Gamma has Alpha
 *  - Default param with circular struct multi-return (original user report)
 *  - Self-referential struct with single-return (regression guard)
 */

// --- Two-way cycle ---
const Parent struct {
    name string
    children [Child]
}

const Child struct {
    label string
    owner Parent
}

do make_parent(name string) -> (Parent, bool) {
    mut p = new(Parent)
    p^.name = name
    return p^, true
}

// --- Three-way cycle ---
const Alpha struct {
    value int
    betas [Beta]
}

const Beta struct {
    value int
    gamma Gamma
}

const Gamma struct {
    value int
    origin Alpha
}

do make_alpha(v int) -> (Alpha, bool) {
    mut a = new(Alpha)
    a^.value = v
    return a^, true
}

// --- Default param + deeper cycle (original user report pattern) ---
const DataKind enum {
    PRIMARY = 0,
    BACKUP
}

const Collection struct {
    name string
    clusters [Cluster]
}

const Cluster struct {
    name string
    parent Collection
    records [Record]
}

const Record struct {
    name string
    parent Cluster
}

do create_collection(n string, kind DataKind = DataKind.PRIMARY) -> (Collection, bool) {
    mut c = new(Collection)
    c^.name = n
    return c^, true
}

// --- Self-referential (single-return, regression guard) ---
const TreeNode struct {
    value int
    children [TreeNode]
}

do make_tree_node(v int) -> TreeNode {
    mut n = new(TreeNode)
    n^.value = v
    return n^
}

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: two-way cycle multi-return ok flag
    mut p, ok1 = make_parent("root")
    if ok1 {
        println("  [PASS] two-way cycle: multi-return ok")
        passed += 1
    } otherwise {
        println("  [FAIL] two-way cycle: multi-return ok")
        failed += 1
    }

    // Test 2: two-way cycle field access
    if p.name == "root" {
        println("  [PASS] two-way cycle: field access")
        passed += 1
    } otherwise {
        println("  [FAIL] two-way cycle: field access, got '${p.name}'")
        failed += 1
    }

    // Test 3: two-way cycle empty nested array
    if len(p.children) == 0 {
        println("  [PASS] two-way cycle: empty children array")
        passed += 1
    } otherwise {
        println("  [FAIL] two-way cycle: expected empty children")
        failed += 1
    }

    // Test 4: three-way cycle multi-return
    mut a, ok2 = make_alpha(42)
    if ok2 && a.value == 42 {
        println("  [PASS] three-way cycle: multi-return value")
        passed += 1
    } otherwise {
        println("  [FAIL] three-way cycle: multi-return value")
        failed += 1
    }

    // Test 5: default param + deep cycle multi-return
    mut col, ok3 = create_collection("mydata")
    if ok3 && col.name == "mydata" {
        println("  [PASS] default-param + deep cycle: multi-return")
        passed += 1
    } otherwise {
        println("  [FAIL] default-param + deep cycle: multi-return")
        failed += 1
    }

    // Test 6: self-referential single-return (regression)
    mut root = make_tree_node(99)
    if root.value == 99 {
        println("  [PASS] self-referential single-return")
        passed += 1
    } otherwise {
        println("  [FAIL] self-referential single-return")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
