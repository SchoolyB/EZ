/*
 * copy_semantics_ref.ez - Test ref() and copy() builtins (#661)
 *
 * Split from copy_semantics.ez to run the passing subset in ezc.
 * Array copy-by-default (Test 2 in original) is excluded — that
 * requires copy-by-default semantics not yet in the compiler.
 */


const Point struct {
    x int
    y int
}

const Nested struct {
    inner Point
    value int
}

do main() {
    println("=== Copy Semantics (ref/copy) Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: struct copy-by-default
    mut p1 Point = Point{x: 10, y: 20}
    mut p2 Point = p1
    p2.x = 999
    if p1.x == 10 && p2.x == 999 {
        println("  [PASS] struct assignment creates copy")
        passed += 1
    } otherwise {
        println("  [FAIL] struct assignment: p1.x=${p1.x}, p2.x=${p2.x}")
        failed += 1
    }

    // Test 2: nested struct copy-by-default
    mut n1 Nested = Nested{inner: Point{x: 5, y: 10}, value: 100}
    mut n2 Nested = n1
    n2.inner.x = 999
    n2.value = 888
    if n1.inner.x == 5 && n1.value == 100 && n2.inner.x == 999 && n2.value == 888 {
        println("  [PASS] nested struct assignment creates deep copy")
        passed += 1
    } otherwise {
        println("  [FAIL] nested struct copy")
        failed += 1
    }

    // Test 3: reassignment also copies
    mut p3 Point = Point{x: 1, y: 2}
    mut p4 Point = Point{x: 0, y: 0}
    p4 = p3
    p4.x = 999
    if p3.x == 1 && p4.x == 999 {
        println("  [PASS] reassignment also creates copy")
        passed += 1
    } otherwise {
        println("  [FAIL] reassignment copy")
        failed += 1
    }

    // Test 4: ref() for struct sharing
    mut p5 Point = Point{x: 100, y: 200}
    mut p6 = ref(p5)
    p6.x = 500
    if p5.x == 500 && p6.x == 500 {
        println("  [PASS] ref() creates shared struct reference")
        passed += 1
    } otherwise {
        println("  [FAIL] ref() struct: p5.x=${p5.x}, p6.x=${p6.x}")
        failed += 1
    }

    // Test 5: ref() for primitive sharing
    mut x int = 10
    mut y = ref(x)
    y = 99
    if x == 99 && y == 99 {
        println("  [PASS] ref() works on primitives")
        passed += 1
    } otherwise {
        println("  [FAIL] ref() primitive: x=${x}, y=${y}")
        failed += 1
    }

    // Test 6: ref() for array sharing
    mut arr3 [int] = {10, 20, 30}
    mut arr4 = ref(arr3)
    arr4[0] = 999
    if arr3[0] == 999 && arr4[0] == 999 {
        println("  [PASS] ref() creates shared array reference")
        passed += 1
    } otherwise {
        println("  [FAIL] ref() array: arr3[0]=${arr3[0]}, arr4[0]=${arr4[0]}")
        failed += 1
    }

    // Test 7: multiple refs share same variable
    mut val int = 42
    mut ref1 = ref(val)
    mut ref2 = ref(val)
    ref1 = 100
    if val == 100 && ref1 == 100 && ref2 == 100 {
        println("  [PASS] multiple refs share same variable")
        passed += 1
    } otherwise {
        println("  [FAIL] multiple refs: val=${val}")
        failed += 1
    }

    // Test 8: explicit copy() still works
    mut p7 Point = Point{x: 1, y: 2}
    mut p8 Point = copy(p7)
    p8.x = 999
    if p7.x == 1 && p8.x == 999 {
        println("  [PASS] copy() still creates explicit copy")
        passed += 1
    } otherwise {
        println("  [FAIL] copy(): p7.x=${p7.x}, p8.x=${p8.x}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
