/*
 * doc_struct_function.gray - #doc attribute on struct functions
 *
 * #doc on a function inside a struct body
 * leaked to the generated C as a field name. Parser now skips the
 * attribute and any parenthesised args before the do declaration.
 */

const Math struct {
    _pad int

    #doc("Adds two numbers")
    do add(a int, b int) -> int {
        return a + b
    }

    #doc
    do sub(a int, b int) -> int {
        return a - b
    }

    #doc("Multiplies")
    #doc("Two numbers")
    do mul(a int, b int) -> int {
        return a * b
    }
}

do main() {
    println("=== #doc Struct Function Test ===")
    mut passed int = 0
    mut failed int = 0

    if Math.add(3, 4) == 7 {
        println("  [PASS] #doc with args on struct fn")
        passed += 1
    } otherwise {
        println("  [FAIL] add")
        failed += 1
    }

    if Math.sub(10, 3) == 7 {
        println("  [PASS] bare #doc on struct fn")
        passed += 1
    } otherwise {
        println("  [FAIL] sub")
        failed += 1
    }

    if Math.mul(6, 7) == 42 {
        println("  [PASS] stacked #doc on struct fn")
        passed += 1
    } otherwise {
        println("  [FAIL] mul")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
