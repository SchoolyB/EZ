/*
 * else_alias.gray - else as alias for otherwise
 *
 * `else` is a syntax alias for `otherwise`.
 * Both keywords produce the same token, so they are interchangeable.
 */

do main() {
    mut passed int = 0
    mut failed int = 0

    // -- else in if/else --
    mut x int = 10
    if x > 20 {
        failed += 1
    } else {
        passed += 1
    }

    // -- else in if/or/else chain --
    if x > 100 {
        failed += 1
    } or x == 5 {
        failed += 1
    } else {
        passed += 1
    }

    // -- mixing else with or (else acts as otherwise) --
    mut name string = "Grayscale"
    if name == "Go" {
        failed += 1
    } or name == "Rust" {
        failed += 1
    } else {
        passed += 1
    }

    println("else_alias: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("FAIL")
    } else {
        println("PASS")
    }
}
