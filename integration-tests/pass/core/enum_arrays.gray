/*
 * enum_arrays.ez - Test integer and string enum arrays (#1801, #1802)
 *
 * Covers: declaring enum arrays, accessing elements, iterating,
 * reassigning elements, and passing enum arrays to functions.
 */

const Direction enum {
    NORTH
    EAST
    SOUTH
    WEST
}

const Color enum {
    RED   = "red"
    GREEN = "green"
    BLUE  = "blue"
}

do count_north(dirs [Direction], n int) -> int {
    mut count int = 0
    for i in range(0, n) {
        if dirs[i] == Direction.NORTH {
            count += 1
        }
    }
    return count
}

do main() {
    println("=== Enum Arrays Test (#1801, #1802) ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: integer enum array declaration and access
    mut dirs [Direction] = {Direction.NORTH, Direction.EAST, Direction.SOUTH}
    if dirs[0] == Direction.NORTH && dirs[1] == Direction.EAST && dirs[2] == Direction.SOUTH {
        println("  [PASS] integer enum array access")
        passed += 1
    } otherwise {
        println("  [FAIL] integer enum array access")
        failed += 1
    }

    // Test 2: integer enum array element reassignment
    dirs[2] = Direction.WEST
    if dirs[2] == Direction.WEST {
        println("  [PASS] integer enum array element reassignment")
        passed += 1
    } otherwise {
        println("  [FAIL] integer enum array element reassignment")
        failed += 1
    }

    // Test 3: pass integer enum array to function
    mut dirs2 [Direction] = {Direction.NORTH, Direction.SOUTH, Direction.NORTH, Direction.EAST}
    mut cnt int = count_north(dirs2, 4)
    if cnt == 2 {
        println("  [PASS] pass integer enum array to function")
        passed += 1
    } otherwise {
        println("  [FAIL] pass integer enum array to function: got ${cnt}")
        failed += 1
    }

    // Test 4: string enum array declaration and access
    mut colors [Color] = {Color.RED, Color.GREEN, Color.BLUE}
    if colors[0] == "red" && colors[1] == "green" && colors[2] == "blue" {
        println("  [PASS] string enum array access")
        passed += 1
    } otherwise {
        println("  [FAIL] string enum array access: ${colors[0]}, ${colors[1]}, ${colors[2]}")
        failed += 1
    }

    // Test 5: string enum array element reassignment
    colors[0] = Color.BLUE
    if colors[0] == "blue" {
        println("  [PASS] string enum array element reassignment")
        passed += 1
    } otherwise {
        println("  [FAIL] string enum array element reassignment: got ${colors[0]}")
        failed += 1
    }

    // Test 6: integer enum array iteration with for loop
    mut dirs3 [Direction] = {Direction.NORTH, Direction.EAST, Direction.SOUTH, Direction.WEST}
    mut sum int = 0
    for i in range(0, 4) {
        sum += dirs3[i]
    }
    // NORTH=0, EAST=1, SOUTH=2, WEST=3 → sum=6
    if sum == 6 {
        println("  [PASS] integer enum array sum via for loop")
        passed += 1
    } otherwise {
        println("  [FAIL] integer enum array sum: got ${sum}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
