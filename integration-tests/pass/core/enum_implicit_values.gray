/*
 * enum_implicit_values.gray - Enum implicit values continue from
 * the last explicit value.
 *
 * implicit entries used the 0-based position
 * index (`= j`) instead of continuing from the previous explicit
 * value. `PENDING = 10, ACTIVE` gave ACTIVE = 1 instead of 11.
 */

const Status enum {
    PENDING = 10,
    ACTIVE,
    DONE = 20
}

const Mixed enum {
    A,
    B,
    C = 100,
    D,
    E = 200,
    F,
    G
}

do main() {
    println("=== Enum Implicit Values Test ===")
    mut passed int = 0
    mut failed int = 0

    // Assign enum values to int variables, then compare
    mut sp int = Status.PENDING
    mut sa int = Status.ACTIVE
    mut sd int = Status.DONE
    if sp == 10 && sa == 11 && sd == 20 {
        println("  [PASS] PENDING=10, ACTIVE=11, DONE=20")
        passed += 1
    } otherwise {
        println("  [FAIL] Status: ${sp}, ${sa}, ${sd}")
        failed += 1
    }

    mut ma int = Mixed.A
    mut mb int = Mixed.B
    mut mc int = Mixed.C
    mut md int = Mixed.D
    mut me int = Mixed.E
    mut mf int = Mixed.F
    mut mg int = Mixed.G
    if ma == 0 && mb == 1 && mc == 100 && md == 101 &&
       me == 200 && mf == 201 && mg == 202 {
        println("  [PASS] A=0, B=1, C=100, D=101, E=200, F=201, G=202")
        passed += 1
    } otherwise {
        println("  [FAIL] Mixed: A=${ma} B=${mb} C=${mc} D=${md} E=${me} F=${mf} G=${mg}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
