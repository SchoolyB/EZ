/*
 * enums.ez - Test enum definitions and usage
 */


/* Basic int enum (auto-incremented 0, 1, 2, 3) */
const Direction enum {
    NORTH
    EAST
    SOUTH
    WEST
}

/* Flags enum with power-of-2 values (1, 2, 4, 8) */
#flags
const Permissions enum {
    READ      // 1
    WRITE     // 2
    EXECUTE   // 4
    DELETE    // 8
}

/* String enum with explicit values */
const Status enum {
    TODO = "todo"
    IN_PROGRESS = "in_progress"
    DONE = "done"
}

/* Int enum without explicit attribute (auto-detected) */
const Priority enum {
    LOW       // 0
    MEDIUM    // 1
    HIGH      // 2
}

do main() {
    println("=== Enums Test ===")
    mut passed int = 0
    mut failed int = 0

    // ==================== BASIC INT ENUM ====================
    println("  -- Basic Int Enum --")

    // Test 1: first enum value is 0
    mut n int = Direction.NORTH
    if n == 0 {
        println("  [PASS] Direction.NORTH = 0")
        passed += 1
    } otherwise {
        println("  [FAIL] Direction.NORTH: expected 0, got ${n}")
        failed += 1
    }

    // Test 2: auto-increment
    mut e int = Direction.EAST
    mut s int = Direction.SOUTH
    mut w int = Direction.WEST
    if e == 1 && s == 2 && w == 3 {
        println("  [PASS] enum auto-increment (1, 2, 3)")
        passed += 1
    } otherwise {
        println("  [FAIL] enum auto-increment")
        failed += 1
    }

    // Test 3: store enum in variable
    mut current int = Direction.SOUTH
    if current == 2 {
        println("  [PASS] enum value in variable")
        passed += 1
    } otherwise {
        println("  [FAIL] enum in variable: expected 2, got ${current}")
        failed += 1
    }

    // ==================== FLAGS ENUM ====================
    println("  -- Flags Enum (power-of-2) --")

    // Test 4: first flag value is 1
    mut r int = Permissions.READ
    if r == 1 {
        println("  [PASS] Permissions.READ = 1")
        passed += 1
    } otherwise {
        println("  [FAIL] Permissions.READ: expected 1, got ${r}")
        failed += 1
    }

    // Test 5: power-of-2 values
    mut wr int = Permissions.WRITE
    if wr == 2 {
        println("  [PASS] Permissions.WRITE = 2")
        passed += 1
    } otherwise {
        println("  [FAIL] Permissions.WRITE: expected 2, got ${wr}")
        failed += 1
    }

    // Test 6: continue power-of-2
    mut ex int = Permissions.EXECUTE
    mut dl int = Permissions.DELETE
    if ex == 4 && dl == 8 {
        println("  [PASS] Permissions.EXECUTE=4, DELETE=8")
        passed += 1
    } otherwise {
        println("  [FAIL] flags enum: EXECUTE=${ex}, DELETE=${dl}")
        failed += 1
    }

    // ==================== STRING ENUM ====================
    println("  -- String Enum --")

    // Test 7: string enum value
    if Status.TODO == "todo" {
        println("  [PASS] Status.TODO = \"todo\"")
        passed += 1
    } otherwise {
        println("  [FAIL] Status.TODO: expected \"todo\", got \"${Status.TODO}\"")
        failed += 1
    }

    // Test 8: other string values
    if Status.IN_PROGRESS == "in_progress" && Status.DONE == "done" {
        println("  [PASS] Status.IN_PROGRESS and DONE")
        passed += 1
    } otherwise {
        println("  [FAIL] string enum values")
        failed += 1
    }

    // Test 9: string enum in variable
    mut current_status string = Status.IN_PROGRESS
    if current_status == "in_progress" {
        println("  [PASS] string enum in variable")
        passed += 1
    } otherwise {
        println("  [FAIL] string enum in variable: got \"${current_status}\"")
        failed += 1
    }

    // ==================== INT ENUM (auto-detected) ====================
    println("  -- Int Enum (auto-detected) --")

    // Test 10: int enum auto-increment works without any attribute
    mut lo int = Priority.LOW
    mut md int = Priority.MEDIUM
    mut hi int = Priority.HIGH
    if lo == 0 && md == 1 && hi == 2 {
        println("  [PASS] int enum auto-increment (0, 1, 2)")
        passed += 1
    } otherwise {
        println("  [FAIL] int enum: LOW=${lo}, MEDIUM=${md}, HIGH=${hi}")
        failed += 1
    }

    // ==================== ENUM COMPARISON ====================
    println("  -- Enum Comparison --")

    // Test 11: compare enum values via int variables
    mut priority int = Priority.HIGH
    if priority >= Priority.MEDIUM {
        println("  [PASS] enum comparison (HIGH >= MEDIUM)")
        passed += 1
    } otherwise {
        println("  [FAIL] enum comparison")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
