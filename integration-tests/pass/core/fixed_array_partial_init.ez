/* Test: Fixed-size arrays with full initialization
 * Related to #1238 (W3003) — verifies that fully initialized
 * fixed-size arrays work correctly at runtime.
 * Expected: all tests pass with no warnings
 */

import @std
using std

do main() {
    println("=== Fixed Array Init Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: fully initialized int array
    mut ints [int, 3] = {10, 20, 30}
    if ints[0] == 10 && ints[1] == 20 && ints[2] == 30 {
        println("  [PASS] fully initialized int array")
        passed += 1
    } otherwise {
        println("  [FAIL] fully initialized int array")
        failed += 1
    }

    // Test 2: len() reports fixed size
    if len(ints) == 3 {
        println("  [PASS] len() reports correct size")
        passed += 1
    } otherwise {
        println("  [FAIL] len() — got ${len(ints)}")
        failed += 1
    }

    // Test 3: modification of fixed-size array elements
    ints[1] = 99
    if ints[1] == 99 {
        println("  [PASS] fixed-size array element modification")
        passed += 1
    } otherwise {
        println("  [FAIL] fixed-size array element modification")
        failed += 1
    }

    // Test 4: larger fixed-size array
    mut big [int, 5] = {1, 2, 3, 4, 5}
    if big[0] == 1 && big[4] == 5 && len(big) == 5 {
        println("  [PASS] larger fixed-size array fully initialized")
        passed += 1
    } otherwise {
        println("  [FAIL] larger fixed-size array")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
