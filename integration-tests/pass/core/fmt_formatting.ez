/*
 * fmt_formatting.ez - Integration tests for @fmt formatting functions
 * Tests: format, pad_left, pad_right, center,
 *        int_to_hex, int_to_binary, int_to_octal,
 *        float_fixed, float_sci
 */

import @fmt

do main() {
    println("=== Fmt Formatting Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: format with string and int
    mut s1 string = fmt.format("Hello %s, you are %d", "Alice", 30)
    if s1 == "Hello Alice, you are 30" {
        println("  [PASS] format with string and int")
        passed += 1
    } otherwise {
        println("  [FAIL] format: got '${s1}'")
        failed += 1
    }

    // Test 2: format with no extra args
    mut s2 string = fmt.format("plain text")
    if s2 == "plain text" {
        println("  [PASS] format with no args")
        passed += 1
    } otherwise {
        println("  [FAIL] format no args: got '${s2}'")
        failed += 1
    }

    // Test 3: pad_left
    mut pl string = fmt.pad_left("42", 8, '0')
    if pl == "00000042" {
        println("  [PASS] pad_left")
        passed += 1
    } otherwise {
        println("  [FAIL] pad_left: got '${pl}'")
        failed += 1
    }

    // Test 4: pad_left when string already wider
    mut pl2 string = fmt.pad_left("longstring", 4, '0')
    if pl2 == "longstring" {
        println("  [PASS] pad_left no-op")
        passed += 1
    } otherwise {
        println("  [FAIL] pad_left no-op: got '${pl2}'")
        failed += 1
    }

    // Test 5: pad_right
    mut pr string = fmt.pad_right("hi", 6, '.')
    if pr == "hi...." {
        println("  [PASS] pad_right")
        passed += 1
    } otherwise {
        println("  [FAIL] pad_right: got '${pr}'")
        failed += 1
    }

    // Test 6: pad_right when string already wider
    mut pr2 string = fmt.pad_right("longstring", 4, '.')
    if pr2 == "longstring" {
        println("  [PASS] pad_right no-op")
        passed += 1
    } otherwise {
        println("  [FAIL] pad_right no-op: got '${pr2}'")
        failed += 1
    }

    // Test 7: center
    mut ct string = fmt.center("hi", 8, '-')
    if ct == "---hi---" {
        println("  [PASS] center")
        passed += 1
    } otherwise {
        println("  [FAIL] center: got '${ct}'")
        failed += 1
    }

    // Test 8: center with odd padding
    mut ct2 string = fmt.center("hi", 7, '-')
    if ct2 == "--hi---" {
        println("  [PASS] center odd padding")
        passed += 1
    } otherwise {
        println("  [FAIL] center odd: got '${ct2}'")
        failed += 1
    }

    // Test 9: center no-op
    mut ct3 string = fmt.center("longstring", 4, '-')
    if ct3 == "longstring" {
        println("  [PASS] center no-op")
        passed += 1
    } otherwise {
        println("  [FAIL] center no-op: got '${ct3}'")
        failed += 1
    }

    // Test 10: int_to_hex
    mut hex string = fmt.int_to_hex(255)
    if hex == "ff" {
        println("  [PASS] int_to_hex")
        passed += 1
    } otherwise {
        println("  [FAIL] int_to_hex: got '${hex}'")
        failed += 1
    }

    // Test 11: int_to_hex zero
    mut hex0 string = fmt.int_to_hex(0)
    if hex0 == "0" {
        println("  [PASS] int_to_hex zero")
        passed += 1
    } otherwise {
        println("  [FAIL] int_to_hex zero: got '${hex0}'")
        failed += 1
    }

    // Test 12: int_to_binary
    mut bin string = fmt.int_to_binary(10)
    if bin == "1010" {
        println("  [PASS] int_to_binary")
        passed += 1
    } otherwise {
        println("  [FAIL] int_to_binary: got '${bin}'")
        failed += 1
    }

    // Test 13: int_to_binary zero
    mut bin0 string = fmt.int_to_binary(0)
    if bin0 == "0" {
        println("  [PASS] int_to_binary zero")
        passed += 1
    } otherwise {
        println("  [FAIL] int_to_binary zero: got '${bin0}'")
        failed += 1
    }

    // Test 14: int_to_binary power of 2
    mut bin8 string = fmt.int_to_binary(128)
    if bin8 == "10000000" {
        println("  [PASS] int_to_binary 128")
        passed += 1
    } otherwise {
        println("  [FAIL] int_to_binary 128: got '${bin8}'")
        failed += 1
    }

    // Test 15: int_to_octal
    mut oct string = fmt.int_to_octal(8)
    if oct == "10" {
        println("  [PASS] int_to_octal")
        passed += 1
    } otherwise {
        println("  [FAIL] int_to_octal: got '${oct}'")
        failed += 1
    }

    // Test 16: int_to_octal zero
    mut oct0 string = fmt.int_to_octal(0)
    if oct0 == "0" {
        println("  [PASS] int_to_octal zero")
        passed += 1
    } otherwise {
        println("  [FAIL] int_to_octal zero: got '${oct0}'")
        failed += 1
    }

    // Test 17: float_fixed
    mut ff string = fmt.float_fixed(3.14159, 2)
    if ff == "3.14" {
        println("  [PASS] float_fixed")
        passed += 1
    } otherwise {
        println("  [FAIL] float_fixed: got '${ff}'")
        failed += 1
    }

    // Test 18: float_fixed zero decimals
    mut ff0 string = fmt.float_fixed(3.14159, 0)
    if ff0 == "3" {
        println("  [PASS] float_fixed zero decimals")
        passed += 1
    } otherwise {
        println("  [FAIL] float_fixed 0 dec: got '${ff0}'")
        failed += 1
    }

    // Test 19: float_sci
    mut fs string = fmt.float_sci(1230.0)
    if fs == "1.230000e+03" {
        println("  [PASS] float_sci")
        passed += 1
    } otherwise {
        println("  [FAIL] float_sci: got '${fs}'")
        failed += 1
    }

    // Test 20: float_sci small number
    mut fs2 string = fmt.float_sci(0.00123)
    if fs2 == "1.230000e-03" {
        println("  [PASS] float_sci small")
        passed += 1
    } otherwise {
        println("  [FAIL] float_sci small: got '${fs2}'")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
