/*
 * foreach_optional_parens.ez - Test optional parentheses in for_each (#1328)
 *
 * Verifies that for_each accepts both parenthesized and non-parenthesized
 * clause syntax, consistent with all other control flow constructs.
 */


do main() {
    println("=== for_each Optional Parentheses Tests ===")
    mut passed int = 0
    mut failed int = 0

    mut nums [int] = {10, 20, 30}

    // Test 1: for_each without parens (baseline)
    mut sum1 int = 0
    for_each val in nums {
        sum1 += val
    }
    if sum1 == 60 {
        println("  [PASS] for_each val in nums (no parens)")
        passed += 1
    } otherwise {
        println("  [FAIL] for_each no parens: got ${sum1}, expected 60")
        failed += 1
    }

    // Test 2: for_each with parens
    mut sum2 int = 0
    for_each (val in nums) {
        sum2 += val
    }
    if sum2 == 60 {
        println("  [PASS] for_each (val in nums) with parens")
        passed += 1
    } otherwise {
        println("  [FAIL] for_each parens: got ${sum2}, expected 60")
        failed += 1
    }

    // Test 3: for_each with index, no parens (syntax: index, value)
    mut idx_sum int = 0
    for_each i, val in nums {
        idx_sum += i
    }
    if idx_sum == 3 {
        println("  [PASS] for_each i, val in nums (no parens)")
        passed += 1
    } otherwise {
        println("  [FAIL] for_each index no parens: got ${idx_sum}, expected 3")
        failed += 1
    }

    // Test 4: for_each with index, with parens
    mut idx_sum2 int = 0
    for_each (i, val in nums) {
        idx_sum2 += i
    }
    if idx_sum2 == 3 {
        println("  [PASS] for_each (i, val in nums) with parens")
        passed += 1
    } otherwise {
        println("  [FAIL] for_each index parens: got ${idx_sum2}, expected 3")
        failed += 1
    }

    // Test 5: for_each strings with parens
    mut names [string] = {"Alice", "Bob", "Charlie"}
    mut concat string = ""
    for_each (name in names) {
        concat = concat + name
    }
    if concat == "AliceBobCharlie" {
        println("  [PASS] for_each (name in names) strings")
        passed += 1
    } otherwise {
        println("  [FAIL] for_each strings parens: got '${concat}'")
        failed += 1
    }

    // Test 6: nested for_each with parens
    mut matrix [[int]] = {{1, 2}, {3, 4}}
    mut total int = 0
    for_each (row in matrix) {
        for_each (val in row) {
            total += val
        }
    }
    if total == 10 {
        println("  [PASS] nested for_each with parens")
        passed += 1
    } otherwise {
        println("  [FAIL] nested for_each parens: got ${total}, expected 10")
        failed += 1
    }

    // Test 7: mixed — outer no parens, inner with parens
    mut total2 int = 0
    for_each row in matrix {
        for_each (val in row) {
            total2 += val
        }
    }
    if total2 == 10 {
        println("  [PASS] mixed parens: outer no, inner yes")
        passed += 1
    } otherwise {
        println("  [FAIL] mixed parens: got ${total2}, expected 10")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
