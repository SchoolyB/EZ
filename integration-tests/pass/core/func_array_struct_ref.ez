/*
 * func_array_struct_ref.ez - Struct-namespaced function refs in [func] arrays
 *
 * Regression for #1458 (commit 18845b6): struct-namespaced func refs
 * stored in a [func] array literal lost their return type identity when
 * called via a constant index. typechecker now tracks the originating
 * referenced function per literal element (Symbol::func_array_refs), so
 * ctors[0](42) recovers the struct return type and downstream field
 * access compiles.
 */

const Vec struct {
    x int
    y int

    do create(val int) -> Vec {
        return Vec{x: val, y: val * 2}
    }

    do origin() -> Vec {
        return Vec{x: 0, y: 0}
    }
}

const Color struct {
    r int
    g int
    b int

    do rgb(r int, g int, b int) -> Color {
        return Color{r: r, g: g, b: b}
    }
}

do main() {
    println("=== [func] Array Struct Ref Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- single-element [func] array of struct-namespaced ref --
    mut ctors [func] = {()Vec.create}
    mut v = ctors[0](42)
    if v.x == 42 && v.y == 84 {
        println("  [PASS] single struct-namespaced ref, const index 0")
        passed += 1
    } otherwise {
        println("  [FAIL] single struct-namespaced ref")
        failed += 1
    }

    // -- multi-element [func] array, different indices --
    mut vec_ops [func] = {()Vec.create, ()Vec.origin}
    mut v1 = vec_ops[0](7)
    mut v2 = vec_ops[1]()
    if v1.x == 7 && v1.y == 14 && v2.x == 0 && v2.y == 0 {
        println("  [PASS] multi-element struct-namespaced refs, const indices")
        passed += 1
    } otherwise {
        println("  [FAIL] multi-element struct-namespaced refs")
        failed += 1
    }

    // -- different struct type in same pattern --
    mut color_ops [func] = {()Color.rgb}
    mut c = color_ops[0](255, 128, 64)
    if c.r == 255 && c.g == 128 && c.b == 64 {
        println("  [PASS] different struct type via [func] array")
        passed += 1
    } otherwise {
        println("  [FAIL] different struct type")
        failed += 1
    }

    // -- field access chained through the call result --
    mut x_val int = vec_ops[0](100).x
    if x_val == 100 {
        println("  [PASS] field access chained on indexed call result")
        passed += 1
    } otherwise {
        println("  [FAIL] field access chained on indexed call result")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
