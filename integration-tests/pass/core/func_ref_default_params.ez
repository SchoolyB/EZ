/*
 * func_ref_default_params.ez - Function references respect default
 * parameter values at reduced arity.
 *
 * Regression for #1503 (bug reported during hunt): `f(5)` where
 * `f = ()add` and add has `b int = 10` fired E5008 "expects 2
 * arguments, got 1". The typechecker now computes min_arity from
 * params without defaults, and codegen builds the function-pointer
 * cast using the full param count.
 */

do add(a int, b int = 10) -> int {
    return a + b
}

do greet(name string, prefix string = "Hello") -> string {
    return "${prefix}, ${name}!"
}

do main() {
    println("=== Func Ref Default Params Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- call with default --
    mut f func = ()add
    if f(5) == 15 {
        println("  [PASS] f(5) with default b=10 → 15")
        passed += 1
    } otherwise {
        println("  [FAIL] f(5)")
        failed += 1
    }

    // -- call overriding default --
    if f(5, 20) == 25 {
        println("  [PASS] f(5, 20) overriding default → 25")
        passed += 1
    } otherwise {
        println("  [FAIL] f(5, 20)")
        failed += 1
    }

    // -- string default through func ref --
    mut g func = ()greet
    if g("World") == "Hello, World!" {
        println("  [PASS] g(\"World\") with default prefix")
        passed += 1
    } otherwise {
        println("  [FAIL] g(\"World\")")
        failed += 1
    }

    if g("World", "Hey") == "Hey, World!" {
        println("  [PASS] g(\"World\", \"Hey\") overriding prefix")
        passed += 1
    } otherwise {
        println("  [FAIL] g(\"World\", \"Hey\")")
        failed += 1
    }

    // -- direct call non-regression --
    if add(5) == 15 && add(5, 20) == 25 {
        println("  [PASS] direct add() still works")
        passed += 1
    } otherwise {
        println("  [FAIL] direct add()")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
