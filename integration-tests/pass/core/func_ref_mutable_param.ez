/*
 * Tests function reference invocation with mutable (&) parameter
 * Verifies that [func] vars correctly pass-through & param mutations
 * Regression for #1494
 */

do modify(&x int) {
    x = 99
}

do triple(&x int) {
    x = x * 3
}

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: basic func ref mutation
    mut fn_ref [func] = ()modify
    mut a int = 10
    fn_ref(a)
    if a == 99 {
        println("  [PASS] fn_ref(modify) mutated a to 99")
        passed += 1
    } otherwise {
        println("  [FAIL] fn_ref(modify): expected 99, got ${a}")
        failed += 1
    }

    // Test 2: different func ref mutation
    mut fn_ref2 [func] = ()triple
    mut b int = 7
    fn_ref2(b)
    if b == 21 {
        println("  [PASS] fn_ref(triple) mutated b to 21")
        passed += 1
    } otherwise {
        println("  [FAIL] fn_ref(triple): expected 21, got ${b}")
        failed += 1
    }

    // Test 3: reassign func ref and mutate again
    fn_ref = ()triple
    mut c int = 4
    fn_ref(c)
    if c == 12 {
        println("  [PASS] reassigned fn_ref(triple) mutated c to 12")
        passed += 1
    } otherwise {
        println("  [FAIL] reassigned fn_ref(triple): expected 12, got ${c}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
