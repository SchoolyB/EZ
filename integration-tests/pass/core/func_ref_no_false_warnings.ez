/* Test: Function references suppress false unused warnings
 * Regression test for #1270 — using a function only via ()name
 * or storing a func ref in a variable that is only called should
 * not emit W1001 (unused variable) or W1003 (unused function).
 * Expected: all tests pass with no warnings
 */


// This function is ONLY used via ()ref — should not trigger W1003
do square(n int) -> int {
    return n * n
}

// This function is ONLY used via ()Helpers.triple — should not trigger W1003
const Helpers struct {
    do triple(n int) -> int {
        return n * 3
    }
}

do apply(n int, fn func) -> int {
    return fn(n)
}

do main() {
    println("=== Func Ref No False Warnings Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: function only used via ()ref — no W1003
    mut result1 int = apply(4, ()square)
    if result1 == 16 {
        println("  [PASS] ()square ref — no false unused warning")
        passed += 1
    } otherwise {
        println("  [FAIL] ()square ref")
        failed += 1
    }

    // Test 2: namespaced function only used via ()ref — no W1003
    mut result2 int = apply(4, ()Helpers.triple)
    if result2 == 12 {
        println("  [PASS] ()Helpers.triple ref — no false unused warning")
        passed += 1
    } otherwise {
        println("  [FAIL] ()Helpers.triple ref")
        failed += 1
    }

    // Test 3: variable holding func ref that is only called — no W1001
    mut fn = ()square
    mut result3 int = fn(7)
    if result3 == 49 {
        println("  [PASS] func ref variable called — no false unused warning")
        passed += 1
    } otherwise {
        println("  [FAIL] func ref variable called")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
