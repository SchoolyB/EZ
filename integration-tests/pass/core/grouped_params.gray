/*
 * grouped_params.gray - Test grouped parameter syntax (a, b int → both get int)
 * Verifies backfill works correctly after parser fix.
 */

do add(a, b int) -> int {
    return a + b
}

do greet(first, last string) -> string {
    return "${first} ${last}"
}

do three_grouped(x, y, z float) -> float {
    return x + y + z
}

do main() {
    println("=== Grouped Params Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: two int params grouped
    mut sum int = add(3, 4)
    if sum == 7 {
        println("  [PASS] add(3, 4) = 7")
        passed += 1
    } otherwise {
        println("  [FAIL] add(3, 4): expected 7, got ${sum}")
        failed += 1
    }

    // Test 2: two string params grouped
    mut name string = greet("John", "Doe")
    if name == "John Doe" {
        println("  [PASS] greet('John', 'Doe') = 'John Doe'")
        passed += 1
    } otherwise {
        println("  [FAIL] greet: expected 'John Doe', got '${name}'")
        failed += 1
    }

    // Test 3: three float params grouped
    mut total float = three_grouped(1.5, 2.5, 3.0)
    if total == 7.0 {
        println("  [PASS] three_grouped(1.5, 2.5, 3.0) = 7.0")
        passed += 1
    } otherwise {
        println("  [FAIL] three_grouped: expected 7.0, got ${total}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
