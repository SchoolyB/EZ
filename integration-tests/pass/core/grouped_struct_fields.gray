/*
 * grouped_struct_fields.gray - Comma-grouped struct field declarations
 *
 * struct fields sharing a type via comma syntax
 * (e.g. `x, y, z float`) were not registered correctly.
 */

const User struct {
    name, email string
    age int
    active, verified bool
}

const Point3D struct {
    x, y, z float
}

do main() {
    println("=== Grouped Struct Fields Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: two string fields grouped
    mut u = User{name: "Alice", email: "alice@test.com", age: 30, active: true, verified: false}
    if u.name == "Alice" {
        println("  [PASS] grouped string field: name")
        passed += 1
    } otherwise {
        println("  [FAIL] grouped string field: name")
        failed += 1
    }

    // Test 2: second grouped string field
    if u.email == "alice@test.com" {
        println("  [PASS] grouped string field: email")
        passed += 1
    } otherwise {
        println("  [FAIL] grouped string field: email")
        failed += 1
    }

    // Test 3: non-grouped field still works
    if u.age == 30 {
        println("  [PASS] non-grouped int field: age")
        passed += 1
    } otherwise {
        println("  [FAIL] non-grouped int field: age")
        failed += 1
    }

    // Test 4: two bool fields grouped
    if u.active && !u.verified {
        println("  [PASS] grouped bool fields: active, verified")
        passed += 1
    } otherwise {
        println("  [FAIL] grouped bool fields: active, verified")
        failed += 1
    }

    // Test 5: three float fields grouped
    mut p = Point3D{x: 1.5, y: 2.5, z: 3.5}
    if p.x == 1.5 && p.y == 2.5 && p.z == 3.5 {
        println("  [PASS] grouped float fields: x, y, z")
        passed += 1
    } otherwise {
        println("  [FAIL] grouped float fields: x, y, z")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
