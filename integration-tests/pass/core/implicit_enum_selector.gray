/*
 * implicit_enum_selector.gray - Test .VARIANT shorthand syntax
 * Tests implicit enum selector resolution in all supported contexts.
 */

const Direction enum {
    NORTH
    EAST
    SOUTH
    WEST
}

const Color enum {
    RED
    GREEN
    BLUE
}

const Config struct {
    dir Direction
    color Color
}

do get_direction() -> Direction {
    return .NORTH
}

do move(d Direction) -> int {
    when d {
        is .NORTH { return 0 }
        is .EAST { return 1 }
        is .SOUTH { return 2 }
        is .WEST { return 3 }
    }
    return -1
}

do with_default(d Direction = .SOUTH) -> int {
    if d == .SOUTH {
        return 1
    }
    return 0
}

do main() {
    println("=== Implicit Enum Selector Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: Variable declaration with type annotation
    mut dir Direction = .NORTH
    if dir == Direction.NORTH {
        println("  [PASS] var decl with type annotation")
        passed += 1
    } otherwise {
        println("  [FAIL] var decl with type annotation")
        failed += 1
    }

    // Test 2: Assignment
    dir = .SOUTH
    if dir == Direction.SOUTH {
        println("  [PASS] assignment")
        passed += 1
    } otherwise {
        println("  [FAIL] assignment")
        failed += 1
    }

    // Test 3: Function argument
    mut result int = move(.EAST)
    if result == 1 {
        println("  [PASS] function argument")
        passed += 1
    } otherwise {
        println("  [FAIL] function argument: expected 1, got ${result}")
        failed += 1
    }

    // Test 4: When/is branches
    dir = .WEST
    mut when_result int = -1
    when dir {
        is .NORTH { when_result = 0 }
        is .EAST { when_result = 1 }
        is .SOUTH { when_result = 2 }
        is .WEST { when_result = 3 }
    }
    if when_result == 3 {
        println("  [PASS] when/is branches")
        passed += 1
    } otherwise {
        println("  [FAIL] when/is branches: expected 3, got ${when_result}")
        failed += 1
    }

    // Test 5: Comparison (==)
    dir = .NORTH
    if dir == .NORTH {
        println("  [PASS] == comparison")
        passed += 1
    } otherwise {
        println("  [FAIL] == comparison")
        failed += 1
    }

    // Test 6: Comparison (!=)
    if dir != .SOUTH {
        println("  [PASS] != comparison")
        passed += 1
    } otherwise {
        println("  [FAIL] != comparison")
        failed += 1
    }

    // Test 7: Return statement
    mut returned Direction = get_direction()
    if returned == .NORTH {
        println("  [PASS] return statement")
        passed += 1
    } otherwise {
        println("  [FAIL] return statement")
        failed += 1
    }

    // Test 8: Struct literal field
    mut cfg = Config{ dir: .EAST, color: .BLUE }
    if cfg.dir == Direction.EAST {
        println("  [PASS] struct literal field (dir)")
        passed += 1
    } otherwise {
        println("  [FAIL] struct literal field (dir)")
        failed += 1
    }

    if cfg.color == Color.BLUE {
        println("  [PASS] struct literal field (color)")
        passed += 1
    } otherwise {
        println("  [FAIL] struct literal field (color)")
        failed += 1
    }

    // Test 9: Default parameter value
    mut def_result int = with_default()
    if def_result == 1 {
        println("  [PASS] default parameter value")
        passed += 1
    } otherwise {
        println("  [FAIL] default parameter value: expected 1, got ${def_result}")
        failed += 1
    }

    // Test 10: Mixed explicit and implicit in same expression
    if Direction.NORTH == .NORTH {
        println("  [PASS] mixed explicit and implicit")
        passed += 1
    } otherwise {
        println("  [FAIL] mixed explicit and implicit")
        failed += 1
    }

    // Test 11: Array literal with enum element type
    mut dirs [Direction] = {.NORTH, .SOUTH, .EAST}
    if dirs[0] == Direction.NORTH {
        println("  [PASS] array literal element")
        passed += 1
    } otherwise {
        println("  [FAIL] array literal element")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
