/*
 * import_alias.gray - Test import aliasing with alias@module syntax
 */

import str@strings, m@math

do main() {
    println("=== Import Alias Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: dot notation with alias
    mut upper string = str.to_upper("hello")
    if upper == "HELLO" {
        println("  [PASS] str.to_upper via alias")
        passed += 1
    } otherwise {
        println("  [FAIL] str.to_upper expected \"HELLO\", got ${upper}")
        failed += 1
    }

    // Test 2: math via alias
    mut a int = m.abs(-99)
    if a == 99 {
        println("  [PASS] m.abs(-99) via alias")
        passed += 1
    } otherwise {
        println("  [FAIL] m.abs expected 99, got ${a}")
        failed += 1
    }

    // Test 3: using with alias name
    mut lower string = str.to_lower("WORLD")
    if lower == "world" {
        println("  [PASS] str.to_lower via alias")
        passed += 1
    } otherwise {
        println("  [FAIL] str.to_lower expected \"world\", got ${lower}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("SOME TESTS FAILED")
    }
}
