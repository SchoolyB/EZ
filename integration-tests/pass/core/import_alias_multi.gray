/*
 * import_alias_multi.gray - Test aliased multi-import
 *
 * Covers: multiple modules imported on one line with aliases,
 * accessed via alias prefix.
 */

import m @math, a @arrays

do main() {
    println("=== Import Alias Multi Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: aliased math access
    mut val = m.abs(-7)
    if val == 7 {
        println("  [PASS] m.abs(-7)")
        passed += 1
    } otherwise {
        println("  [FAIL] m.abs: got ${val}")
        failed += 1
    }

    // Test 2: aliased arrays access
    mut arr [int] = {9, 3, 6}
    a.sort_asc(arr)
    if arr[0] == 3 && arr[2] == 9 {
        println("  [PASS] a.sort_asc")
        passed += 1
    } otherwise {
        println("  [FAIL] a.sort_asc: got ${arr}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
