/*
 * import_and_use.gray - Unqualified access via import and use / using.
 *
 * import and use only brought stdlib functions
 * into scope. Constants (PI, E), types, and usage tracking were all
 * broken. Fixed in b9c9752.
 *
 * Covers: unqualified constants, unqualified functions, qualified
 * access alongside unqualified.
 */

import and use @math

do main() {
    println("=== Import and Use Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- stdlib constants unqualified --
    if PI > 3.14 && PI < 3.15 {
        println("  [PASS] PI unqualified")
        passed += 1
    } otherwise {
        println("  [FAIL] PI")
        failed += 1
    }

    if E > 2.71 && E < 2.72 {
        println("  [PASS] E unqualified")
        passed += 1
    } otherwise {
        println("  [FAIL] E")
        failed += 1
    }

    // -- stdlib functions unqualified --
    if sqrt(25.0) == 5.0 {
        println("  [PASS] sqrt unqualified")
        passed += 1
    } otherwise {
        println("  [FAIL] sqrt")
        failed += 1
    }

    if factorial(5) == 120 {
        println("  [PASS] factorial unqualified")
        passed += 1
    } otherwise {
        println("  [FAIL] factorial")
        failed += 1
    }

    // -- qualified access still works alongside --
    if math.sqrt(36.0) == 6.0 {
        println("  [PASS] math.sqrt qualified still works")
        passed += 1
    } otherwise {
        println("  [FAIL] math.sqrt qualified")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
