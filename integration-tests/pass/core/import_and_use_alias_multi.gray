/*
 * import_and_use_alias_multi.gray - Test import and use with aliases
 *
 * Covers: both unqualified and alias-qualified access when using
 * import and use with aliases on multiple modules.
 */

import and use m @math, a @arrays

do main() {
    println("=== Import And Use Alias Multi Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: unqualified access
    mut val = abs(-3)
    if val == 3 {
        println("  [PASS] unqualified abs(-3)")
        passed += 1
    } otherwise {
        println("  [FAIL] unqualified abs: got ${val}")
        failed += 1
    }

    // Test 2: alias-qualified access
    mut val2 = m.abs(-10)
    if val2 == 10 {
        println("  [PASS] m.abs(-10) alias qualified")
        passed += 1
    } otherwise {
        println("  [FAIL] m.abs: got ${val2}")
        failed += 1
    }

    // Test 3: unqualified arrays function
    mut arr [int] = {4, 2, 7}
    sort_asc(arr)
    if arr[0] == 2 {
        println("  [PASS] unqualified sort_asc")
        passed += 1
    } otherwise {
        println("  [FAIL] sort_asc: got ${arr}")
        failed += 1
    }

    // Test 4: alias-qualified arrays function
    mut arr2 [int] = {8, 1, 5}
    a.sort_asc(arr2)
    if arr2[0] == 1 {
        println("  [PASS] a.sort_asc alias qualified")
        passed += 1
    } otherwise {
        println("  [FAIL] a.sort_asc: got ${arr2}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
