/*
 * import_and_use_multi.ez - Test import and use with multiple modules
 *
 * Covers: unqualified access to functions from multiple modules
 * imported on a single line.
 */

import and use @math, @strings, @arrays

do main() {
    println("=== Import And Use Multi Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: unqualified math function
    mut val = abs(-42)
    if val == 42 {
        println("  [PASS] unqualified abs(-42)")
        passed += 1
    } otherwise {
        println("  [FAIL] abs: got ${val}")
        failed += 1
    }

    // Test 2: unqualified strings function
    mut upper string = to_upper("world")
    if upper == "WORLD" {
        println("  [PASS] unqualified to_upper")
        passed += 1
    } otherwise {
        println("  [FAIL] to_upper: got '${upper}'")
        failed += 1
    }

    // Test 3: unqualified arrays function
    mut arr [int] = {5, 2, 8, 1}
    sort_asc(arr)
    if arr[0] == 1 && arr[3] == 8 {
        println("  [PASS] unqualified sort_asc")
        passed += 1
    } otherwise {
        println("  [FAIL] sort_asc: got ${arr}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
