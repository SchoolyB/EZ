/*
 * import_and_use_syntax.ez - Test 'import and use @module' syntax
 */

import and use @strings, @math

do main() {
    println("=== Import and Use Syntax Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: std println works
    println("  [PASS] println works via import and use")
    passed += 1

    // Test 2: strings function unqualified
    mut result string = to_upper("test")
    if result == "TEST" {
        println("  [PASS] to_upper via import and use")
        passed += 1
    } otherwise {
        println("  [FAIL] to_upper expected \"TEST\", got ${result}")
        failed += 1
    }

    // Test 3: math function unqualified
    mut v int = abs(-10)
    if v == 10 {
        println("  [PASS] abs via import and use")
        passed += 1
    } otherwise {
        println("  [FAIL] abs expected 10, got ${v}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("SOME TESTS FAILED")
    }
}
