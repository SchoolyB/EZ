/*
 * import_syntax_variants.gray - Test all import syntax variants
 *
 * Covers: inline multi-import, aliased import, import and use,
 * import and use with alias, and combinations.
 */

import @math, @arrays, @strings

do main() {
    println("=== Import Syntax Variants Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: inline multi-import with qualified access
    mut abs_val = math.abs(-5)
    if abs_val == 5 {
        println("  [PASS] inline multi-import qualified access")
        passed += 1
    } otherwise {
        println("  [FAIL] math.abs(-5): got ${abs_val}")
        failed += 1
    }

    // Test 2: second module from inline import
    mut arr [int] = {3, 1, 2}
    arrays.sort_asc(arr)
    if arr[0] == 1 {
        println("  [PASS] second module from inline import")
        passed += 1
    } otherwise {
        println("  [FAIL] arrays.sort_asc")
        failed += 1
    }

    // Test 3: third module from inline import
    mut upper string = strings.to_upper("hello")
    if upper == "HELLO" {
        println("  [PASS] third module from inline import")
        passed += 1
    } otherwise {
        println("  [FAIL] strings.to_upper: got '${upper}'")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
