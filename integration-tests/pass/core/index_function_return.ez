/*
 * index_function_return.ez - Test indexing arrays returned directly from functions
 */


do get_numbers() -> [int] {
    return {10, 20, 30}
}

do get_names() -> [string] {
    return {"alice", "bob", "charlie"}
}

do main() {
    println("=== Index Function Return Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: Index first element
    mut a int = get_numbers()[0]
    if a == 10 {
        println("  [PASS] get_numbers()[0] == 10")
        passed += 1
    } otherwise {
        println("  [FAIL] get_numbers()[0] expected 10, got ${a}")
        failed += 1
    }

    // Test 2: Index last element
    mut b int = get_numbers()[2]
    if b == 30 {
        println("  [PASS] get_numbers()[2] == 30")
        passed += 1
    } otherwise {
        println("  [FAIL] get_numbers()[2] expected 30, got ${b}")
        failed += 1
    }

    // Test 3: Index string array from function
    mut c string = get_names()[1]
    if c == "bob" {
        println("  [PASS] get_names()[1] == \"bob\"")
        passed += 1
    } otherwise {
        println("  [FAIL] get_names()[1] expected \"bob\", got ${c}")
        failed += 1
    }

    // Test 4: Use indexed return value in expression
    mut d int = get_numbers()[0] + get_numbers()[2]
    if d == 40 {
        println("  [PASS] get_numbers()[0] + get_numbers()[2] == 40")
        passed += 1
    } otherwise {
        println("  [FAIL] expected 40, got ${d}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("SOME TESTS FAILED")
    }
}
