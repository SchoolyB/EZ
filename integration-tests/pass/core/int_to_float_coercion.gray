/*
 * int_to_float_coercion.gray - Implicit int → float promotion.
 *
 * integer literals and int-typed values assigned to
 * float/f32/f64 variables, struct fields, map values, and return
 * positions are accepted without explicit casts. C handles the
 * promotion natively.
 *
 * Note: array literals (`[f64] = {1, 2}`) pass typechecking but
 * codegen picks the array constructor based on the first element's
 * resolved type (int), producing wrong storage. That's tracked as
 * a follow-up and intentionally not tested here.
 */

do takes_float(x float) -> float {
    return x + 0.5
}

do main() {
    println("=== Int-to-Float Coercion Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- var_decl: int literal to float --
    mut x float = 5
    if x == 5.0 {
        println("  [PASS] mut x float = 5 → 5.0")
        passed += 1
    } otherwise {
        println("  [FAIL] x = ${x}")
        failed += 1
    }

    // -- var_decl: int literal to f32 --
    mut y f32 = 1
    if y == 1.0 {
        println("  [PASS] mut y f32 = 1 → 1.0")
        passed += 1
    } otherwise {
        println("  [FAIL] y = ${y}")
        failed += 1
    }

    // -- reassignment: int to float var --
    x = 42
    if x == 42.0 {
        println("  [PASS] x = 42 (reassign) → 42.0")
        passed += 1
    } otherwise {
        println("  [FAIL] reassign x = ${x}")
        failed += 1
    }

    // -- function argument: int to float param --
    if takes_float(7) == 7.5 {
        println("  [PASS] takes_float(7) → 7.5")
        passed += 1
    } otherwise {
        println("  [FAIL] takes_float(7)")
        failed += 1
    }

    // -- int-typed variable to float --
    mut n int = 100
    mut z float = n
    if z == 100.0 {
        println("  [PASS] mut z float = n (int var) → 100.0")
        passed += 1
    } otherwise {
        println("  [FAIL] z = ${z}")
        failed += 1
    }

    // -- map literal: int value in float-typed map --
    mut m map[string:float] = {"pi": 3, "e": 2}
    if m["pi"] == 3.0 && m["e"] == 2.0 {
        println("  [PASS] map[string:float] with int values")
        passed += 1
    } otherwise {
        println("  [FAIL] map values")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
