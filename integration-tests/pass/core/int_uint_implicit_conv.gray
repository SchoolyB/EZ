/*
 * int-uint-implicit-conv.gray - Test implicit int-to-uint conversion
 * for literals, comparisons, variable assignments, and struct fields.
 */


const Pair struct {
    x uint
    y int
}

do main() {
    println("=== Int/Uint Implicit Conversion ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: Assign int literal to uint variable
    mut a uint = 42
    if a == 42 {
        println("  [PASS] assign int literal to uint var")
        passed += 1
    } otherwise {
        println("  [FAIL] assign int literal to uint var")
        failed += 1
    }

    // Test 2: Assign uint value to int variable
    mut b int = a
    if b == 42 {
        println("  [PASS] assign uint value to int var")
        passed += 1
    } otherwise {
        println("  [FAIL] assign uint value to int var")
        failed += 1
    }

    // Test 3: Equality comparison between int and uint
    mut c int = 10
    mut d uint = 10
    if c == d {
        println("  [PASS] int == uint comparison")
        passed += 1
    } otherwise {
        println("  [FAIL] int == uint comparison")
        failed += 1
    }

    // Test 4: Inequality comparison between int and uint
    mut e int = 5
    mut f uint = 10
    if e != f {
        println("  [PASS] int != uint comparison")
        passed += 1
    } otherwise {
        println("  [FAIL] int != uint comparison")
        failed += 1
    }

    // Test 5: Reassign struct uint field with int value
    mut g uint = 99
    mut p Pair = Pair { x: g, y: 7 }
    mut val int = 200
    p.x = val
    if p.x == 200 {
        println("  [PASS] reassign struct uint field with int value")
        passed += 1
    } otherwise {
        println("  [FAIL] reassign struct uint field with int value")
        failed += 1
    }

    // Test 6: Assign int literal to byte variable
    mut h byte = 65
    if h == 65 {
        println("  [PASS] assign int literal to byte var")
        passed += 1
    } otherwise {
        println("  [FAIL] assign int literal to byte var")
        failed += 1
    }

    // Test 7: Equality comparison between byte and int
    mut i int = 65
    if h == i {
        println("  [PASS] byte == int comparison")
        passed += 1
    } otherwise {
        println("  [FAIL] byte == int comparison")
        failed += 1
    }

    // Test 8: Assign int value to byte variable
    mut j byte = 0
    mut k int = 100
    j = k
    if j == 100 {
        println("  [PASS] assign int value to byte var")
        passed += 1
    } otherwise {
        println("  [FAIL] assign int value to byte var")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
