/*
 * loop_return.gray - Test return inside loop recognized as valid return path
 *
 * Covers: loop with return, loop with conditional return,
 * while with return, for with return.
 */

do find_value() -> int {
    mut i int = 0
    loop {
        i += 1
        if i == 42 { return i }
    }
}

do search(target int) -> string {
    mut i int = 0
    loop {
        if i == target { return "found at ${i}" }
        i += 1
        if i > 100 { return "not found" }
    }
}

do main() {
    println("=== Loop Return Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: loop with return
    mut val int = find_value()
    if val == 42 {
        println("  [PASS] loop with return")
        passed += 1
    } otherwise {
        println("  [FAIL] loop return: got ${val}")
        failed += 1
    }

    // Test 2: loop with conditional return (found)
    mut result string = search(10)
    if result == "found at 10" {
        println("  [PASS] loop search found")
        passed += 1
    } otherwise {
        println("  [FAIL] search: got '${result}'")
        failed += 1
    }

    // Test 3: loop with conditional return (not found)
    mut result2 string = search(999)
    if result2 == "not found" {
        println("  [PASS] loop search not found")
        passed += 1
    } otherwise {
        println("  [FAIL] search 999: got '${result2}'")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
