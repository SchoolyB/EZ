/*
 * map_compound_assign.gray - Compound assignment operators on map values
 *
 * Covers: +=, -=, *=, /=, %= on existing map entries.
 * Each operation must read the stored value before applying the operator.
 */

do main() {
    println("=== Map Compound Assignment Test ===")
    mut passed int = 0
    mut failed int = 0

    mut m map[string:int] = {"a": 10, "b": 20, "c": 30, "d": 40, "e": 50}

    // += reads existing value
    m["a"] += 5
    if m["a"] == 15 {
        println("  [PASS] +=")
        passed += 1
    } otherwise {
        println("  [FAIL] +=: got ${m["a"]}, expected 15")
        failed += 1
    }

    // -= reads existing value
    m["b"] -= 5
    if m["b"] == 15 {
        println("  [PASS] -=")
        passed += 1
    } otherwise {
        println("  [FAIL] -=: got ${m["b"]}, expected 15")
        failed += 1
    }

    // *= reads existing value
    m["c"] *= 3
    if m["c"] == 90 {
        println("  [PASS] *=")
        passed += 1
    } otherwise {
        println("  [FAIL] *=: got ${m["c"]}, expected 90")
        failed += 1
    }

    // /= reads existing value
    m["d"] /= 4
    if m["d"] == 10 {
        println("  [PASS] /=")
        passed += 1
    } otherwise {
        println("  [FAIL] /=: got ${m["d"]}, expected 10")
        failed += 1
    }

    // %= reads existing value
    m["e"] %= 7
    if m["e"] == 1 {
        println("  [PASS] %=")
        passed += 1
    } otherwise {
        println("  [FAIL] %=: got ${m["e"]}, expected 1")
        failed += 1
    }

    // chained compound assignments accumulate correctly
    mut c map[string:int] = {"n": 0}
    c["n"] += 3
    c["n"] += 7
    c["n"] *= 2
    if c["n"] == 20 {
        println("  [PASS] chained compound assignments")
        passed += 1
    } otherwise {
        println("  [FAIL] chained: got ${c["n"]}, expected 20")
        failed += 1
    }

    // int key map compound assignment
    mut idx map[int:int] = {1: 100}
    idx[1] -= 50
    if idx[1] == 50 {
        println("  [PASS] int key -=")
        passed += 1
    } otherwise {
        println("  [FAIL] int key -=: got ${idx[1]}, expected 50")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
