/*
 * map_enum_keys.ez - Maps keyed by enum types
 *
 * Regression for #1444 (commit 3dd0a6d): enum keys were rejected at
 * index time with "expected 'Color', got 'int'" because enum members
 * resolve as int. Enums are int-backed and hash fine; the typechecker
 * now accepts int expressions against an enum-typed key in
 * NODE_INDEX_EXPR.
 */

const Color enum {
    RED,
    GREEN,
    BLUE
}

const Status enum {
    PENDING,
    ACTIVE,
    DONE
}

do main() {
    println("=== Enum Map Keys Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- literal init + access --
    mut cmap map[Color:string] = {
        Color.RED: "red",
        Color.GREEN: "green",
        Color.BLUE: "blue"
    }
    if cmap[Color.RED] == "red" && cmap[Color.GREEN] == "green" && cmap[Color.BLUE] == "blue" {
        println("  [PASS] enum key literal + access")
        passed += 1
    } otherwise {
        println("  [FAIL] enum key literal + access")
        failed += 1
    }

    // -- assignment / update --
    cmap[Color.RED] = "crimson"
    if cmap[Color.RED] == "crimson" {
        println("  [PASS] enum key assignment")
        passed += 1
    } otherwise {
        println("  [FAIL] enum key assignment")
        failed += 1
    }

    // -- insertion of new enum key --
    mut smap map[Status:int] = {:}
    smap[Status.PENDING] = 1
    smap[Status.ACTIVE] = 2
    smap[Status.DONE] = 3
    if smap[Status.PENDING] == 1 && smap[Status.ACTIVE] == 2 && smap[Status.DONE] == 3 && len(smap) == 3 {
        println("  [PASS] enum key insertion into empty map")
        passed += 1
    } otherwise {
        println("  [FAIL] enum key insertion into empty map")
        failed += 1
    }

    // -- 'in' / '!in' --
    if Color.RED in cmap && Color.GREEN in cmap {
        println("  [PASS] enum key 'in' operator")
        passed += 1
    } otherwise {
        println("  [FAIL] enum key 'in' operator")
        failed += 1
    }

    // -- len --
    if len(cmap) == 3 {
        println("  [PASS] enum keyed map len")
        passed += 1
    } otherwise {
        println("  [FAIL] enum keyed map len: got ${len(cmap)}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
