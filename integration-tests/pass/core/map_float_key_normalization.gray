/*
 * map_float_key_normalization.ez - +0.0/-0.0 collide and NaN keys dedup.
 *
 * Before the fix, ez_map hashed and compared float keys bytewise. That
 * made +0.0 and -0.0 land in different buckets even though they compare
 * equal under == and IEEE 754, and any two NaNs with different bit
 * patterns lived in different buckets too. Map now tags float keys with
 * a key_kind and normalizes -0.0 to +0.0 and NaN to a canonical quiet
 * NaN before hash/compare.
 *
 * Also exercises that ez_map_copy and maps.merge propagate the kind so
 * the normalization survives a copy or a merge.
 */

import @maps
import @math

do main() {
    println("=== Float Map Key Normalization Test ===")
    mut passed int = 0
    mut failed int = 0

    // ==================== float (f64): +0.0 vs -0.0 ====================
    println("  -- f64: +0.0 vs -0.0 --")

    mut m map[float:string] = {0.0: "pos"}
    m[-0.0] = "neg"
    if len(m) == 1 {
        println("  [PASS] +0.0 and -0.0 collapse to one entry")
        passed += 1
    } otherwise {
        println("  [FAIL] expected 1 entry, got ${len(m)}")
        failed += 1
    }
    if m[0.0] == "neg" && m[-0.0] == "neg" {
        println("  [PASS] -0.0 overwrote +0.0; both lookups return 'neg'")
        passed += 1
    } otherwise {
        println("  [FAIL] m[0.0]='${m[0.0]}', m[-0.0]='${m[-0.0]}'")
        failed += 1
    }

    // ==================== f64: NaN dedup ====================
    println("  -- f64: NaN keys --")

    mut nan1 float = math.INF - math.INF
    mut nan2 float = math.INF - math.INF
    mut nm map[float:int] = {:}
    nm[nan1] = 1
    nm[nan2] = 2
    if len(nm) == 1 && nm[nan1] == 2 && nm[nan2] == 2 {
        println("  [PASS] NaN keys dedup; later write wins")
        passed += 1
    } otherwise {
        println("  [FAIL] len=${len(nm)}, nm[nan1]=${nm[nan1]}, nm[nan2]=${nm[nan2]}")
        failed += 1
    }

    // ==================== f32: +0.0 vs -0.0 ====================
    println("  -- f32: +0.0 vs -0.0 --")

    mut m32 map[f32:string] = {0.0: "pos"}
    m32[-0.0] = "neg"
    if len(m32) == 1 && m32[0.0] == "neg" && m32[-0.0] == "neg" {
        println("  [PASS] f32 +0.0/-0.0 collapse, value 'neg'")
        passed += 1
    } otherwise {
        println("  [FAIL] f32: len=${len(m32)}, m[0]='${m32[0.0]}', m[-0]='${m32[-0.0]}'")
        failed += 1
    }

    // ==================== copy preserves kind ====================
    println("  -- maps.copy preserves kind --")

    mut src map[float:string] = {0.0: "z"}
    mut dst = copy(src)
    dst[-0.0] = "negz"
    if len(dst) == 1 && dst[0.0] == "negz" {
        println("  [PASS] copied map still normalizes -0.0 to +0.0")
        passed += 1
    } otherwise {
        println("  [FAIL] copied map: len=${len(dst)}, dst[0.0]='${dst[0.0]}'")
        failed += 1
    }

    // ==================== merge preserves kind ====================
    println("  -- maps.merge preserves kind --")

    mut a map[float:int] = {0.0: 10}
    mut b map[float:int] = {:}
    b[-0.0] = 20
    mut merged = maps.merge(a, b)
    if len(merged) == 1 && merged[0.0] == 20 && merged[-0.0] == 20 {
        println("  [PASS] merged map normalizes float keys")
        passed += 1
    } otherwise {
        println("  [FAIL] merged: len=${len(merged)}, merged[0.0]=${merged[0.0]}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
