/*
 * Test: map 'in' operator with various key types
 * Verifies map membership check works with correct C type casting
 */

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: string key lookup
    mut colors map[string:int] = {"red": 1, "green": 2, "blue": 3}
    if "red" in colors {
        println("  [PASS] string key 'red' found in map")
        passed += 1
    } otherwise {
        println("  [FAIL] string key 'red' not found in map")
        failed += 1
    }

    // Test 2: string key not present
    if "yellow" !in colors {
        println("  [PASS] string key 'yellow' not in map")
        passed += 1
    } otherwise {
        println("  [FAIL] string key 'yellow' unexpectedly in map")
        failed += 1
    }

    // Test 3: int key lookup
    mut ids map[int:string] = {1: "alice", 2: "bob", 3: "charlie"}
    if 2 in ids {
        println("  [PASS] int key 2 found in map")
        passed += 1
    } otherwise {
        println("  [FAIL] int key 2 not found in map")
        failed += 1
    }

    // Test 4: int key not present
    if 99 !in ids {
        println("  [PASS] int key 99 not in map")
        passed += 1
    } otherwise {
        println("  [FAIL] int key 99 unexpectedly in map")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
