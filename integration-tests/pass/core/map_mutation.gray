/*
 * map_mutation.ez - Test map mutation operations
 *
 * Covers: add key, update key, delete key, overwrite,
 * check after mutation, string and int keys.
 */

import @maps

do main() {
    println("=== Map Mutation Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: add key
    mut m map[string:int] = {"a": 1}
    m["b"] = 2
    if len(m) == 2 && m["b"] == 2 {
        println("  [PASS] add key")
        passed += 1
    } otherwise {
        println("  [FAIL] add key")
        failed += 1
    }

    // Test 2: update existing key
    m["a"] = 99
    if m["a"] == 99 {
        println("  [PASS] update existing key")
        passed += 1
    } otherwise {
        println("  [FAIL] update: got ${m["a"]}")
        failed += 1
    }

    // Test 3: remove key
    maps.remove_key(m, "a")
    if len(m) == 1 && !maps.has_key(m, "a") {
        println("  [PASS] remove key")
        passed += 1
    } otherwise {
        println("  [FAIL] remove key")
        failed += 1
    }

    // Test 4: remaining key still accessible
    if m["b"] == 2 {
        println("  [PASS] remaining key accessible after remove")
        passed += 1
    } otherwise {
        println("  [FAIL] remaining key")
        failed += 1
    }

    // Test 5: int keys
    mut nums map[int:string] = {1: "one"}
    nums[2] = "two"
    nums[3] = "three"
    if len(nums) == 3 && nums[2] == "two" {
        println("  [PASS] int key mutation")
        passed += 1
    } otherwise {
        println("  [FAIL] int keys")
        failed += 1
    }

    // Test 6: overwrite many times
    mut counter map[string:int] = {"x": 0}
    for i in range(0, 100) {
        counter["x"] = i
    }
    if counter["x"] == 99 {
        println("  [PASS] overwrite 100 times")
        passed += 1
    } otherwise {
        println("  [FAIL] overwrite: got ${counter["x"]}")
        failed += 1
    }

    // Test 7: clear then re-add
    maps.clear(counter)
    counter["y"] = 42
    if len(counter) == 1 && counter["y"] == 42 {
        println("  [PASS] clear then re-add")
        passed += 1
    } otherwise {
        println("  [FAIL] clear then re-add")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
