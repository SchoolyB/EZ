/*
 * map_non_standard_keys.gray - Maps with bool, char, byte, and float keys
 *
 * map codegen only handled string and int
 * keys. bool/char/byte/float keys passed typechecking but emitted GrayString
 * as the C key type, causing compile errors or runtime key-not-found panics.
 */

do main() {
    println("=== Non-Standard Map Keys Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- bool keys --
    mut bmap map[bool:string] = {true: "yes", false: "no"}
    if bmap[true] == "yes" && bmap[false] == "no" {
        println("  [PASS] bool key literal access")
        passed += 1
    } otherwise {
        println("  [FAIL] bool key literal access")
        failed += 1
    }

    bmap[true] = "affirmative"
    if bmap[true] == "affirmative" {
        println("  [PASS] bool key assignment update")
        passed += 1
    } otherwise {
        println("  [FAIL] bool key assignment update")
        failed += 1
    }

    // -- char keys --
    mut cmap map[char:int] = {'a': 1, 'b': 2, 'c': 3}
    if cmap['a'] == 1 && cmap['b'] == 2 && cmap['c'] == 3 {
        println("  [PASS] char key literal access")
        passed += 1
    } otherwise {
        println("  [FAIL] char key literal access")
        failed += 1
    }

    cmap['d'] = 4
    if cmap['d'] == 4 && len(cmap) == 4 {
        println("  [PASS] char key insertion")
        passed += 1
    } otherwise {
        println("  [FAIL] char key insertion")
        failed += 1
    }

    // -- byte keys --
    mut ymap map[byte:string] = {0b1: "one", 0b10: "two", 0b11: "three"}
    if ymap[0b1] == "one" && ymap[0b10] == "two" && ymap[0b11] == "three" {
        println("  [PASS] byte key literal access")
        passed += 1
    } otherwise {
        println("  [FAIL] byte key literal access")
        failed += 1
    }

    ymap[0b100] = "four"
    if ymap[0b100] == "four" && len(ymap) == 4 {
        println("  [PASS] byte key insertion")
        passed += 1
    } otherwise {
        println("  [FAIL] byte key insertion")
        failed += 1
    }

    // -- float keys --
    mut fmap map[float:int] = {1.5: 10, 2.5: 20, 3.5: 30}
    if fmap[1.5] == 10 && fmap[2.5] == 20 && fmap[3.5] == 30 {
        println("  [PASS] float key literal access")
        passed += 1
    } otherwise {
        println("  [FAIL] float key literal access")
        failed += 1
    }

    fmap[4.5] = 40
    if fmap[4.5] == 40 && len(fmap) == 4 {
        println("  [PASS] float key insertion")
        passed += 1
    } otherwise {
        println("  [FAIL] float key insertion")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
