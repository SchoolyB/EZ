/*
 * map_non_standard_keys_ops.ez - 'in' operator and function params for
 * bool/char/byte/float key maps.
 *
 * Complements map_non_standard_keys.ez (#1430). The original fix patched
 * five map codegen sites to use ez_map_elem_c_type for the key; this test
 * exercises the remaining user-visible paths for those key types: the
 * 'in'/'!in' membership operator and passing such maps through function
 * calls (which re-emits key types at the call boundary).
 */

do count_true(m map[bool:string]) -> int {
    mut n int = 0
    if true in m { n += 1 }
    if false in m { n += 1 }
    return n
}

do lookup_char(m map[char:int], k char) -> int {
    if k in m {
        return m[k]
    }
    return -1
}

do sum_byte_values(m map[byte:int]) -> int {
    mut total int = 0
    if 0b1 in m { total += m[0b1] }
    if 0b10 in m { total += m[0b10] }
    if 0b100 in m { total += m[0b100] }
    return total
}

do has_float_key(m map[float:string], k float) -> bool {
    return k in m
}

do main() {
    println("=== Non-Standard Map Key Ops Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- bool: in / !in --
    mut bmap map[bool:string] = {true: "yes", false: "no"}
    if true in bmap && false in bmap {
        println("  [PASS] bool keys 'in' operator")
        passed += 1
    } otherwise {
        println("  [FAIL] bool keys 'in' operator")
        failed += 1
    }

    // -- char: in / !in --
    mut cmap map[char:int] = {'a': 1, 'b': 2}
    if 'a' in cmap && 'z' !in cmap {
        println("  [PASS] char key 'in' / '!in'")
        passed += 1
    } otherwise {
        println("  [FAIL] char key 'in' / '!in'")
        failed += 1
    }

    // -- byte: in / !in --
    mut ymap map[byte:int] = {0b1: 10, 0b10: 20, 0b100: 40}
    if 0b10 in ymap && 0b1000 !in ymap {
        println("  [PASS] byte key 'in' / '!in'")
        passed += 1
    } otherwise {
        println("  [FAIL] byte key 'in' / '!in'")
        failed += 1
    }

    // -- float: in / !in --
    mut fmap map[float:string] = {1.5: "a", 2.5: "b"}
    if 1.5 in fmap && 9.9 !in fmap {
        println("  [PASS] float key 'in' / '!in'")
        passed += 1
    } otherwise {
        println("  [FAIL] float key 'in' / '!in'")
        failed += 1
    }

    // -- bool map through function call --
    if count_true(bmap) == 2 {
        println("  [PASS] bool key map passed to function")
        passed += 1
    } otherwise {
        println("  [FAIL] bool key map passed to function")
        failed += 1
    }

    // -- char map through function call --
    if lookup_char(cmap, 'b') == 2 && lookup_char(cmap, 'x') == -1 {
        println("  [PASS] char key map passed to function")
        passed += 1
    } otherwise {
        println("  [FAIL] char key map passed to function")
        failed += 1
    }

    // -- byte map through function call --
    if sum_byte_values(ymap) == 70 {
        println("  [PASS] byte key map passed to function")
        passed += 1
    } otherwise {
        println("  [FAIL] byte key map passed to function: got ${sum_byte_values(ymap)}")
        failed += 1
    }

    // -- float map through function call --
    if has_float_key(fmap, 2.5) && !has_float_key(fmap, 0.0) {
        println("  [PASS] float key map passed to function")
        passed += 1
    } otherwise {
        println("  [FAIL] float key map passed to function")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
