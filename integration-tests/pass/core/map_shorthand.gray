/*
 * map_shorthand.gray - Test [K:V] shorthand syntax for maps
 */

import @maps

do get_map() -> [string:int] {
    mut result [string:int] = {"a": 1, "b": 2}
    return result
}

do take_map(m [string:int]) -> int {
    return m["a"]
}

do main() {
    println("=== Map Shorthand [K:V] Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: Variable declaration with [K:V]
    mut m1 [string:int] = {"x": 10, "y": 20}
    if len(m1) == 2 {
        println("  [PASS] [K:V] variable declaration")
        passed += 1
    } otherwise {
        println("  [FAIL] [K:V] variable declaration")
        failed += 1
    }

    // Test 2: Function return type with [K:V]
    mut m2 [string:int] = get_map()
    if m2["a"] == 1 {
        println("  [PASS] [K:V] function return type")
        passed += 1
    } otherwise {
        println("  [FAIL] [K:V] function return type")
        failed += 1
    }

    // Test 3: Function parameter with [K:V]
    mut m3 [string:int] = {"a": 42}
    if take_map(m3) == 42 {
        println("  [PASS] [K:V] function parameter")
        passed += 1
    } otherwise {
        println("  [FAIL] [K:V] function parameter")
        failed += 1
    }

    // Test 4: Nested map — array of maps [[string:int]]
    mut m4 [[string:int]] = {{"a": 1}, {"b": 2}}
    if len(m4) == 2 {
        println("  [PASS] nested [[string:int]]")
        passed += 1
    } otherwise {
        println("  [FAIL] nested [[string:int]]")
        failed += 1
    }

    // Test 5: Nested map — map of maps [string:[string:int]]
    mut m5 [string:[string:int]] = {"outer": {"inner": 99}}
    if m5["outer"]["inner"] == 99 {
        println("  [PASS] nested [string:[string:int]]")
        passed += 1
    } otherwise {
        println("  [FAIL] nested [string:[string:int]]")
        failed += 1
    }

    // Test 6: Mixed — map[K:V] and [K:V] in same program
    mut m6 map[string:int] = {"old": 1}
    mut m7 [string:int] = {"new": 2}
    if m6["old"] == 1 && m7["new"] == 2 {
        println("  [PASS] mixed map[K:V] and [K:V]")
        passed += 1
    } otherwise {
        println("  [FAIL] mixed map[K:V] and [K:V]")
        failed += 1
    }

    // Test 7: Empty map with [K:V]
    mut m8 [string:int] = {:}
    if len(m8) == 0 {
        println("  [PASS] empty [K:V] map")
        passed += 1
    } otherwise {
        println("  [FAIL] empty [K:V] map")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed out of ${passed + failed}")
}
