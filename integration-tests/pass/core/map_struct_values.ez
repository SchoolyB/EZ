/*
 * map_struct_values.ez - Test maps with struct value types
 */

import @std
using std

const Point struct {
    x int
    y int
}

const Person struct {
    name string
    age int
}

do main() {
    println("=== Map Struct Values Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: Create map with struct values
    mut points map[string:Point] = {"origin": Point{x: 0, y: 0}, "corner": Point{x: 10, y: 20}}
    mut p Point = points["origin"]
    if p.x == 0 {
        println("  [PASS] points[\"origin\"].x == 0")
        passed += 1
    } otherwise {
        println("  [FAIL] points[\"origin\"].x expected 0")
        failed += 1
    }

    // Test 2: Access second entry
    mut c Point = points["corner"]
    if c.y == 20 {
        println("  [PASS] points[\"corner\"].y == 20")
        passed += 1
    } otherwise {
        println("  [FAIL] points[\"corner\"].y expected 20")
        failed += 1
    }

    // Test 3: Set a new struct value in map
    points["mid"] = Point{x: 5, y: 10}
    mut m Point = points["mid"]
    if m.x == 5 {
        println("  [PASS] points[\"mid\"].x == 5 after set")
        passed += 1
    } otherwise {
        println("  [FAIL] points[\"mid\"].x expected 5")
        failed += 1
    }

    // Test 4: Map with Person struct values
    mut people map[string:Person] = {"alice": Person{name: "Alice", age: 30}}
    mut a Person = people["alice"]
    if a.age == 30 {
        println("  [PASS] people[\"alice\"].age == 30")
        passed += 1
    } otherwise {
        println("  [FAIL] people[\"alice\"].age expected 30")
        failed += 1
    }

    // Test 5: for_each over map with struct values
    mut count int = 0
    for_each key, val in points {
        count += 1
    }
    if count == 3 {
        println("  [PASS] for_each iterated 3 entries")
        passed += 1
    } otherwise {
        println("  [FAIL] for_each expected 3 entries, got ${count}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("SOME TESTS FAILED")
    }
}
