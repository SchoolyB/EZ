/*
 * math_float_returns.ez - Test math functions return float for float args (#1312)
 *
 * Verifies that math.abs, min, max, clamp, neg return float when
 * given float arguments instead of truncating to int.
 */

import @math

do main() {
    println("=== Math Float Return Type Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: math.abs(float) returns float
    mut a float = math.abs(-3.14)
    if a > 3.13 && a < 3.15 {
        println("  [PASS] math.abs(-3.14) == 3.14 (float)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.abs(-3.14) got ${a}")
        failed += 1
    }

    // Test 2: math.abs(int) still returns int
    mut b int = math.abs(-42)
    if b == 42 {
        println("  [PASS] math.abs(-42) == 42 (int)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.abs(-42) got ${b}")
        failed += 1
    }

    // Test 3: math.min(float, float) returns float
    mut c float = math.min(1.5, 2.7)
    if c > 1.49 && c < 1.51 {
        println("  [PASS] math.min(1.5, 2.7) == 1.5 (float)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.min(1.5, 2.7) got ${c}")
        failed += 1
    }

    // Test 4: math.max(float, float) returns float
    mut d float = math.max(1.5, 2.7)
    if d > 2.69 && d < 2.71 {
        println("  [PASS] math.max(1.5, 2.7) == 2.7 (float)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.max(1.5, 2.7) got ${d}")
        failed += 1
    }

    // Test 5: math.min(int, int) still returns int
    mut e int = math.min(10, 20)
    if e == 10 {
        println("  [PASS] math.min(10, 20) == 10 (int)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.min(10, 20) got ${e}")
        failed += 1
    }

    // Test 6: math.max(int, int) still returns int
    mut f int = math.max(10, 20)
    if f == 20 {
        println("  [PASS] math.max(10, 20) == 20 (int)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.max(10, 20) got ${f}")
        failed += 1
    }

    // Test 7: math.clamp(float, float, float) returns float
    mut g float = math.clamp(5.5, 0.0, 3.0)
    if g > 2.99 && g < 3.01 {
        println("  [PASS] math.clamp(5.5, 0.0, 3.0) == 3.0 (float)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.clamp(5.5, 0.0, 3.0) got ${g}")
        failed += 1
    }

    // Test 8: math.clamp(int, int, int) still returns int
    mut h int = math.clamp(150, 0, 100)
    if h == 100 {
        println("  [PASS] math.clamp(150, 0, 100) == 100 (int)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.clamp(150, 0, 100) got ${h}")
        failed += 1
    }

    // Test 9: math.clamp(float) within range passes through
    mut i float = math.clamp(1.5, 0.0, 3.0)
    if i > 1.49 && i < 1.51 {
        println("  [PASS] math.clamp(1.5, 0.0, 3.0) == 1.5 (passthrough)")
        passed += 1
    } otherwise {
        println("  [FAIL] math.clamp passthrough got ${i}")
        failed += 1
    }

    // Test 10: math.abs(float) with zero
    mut j float = math.abs(0.0)
    if j > -0.01 && j < 0.01 {
        println("  [PASS] math.abs(0.0) == 0.0")
        passed += 1
    } otherwise {
        println("  [FAIL] math.abs(0.0) got ${j}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
