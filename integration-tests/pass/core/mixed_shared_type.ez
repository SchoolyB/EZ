/* Test: Mixed shared type named return values
 * Expected: passes with output "Alice", "NYC", "30"
 */


do getFullInfo() -> (name, city string, age int) {
    mut name string = "Alice"
    mut city string = "NYC"
    mut age int = 30
    return name, city, age
}

do main() {
    mut n string, c string, a int = getFullInfo()
    println(n)
    println(c)
    println(a)
}
