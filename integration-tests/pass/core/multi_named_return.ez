/* Test: Multiple named return values with different types
 * Expected: passes with output "25" and "Bob"
 */


do getPersonInfo() -> (age int, name string) {
    mut age int = 25
    mut name string = "Bob"
    return age, name
}

do main() {
    mut a int, n string = getPersonInfo()
    println(a)
    println(n)
    println("ALL TESTS PASSED")
}
