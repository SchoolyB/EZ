/*
 * mut_mutability.ez - Test that mut automatically makes function returns mutable
 */

import @arrays
using arrays

do get_numbers() -> [int] {
    return {1, 2, 3}
}

do get_point() -> (int, int) {
    return 10, 20
}

do main() {
    println("=== Temp Mutability Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: mut from function return is mutable (can modify elements)
    mut arr = get_numbers()
    arr[0] = 99
    if arr[0] == 99 {
        println("  [PASS] mut arr from fn return: arr[0] = 99 (mutable)")
        passed += 1
    } otherwise {
        println("  [FAIL] mut arr from fn return: expected arr[0] = 99, got ${arr[0]}")
        failed += 1
    }

    // Test 2: mut from function return can be appended to
    arrays.append(arr, 4)
    if len(arr) == 4 {
        println("  [PASS] mut arr from fn return: append works, len = 4")
        passed += 1
    } otherwise {
        println("  [FAIL] mut arr from fn return: expected len 4, got ${len(arr)}")
        failed += 1
    }

    // Test 3: mut from function return can be reassigned
    arr = {10, 20}
    if len(arr) == 2 {
        println("  [PASS] mut arr reassigned: len = 2")
        passed += 1
    } otherwise {
        println("  [FAIL] mut arr reassigned: expected len 2, got ${len(arr)}")
        failed += 1
    }

    // Test 4: mut from multi-return is mutable
    mut x, y = get_point()
    x = x + 5
    y = y + 10
    if x == 15 && y == 30 {
        println("  [PASS] mut from multi-return: x = 15, y = 30 (mutable)")
        passed += 1
    } otherwise {
        println("  [FAIL] mut from multi-return: expected 15,30, got ${x},${y}")
        failed += 1
    }

    // Test 5: mut from array literal is mutable
    mut lit [int] = {1, 2, 3}
    lit[0] = 100
    if lit[0] == 100 {
        println("  [PASS] mut array literal: lit[0] = 100 (mutable)")
        passed += 1
    } otherwise {
        println("  [FAIL] mut array literal: expected 100, got ${lit[0]}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
