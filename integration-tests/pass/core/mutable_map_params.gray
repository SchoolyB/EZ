/*
 * mutable_map_params.gray - Test mutable map element parameters
 *
 * Verifies that passing map elements (m["key"]) as mutable parameters
 * uses the map accessor instead of the array accessor.
 */


do increment(&val int) {
    val += 1
}

do set_value(&val int, new_val int) {
    val = new_val
}

do main() {
    println("=== Mutable Map Element Parameters ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: increment map value via mutable param
    mut m map[string:int] = {"a": 10, "b": 20}
    increment(m["a"])
    if m["a"] == 11 {
        println("  [PASS] increment map['a'] via mutable param")
        passed += 1
    } otherwise {
        println("  [FAIL] increment map['a']")
        failed += 1
    }

    // Test 2: other keys unaffected
    if m["b"] == 20 {
        println("  [PASS] m['b'] unchanged")
        passed += 1
    } otherwise {
        println("  [FAIL] m['b'] changed unexpectedly")
        failed += 1
    }

    // Test 3: set map value via mutable param
    set_value(m["b"], 99)
    if m["b"] == 99 {
        println("  [PASS] set_value m['b'] via mutable param")
        passed += 1
    } otherwise {
        println("  [FAIL] set_value m['b']")
        failed += 1
    }

    // Test 4: multiple increments on same key
    increment(m["a"])
    increment(m["a"])
    if m["a"] == 13 {
        println("  [PASS] multiple increments on m['a']")
        passed += 1
    } otherwise {
        println("  [FAIL] multiple increments m['a']")
        failed += 1
    }

    // Test 5: int-keyed map
    mut m2 map[int:int] = {1: 100, 2: 200}
    increment(m2[1])
    if m2[1] == 101 {
        println("  [PASS] increment int-keyed map[1]")
        passed += 1
    } otherwise {
        println("  [FAIL] int-keyed map increment")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
