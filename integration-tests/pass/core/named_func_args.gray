/*
 * named_func_args.gray - Test named function arguments at call sites
 * Verifies name: value syntax for call-site named args
 */

do add(a int, b int) -> int {
    return a + b
}

do greet(name string, greeting string = "Hello") -> string {
    return "${greeting}, ${name}!"
}

do point(x int, y int, z int = 0) -> string {
    return "(${x}, ${y}, ${z})"
}

const Vec struct {
    x int
    y int

    do scale(self Vec, factor int) -> Vec {
        return Vec{x: self.x * factor, y: self.y * factor}
    }
}

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: all named, in signature order
    mut r1 int = add(a: 3, b: 4)
    if r1 == 7 {
        println("  [PASS] add(a: 3, b: 4) = 7")
        passed += 1
    } otherwise {
        println("  [FAIL] add(a: 3, b: 4): expected 7, got ${r1}")
        failed += 1
    }

    // Test 2: all named, reordered
    mut r2 int = add(b: 10, a: 5)
    if r2 == 15 {
        println("  [PASS] add(b: 10, a: 5) = 15")
        passed += 1
    } otherwise {
        println("  [FAIL] add(b: 10, a: 5): expected 15, got ${r2}")
        failed += 1
    }

    // Test 3: mixed positional + named
    mut r3 int = add(1, b: 2)
    if r3 == 3 {
        println("  [PASS] add(1, b: 2) = 3")
        passed += 1
    } otherwise {
        println("  [FAIL] add(1, b: 2): expected 3, got ${r3}")
        failed += 1
    }

    // Test 4: named arg skipping a default param
    mut r4 string = greet(name: "World")
    if r4 == "Hello, World!" {
        println("  [PASS] greet(name: 'World') = 'Hello, World!'")
        passed += 1
    } otherwise {
        println("  [FAIL] greet(name: 'World'): expected 'Hello, World!', got '${r4}'")
        failed += 1
    }

    // Test 5: named arg overriding a default
    mut r5 string = greet(name: "World", greeting: "Hi")
    if r5 == "Hi, World!" {
        println("  [PASS] greet(name: 'World', greeting: 'Hi') = 'Hi, World!'")
        passed += 1
    } otherwise {
        println("  [FAIL] greet(name: 'World', greeting: 'Hi'): expected 'Hi, World!', got '${r5}'")
        failed += 1
    }

    // Test 6: named args reordered with defaults
    mut r6 string = greet(greeting: "Hey", name: "Grayscale")
    if r6 == "Hey, Grayscale!" {
        println("  [PASS] greet(greeting: 'Hey', name: 'Grayscale') = 'Hey, Grayscale!'")
        passed += 1
    } otherwise {
        println("  [FAIL] greet(greeting: 'Hey', name: 'Grayscale'): expected 'Hey, Grayscale!', got '${r6}'")
        failed += 1
    }

    // Test 7: positional + named with trailing default
    mut r7 string = point(1, y: 2)
    if r7 == "(1, 2, 0)" {
        println("  [PASS] point(1, y: 2) = '(1, 2, 0)'")
        passed += 1
    } otherwise {
        println("  [FAIL] point(1, y: 2): expected '(1, 2, 0)', got '${r7}'")
        failed += 1
    }

    // Test 8: named arg targeting last param, skipping middle default
    mut r8 string = point(1, 2, z: 9)
    if r8 == "(1, 2, 9)" {
        println("  [PASS] point(1, 2, z: 9) = '(1, 2, 9)'")
        passed += 1
    } otherwise {
        println("  [FAIL] point(1, 2, z: 9): expected '(1, 2, 9)', got '${r8}'")
        failed += 1
    }

    // Test 9: all positional still works (no regression)
    mut r9 int = add(100, 200)
    if r9 == 300 {
        println("  [PASS] add(100, 200) = 300")
        passed += 1
    } otherwise {
        println("  [FAIL] add(100, 200): expected 300, got ${r9}")
        failed += 1
    }

    // Test 10: struct function with named args
    mut v Vec = Vec{x: 2, y: 3}
    mut r10 Vec = v.scale(factor: 5)
    if r10.x == 10 {
        println("  [PASS] v.scale(factor: 5).x = 10")
        passed += 1
    } otherwise {
        println("  [FAIL] v.scale(factor: 5).x: expected 10, got ${r10.x}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
