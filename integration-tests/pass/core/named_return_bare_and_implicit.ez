/* Test: Named return values with bare return and implicit return
 * Regression test for #1280 — bare `return` and fall-through implicit
 * return now collect named return variables automatically.
 * Expected: all tests pass
 */


// Single named return with bare return
do get_answer() -> (result int) {
    result = 42
    return
}

// Multiple named returns with bare return
do get_person() -> (name string, age int) {
    name = "Alice"
    age = 30
    return
}

// Single named return with implicit return (no return statement)
do get_greeting() -> (msg string) {
    msg = "hello world"
}

// Multiple named returns with implicit return (no return statement)
do get_coords() -> (x int, y int, z int) {
    x = 10
    y = 20
    z = 30
}

// Shared type named returns with bare return
do get_names() -> (first, last string) {
    first = "John"
    last = "Doe"
    return
}

// Named returns modified in control flow, then bare return
do classify(n int) -> (label string, value int) {
    value = n
    if n > 0 {
        label = "positive"
    } or n < 0 {
        label = "negative"
    } otherwise {
        label = "zero"
    }
    return
}

// Named return with implicit return after loop
do sum_to(n int) -> (total int) {
    total = 0
    for i in range(1, n + 1) {
        total += i
    }
}

do main() {
    println("=== Named Return: Bare & Implicit Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: single named return with bare return
    mut ans int = get_answer()
    if ans == 42 {
        println("  [PASS] single named return with bare return")
        passed += 1
    } otherwise {
        println("  [FAIL] single named return with bare return")
        failed += 1
    }

    // Test 2: multiple named returns with bare return
    mut name string, age int = get_person()
    if name == "Alice" && age == 30 {
        println("  [PASS] multiple named returns with bare return")
        passed += 1
    } otherwise {
        println("  [FAIL] multiple named returns with bare return")
        failed += 1
    }

    // Test 3: single named return with implicit return
    mut greet string = get_greeting()
    if greet == "hello world" {
        println("  [PASS] single named return with implicit return")
        passed += 1
    } otherwise {
        println("  [FAIL] single named return with implicit return")
        failed += 1
    }

    // Test 4: multiple named returns with implicit return
    mut cx int, cy int, cz int = get_coords()
    if cx == 10 && cy == 20 && cz == 30 {
        println("  [PASS] multiple named returns with implicit return")
        passed += 1
    } otherwise {
        println("  [FAIL] multiple named returns with implicit return")
        failed += 1
    }

    // Test 5: shared type named returns with bare return
    mut f string, l string = get_names()
    if f == "John" && l == "Doe" {
        println("  [PASS] shared type named returns with bare return")
        passed += 1
    } otherwise {
        println("  [FAIL] shared type named returns with bare return")
        failed += 1
    }

    // Test 6: named returns modified in control flow
    mut lab1 string, _ = classify(5)
    mut lab2 string, _ = classify(-3)
    mut lab3 string, val3 int = classify(0)
    if lab1 == "positive" && lab2 == "negative" && lab3 == "zero" && val3 == 0 {
        println("  [PASS] named returns with control flow + bare return")
        passed += 1
    } otherwise {
        println("  [FAIL] named returns with control flow + bare return")
        failed += 1
    }

    // Test 7: named return with implicit return after loop
    mut total int = sum_to(10)
    if total == 55 {
        println("  [PASS] named return with implicit return after loop")
        passed += 1
    } otherwise {
        println("  [FAIL] named return with implicit return after loop")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
