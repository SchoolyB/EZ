/* Test: Named return values with explicit variable declarations
 * Regression test for #1280 — verifies that functions with named
 * return values work correctly when variables are explicitly declared.
 * Expected: all tests pass
 */


// Single named return
do get_answer() -> (result int) {
    mut result int = 42
    return result
}

// Multiple named returns
do get_person() -> (name string, age int) {
    mut name string = "Alice"
    mut age int = 30
    return name, age
}

// Single named return
do get_greeting() -> (msg string) {
    mut msg string = "hello world"
    return msg
}

// Multiple named returns
do get_coords() -> (x int, y int, z int) {
    mut x int = 10
    mut y int = 20
    mut z int = 30
    return x, y, z
}

// Shared type named returns
do get_names() -> (first, last string) {
    mut first string = "John"
    mut last string = "Doe"
    return first, last
}

// Named returns modified in control flow
do classify(n int) -> (label string, value int) {
    mut value int = n
    mut label string = ""
    if n > 0 {
        label = "positive"
    } or n < 0 {
        label = "negative"
    } otherwise {
        label = "zero"
    }
    return label, value
}

// Named return after loop
do sum_to(n int) -> (total int) {
    mut total int = 0
    for i in range(1, n + 1) {
        total += i
    }
    return total
}

do main() {
    println("=== Named Return: Explicit Declaration Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: single named return
    mut ans int = get_answer()
    if ans == 42 {
        println("  [PASS] single named return")
        passed += 1
    } otherwise {
        println("  [FAIL] single named return")
        failed += 1
    }

    // Test 2: multiple named returns
    mut name string, age int = get_person()
    if name == "Alice" && age == 30 {
        println("  [PASS] multiple named returns")
        passed += 1
    } otherwise {
        println("  [FAIL] multiple named returns")
        failed += 1
    }

    // Test 3: single named return greeting
    mut greet string = get_greeting()
    if greet == "hello world" {
        println("  [PASS] single named return greeting")
        passed += 1
    } otherwise {
        println("  [FAIL] single named return greeting")
        failed += 1
    }

    // Test 4: multiple named returns coords
    mut cx int, cy int, cz int = get_coords()
    if cx == 10 && cy == 20 && cz == 30 {
        println("  [PASS] multiple named returns coords")
        passed += 1
    } otherwise {
        println("  [FAIL] multiple named returns coords")
        failed += 1
    }

    // Test 5: shared type named returns
    mut f string, l string = get_names()
    if f == "John" && l == "Doe" {
        println("  [PASS] shared type named returns")
        passed += 1
    } otherwise {
        println("  [FAIL] shared type named returns")
        failed += 1
    }

    // Test 6: named returns modified in control flow
    mut lab1 string, _ = classify(5)
    mut lab2 string, _ = classify(-3)
    mut lab3 string, val3 int = classify(0)
    if lab1 == "positive" && lab2 == "negative" && lab3 == "zero" && val3 == 0 {
        println("  [PASS] named returns with control flow")
        passed += 1
    } otherwise {
        println("  [FAIL] named returns with control flow")
        failed += 1
    }

    // Test 7: named return after loop
    mut total int = sum_to(10)
    if total == 55 {
        println("  [PASS] named return after loop")
        passed += 1
    } otherwise {
        println("  [FAIL] named return after loop")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
