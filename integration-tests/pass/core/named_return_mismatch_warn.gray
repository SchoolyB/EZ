/* Test: Named return values — matching and mismatched variable names
 * E3080 enforces that returned variables must match
 * the named return identifiers. This test verifies correct behavior
 * when variable names match the named returns.
 * Note: W2011 warning not yet implemented
 */


do get_value() -> (result int) {
    mut result int = 99
    return result
}

do get_pair() -> (name string, age int) {
    mut name string = "Bob"
    mut age int = 25
    return name, age
}

do get_proper() -> (name string) {
    mut name string = "Alice"
    return name
}

do main() {
    println("=== Named Return Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: single named return — value is correct
    mut v int = get_value()
    if v == 99 {
        println("  [PASS] named return produces correct value")
        passed += 1
    } otherwise {
        println("  [FAIL] named return")
        failed += 1
    }

    // Test 2: multi-return with named vars — values correct
    mut n string, a int = get_pair()
    if n == "Bob" && a == 25 {
        println("  [PASS] multi named return correct")
        passed += 1
    } otherwise {
        println("  [FAIL] multi named return")
        failed += 1
    }

    // Test 3: proper named return — correct value
    mut proper string = get_proper()
    if proper == "Alice" {
        println("  [PASS] proper named return — correct value")
        passed += 1
    } otherwise {
        println("  [FAIL] proper named return")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
