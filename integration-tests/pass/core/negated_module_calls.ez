/*
 * negated_module_calls.ez - Test !module.func() codegen (#1309)
 *
 * Verifies that negated module-qualified calls generate valid C.
 * Previously, !regex.is_valid(), !strings.contains(), etc. emitted
 * raw module.func() dot-access in C instead of ez_module_func().
 */

import @std
import @strings
import @math
import @regex
using std

do main() {
    println("=== Negated Module-Qualified Calls ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: !strings.contains() in if
    if !strings.contains("hello", "xyz") {
        println("  [PASS] !strings.contains('hello', 'xyz') is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !strings.contains should be true")
        failed += 1
    }

    // Test 2: strings.contains() without negation (baseline)
    if strings.contains("hello", "ell") {
        println("  [PASS] strings.contains('hello', 'ell') is true")
        passed += 1
    } otherwise {
        println("  [FAIL] strings.contains should be true")
        failed += 1
    }

    // Test 3: !math.is_even() in if
    if !math.is_even(3) {
        println("  [PASS] !math.is_even(3) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !math.is_even(3) should be true")
        failed += 1
    }

    // Test 4: math.is_even() without negation
    if math.is_even(4) {
        println("  [PASS] math.is_even(4) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] math.is_even(4) should be true")
        failed += 1
    }

    // Test 5: !math.is_odd() in if
    if !math.is_odd(4) {
        println("  [PASS] !math.is_odd(4) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !math.is_odd(4) should be true")
        failed += 1
    }

    // Test 6: !regex.is_valid() with invalid pattern
    if !regex.is_valid("[unclosed") {
        println("  [PASS] !regex.is_valid('[unclosed') is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !regex.is_valid('[unclosed') should be true")
        failed += 1
    }

    // Test 7: regex.is_valid() with valid pattern
    if regex.is_valid("[0-9]+") {
        println("  [PASS] regex.is_valid('[0-9]+') is true")
        passed += 1
    } otherwise {
        println("  [FAIL] regex.is_valid('[0-9]+') should be true")
        failed += 1
    }

    // Test 8: store module call in variable, then negate
    mut contains bool = strings.contains("hello world", "xyz")
    if !contains {
        println("  [PASS] stored result negation matches direct negation")
        passed += 1
    } otherwise {
        println("  [FAIL] stored result negation should match")
        failed += 1
    }

    // Test 9: store negated module call directly
    mut not_even bool = !math.is_even(7)
    if not_even {
        println("  [PASS] mut not_even = !math.is_even(7) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !math.is_even(7) stored should be true")
        failed += 1
    }

    // Test 10: double negation of module call
    if !!strings.contains("test", "es") {
        println("  [PASS] !!strings.contains('test', 'es') is true")
        passed += 1
    } otherwise {
        println("  [FAIL] double negation should preserve truthiness")
        failed += 1
    }

    // Test 11: negated module call in compound condition
    if !strings.contains("abc", "z") && math.is_even(10) {
        println("  [PASS] !module.func() in compound && condition")
        passed += 1
    } otherwise {
        println("  [FAIL] compound condition with negated module call")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
