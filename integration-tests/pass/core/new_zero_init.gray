/*
 * Test: new() returns zero-initialized struct fields
 * Verifies that arena-allocated structs via new() have all fields
 * at their zero values (0, "", false) instead of garbage.
 */

const Data struct {
    count int
    name string
    flag bool
    score float
    tag char
    small u8
}

const Nested struct {
    x int
    y int
}

const Outer struct {
    n Nested
    value int
}

do main() {
    mut passed int = 0
    mut failed int = 0

    mut d = new(Data)

    // Test 1: int field is 0
    if d.count == 0 {
        println("  [PASS] new() int field is 0")
        passed += 1
    } otherwise {
        println("  [FAIL] new() int field: expected 0, got ${d.count}")
        failed += 1
    }

    // Test 2: string field is ""
    if d.name == "" {
        println("  [PASS] new() string field is empty")
        passed += 1
    } otherwise {
        println("  [FAIL] new() string field: expected empty")
        failed += 1
    }

    // Test 3: bool field is false
    if d.flag == false {
        println("  [PASS] new() bool field is false")
        passed += 1
    } otherwise {
        println("  [FAIL] new() bool field: expected false")
        failed += 1
    }

    // Test 4: float field is 0.0
    if d.score == 0.0 {
        println("  [PASS] new() float field is 0.0")
        passed += 1
    } otherwise {
        println("  [FAIL] new() float field: expected 0.0")
        failed += 1
    }

    // Test 5: u8 field is 0
    if cast(d.small, int) == 0 {
        println("  [PASS] new() u8 field is 0")
        passed += 1
    } otherwise {
        println("  [FAIL] new() u8 field: expected 0")
        failed += 1
    }

    // Test 6: second allocation also zero-initialized
    // (tests that recycled arena memory is zeroed)
    mut d2 = new(Data)
    if d2.count == 0 {
        println("  [PASS] second new() int field is 0")
        passed += 1
    } otherwise {
        println("  [FAIL] second new() int field: expected 0, got ${d2.count}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
