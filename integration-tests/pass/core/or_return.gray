/*
 * or_return.gray - Test or_return error propagation
 *
 * Covers: bare or_return, or_return with fallback values,
 * chained or_return, successful path (no error).
 */

do might_fail(fail bool) -> (int, Error) {
    if fail {
        return 0, error("it failed")
    }
    return 42, nil
}

do double_fail(fail bool) -> (string, Error) {
    if fail {
        return "", error("double failed")
    }
    return "ok", nil
}

do wrapper_bare() -> (int, Error) {
    mut val int = might_fail(true) or_return
    return val, nil
}

do wrapper_success() -> (int, Error) {
    mut val int = might_fail(false) or_return
    return val, nil
}

do chained() -> (string, Error) {
    mut num int = might_fail(false) or_return
    mut msg string = double_fail(false) or_return
    return "${msg}-${num}", nil
}

do chained_fail_first() -> (string, Error) {
    mut num int = might_fail(true) or_return
    mut msg string = double_fail(false) or_return
    return "${msg}-${num}", nil
}

do chained_fail_second() -> (string, Error) {
    mut num int = might_fail(false) or_return
    mut msg string = double_fail(true) or_return
    return "${msg}-${num}", nil
}

do main() {
    println("=== or_return Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: bare or_return propagates error
    mut v1 int, e1 Error = wrapper_bare()
    if e1 != nil && v1 == 0 {
        println("  [PASS] bare or_return propagates error")
        passed += 1
    } otherwise {
        println("  [FAIL] bare or_return: v=${v1}")
        failed += 1
    }

    // Test 2: or_return passes through on success
    mut v2 int, e2 Error = wrapper_success()
    if e2 == nil && v2 == 42 {
        println("  [PASS] or_return passes through on success")
        passed += 1
    } otherwise {
        println("  [FAIL] or_return success: v=${v2}")
        failed += 1
    }

    // Test 3: chained or_return all succeed
    mut v3 string, e3 Error = chained()
    if e3 == nil && v3 == "ok-42" {
        println("  [PASS] chained or_return all succeed")
        passed += 1
    } otherwise {
        println("  [FAIL] chained: v='${v3}'")
        failed += 1
    }

    // Test 4: chained or_return first fails
    mut v4 string, e4 Error = chained_fail_first()
    if e4 != nil {
        println("  [PASS] chained first fails propagates")
        passed += 1
    } otherwise {
        println("  [FAIL] chained first: expected error")
        failed += 1
    }

    // Test 5: chained or_return second fails
    mut v5 string, e5 Error = chained_fail_second()
    if e5 != nil {
        println("  [PASS] chained second fails propagates")
        passed += 1
    } otherwise {
        println("  [FAIL] chained second: expected error")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
