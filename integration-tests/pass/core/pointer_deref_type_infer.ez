/*
 * pointer_deref_type_infer.ez
 * Regression test for #1786: `mut x = ptr^` should infer the struct type,
 * not int64_t. Previously, NODE_POSTFIX_EXPR was missing from the codegen
 * inferred-type dispatch, causing all pointer dereference assignments without
 * an explicit type annotation to be emitted as int64_t.
 */

const Vec2 struct {
    x int
    y int
}

const Config struct {
    host string
    port int
    debug bool
}

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: infer struct type from pointer deref
    mut v = Vec2{x: 10, y: 20}
    mut p ^Vec2 = addr(v)
    mut local = p^

    if local.x == 10 {
        println("  [PASS] x field correct after inferred deref assign")
        passed += 1
    } otherwise {
        println("  [FAIL] x: ${local.x}")
        failed += 1
    }

    if local.y == 20 {
        println("  [PASS] y field correct after inferred deref assign")
        passed += 1
    } otherwise {
        println("  [FAIL] y: ${local.y}")
        failed += 1
    }

    // Test 2: infer from pointer to multi-field struct
    mut cfg = Config{host: "localhost", port: 8080, debug: true}
    mut cp ^Config = addr(cfg)
    mut local_cfg = cp^

    if local_cfg.host == "localhost" {
        println("  [PASS] string field correct after inferred deref assign")
        passed += 1
    } otherwise {
        println("  [FAIL] host: ${local_cfg.host}")
        failed += 1
    }

    if local_cfg.port == 8080 {
        println("  [PASS] int field correct after inferred deref assign")
        passed += 1
    } otherwise {
        println("  [FAIL] port: ${local_cfg.port}")
        failed += 1
    }

    if local_cfg.debug {
        println("  [PASS] bool field correct after inferred deref assign")
        passed += 1
    } otherwise {
        println("  [FAIL] debug field wrong")
        failed += 1
    }

    // Test 3: infer from primitive pointer (pre-existing behavior should still work)
    mut n int = 42
    mut np ^int = addr(n)
    mut local_n = np^

    if local_n == 42 {
        println("  [PASS] primitive value correct after inferred deref assign")
        passed += 1
    } otherwise {
        println("  [FAIL] n: ${local_n}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 { println("SOME TESTS FAILED") } otherwise { println("ALL TESTS PASSED") }
}
