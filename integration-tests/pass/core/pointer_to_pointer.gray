/*
 * Tests pointer-to-pointer (^^T) type support
 * Verifies parser handles nested ^ and codegen emits correct C types
 * Regression for #1504
 */

const Point struct {
    x int
    y int
}

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: basic ^^T — pointer to pointer to struct
    mut p = new(Point)
    p^.x = 42
    p^.y = 99

    mut ptr1 ^Point = p
    mut ptr2 ^^Point = addr(ptr1)

    if ptr2^^.x == 42 {
        println("  [PASS] ^^Point deref x == 42")
        passed += 1
    } otherwise {
        println("  [FAIL] ^^Point deref x: expected 42, got ${ptr2^^.x}")
        failed += 1
    }

    if ptr2^^.y == 99 {
        println("  [PASS] ^^Point deref y == 99")
        passed += 1
    } otherwise {
        println("  [FAIL] ^^Point deref y: expected 99, got ${ptr2^^.y}")
        failed += 1
    }

    // Test 2: mutation through ^^T
    ptr2^^.x = 200
    if p^.x == 200 {
        println("  [PASS] mutation through ^^Point reflected in original")
        passed += 1
    } otherwise {
        println("  [FAIL] mutation through ^^Point: expected 200, got ${p^.x}")
        failed += 1
    }

    // Test 3: single deref of ^^T gives ^T
    mut back ^Point = ptr2^
    if back^.y == 99 {
        println("  [PASS] single deref of ^^Point gives valid ^Point")
        passed += 1
    } otherwise {
        println("  [FAIL] single deref of ^^Point: expected y=99, got ${back^.y}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
