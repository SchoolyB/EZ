/*
 * prefix_infix_grouping.ez - Test prefix operator grouping with infix (#1326)
 *
 * Verifies that !(a && b), !(a || b), and negation of infix expressions
 * correctly group the entire infix expression, not just the first operand.
 */

import @std
using std

do main() {
    println("=== Prefix-Infix Grouping Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: !(true && true) should be false
    mut a bool = true
    mut b bool = true
    if !(a && b) {
        println("  [FAIL] !(true && true) should be false")
        failed += 1
    } otherwise {
        println("  [PASS] !(true && true) is false")
        passed += 1
    }

    // Test 2: !(true && false) should be true
    mut c bool = true
    mut d bool = false
    if !(c && d) {
        println("  [PASS] !(true && false) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !(true && false) should be true")
        failed += 1
    }

    // Test 3: !(false || false) should be true
    mut e bool = false
    mut f bool = false
    if !(e || f) {
        println("  [PASS] !(false || false) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !(false || false) should be true")
        failed += 1
    }

    // Test 4: !(true || false) should be false
    mut g bool = true
    mut h bool = false
    if !(g || h) {
        println("  [FAIL] !(true || false) should be false")
        failed += 1
    } otherwise {
        println("  [PASS] !(true || false) is false")
        passed += 1
    }

    // Test 5: !(a && b) where both false - should be true
    mut i bool = false
    mut j bool = false
    if !(i && j) {
        println("  [PASS] !(false && false) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !(false && false) should be true")
        failed += 1
    }

    // Test 6: negation of comparison infix
    mut x int = 5
    mut y int = 10
    if !(x > y) {
        println("  [PASS] !(5 > 10) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !(5 > 10) should be true")
        failed += 1
    }

    // Test 7: negation of equality infix
    if !(x == y) {
        println("  [PASS] !(5 == 10) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !(5 == 10) should be true")
        failed += 1
    }

    // Test 8: double negation of infix
    mut t bool = true
    mut u bool = true
    if !!(t && u) {
        println("  [PASS] !!(true && true) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] !!(true && true) should be true")
        failed += 1
    }

    // Test 9: negation in assignment from infix
    mut result bool = !(true && false)
    if result == true {
        println("  [PASS] mut result = !(true && false) is true")
        passed += 1
    } otherwise {
        println("  [FAIL] mut result = !(true && false) should be true")
        failed += 1
    }

    // Test 10: the exact bug case — !(a && b) must NOT evaluate as (!a && b)
    // If the bug were present: !(true && true) would emit (!true && true) = (false && true) = false ✓ (coincidence)
    // But !(false && true) would emit (!false && true) = (true && true) = true ✗ (wrong!)
    mut p bool = false
    mut q bool = true
    mut bugcheck bool = !(p && q)
    if bugcheck == true {
        println("  [PASS] !(false && true) is true (not misread as !false && true)")
        passed += 1
    } otherwise {
        println("  [FAIL] !(false && true) was misread as (!false && true)")
        failed += 1
    }

    // Test 11: another distinguishing case — !(false || true)
    // Correct: !(false || true) = !(true) = false
    // Bug:     (!false || true) = (true || true) = true  ← WRONG
    mut r bool = false
    mut s bool = true
    mut bugcheck2 bool = !(r || s)
    if bugcheck2 == false {
        println("  [PASS] !(false || true) is false (not misread as !false || true)")
        passed += 1
    } otherwise {
        println("  [FAIL] !(false || true) was misread as (!false || true)")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
