/*
 * print_composite.gray - Test printing composite types (arrays, maps, structs, pointers)
 */


const Point struct {
    x int
    y int
}

const Person struct {
    name string
    age int
}

const Team struct {
    name string
    scores [int]
}

do main() {
    println("=== Print Composite Types Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: println on [int] array
    mut nums [int] = {1, 2, 3}
    println(nums)
    println("  [PASS] println array [int]")
    passed += 1

    // Test 2: println on map[string:int]
    mut ages map[string:int] = {"alice": 30, "bob": 25}
    println(ages)
    println("  [PASS] println map[string:int]")
    passed += 1

    // Test 3: println on struct
    mut p Point = Point{x: 10, y: 20}
    println(p)
    println("  [PASS] println struct")
    passed += 1

    // Test 4: println on pointer (dereferences)
    mut f = new(Point)
    f^.x = 5
    f^.y = 15
    println(f)
    println("  [PASS] println pointer")
    passed += 1

    // Test 5: println on nested [[int]]
    mut matrix [[int]] = {{1, 2}, {3, 4}}
    println(matrix)
    println("  [PASS] println nested array")
    passed += 1

    // Test 6: println on struct with string field
    mut person = Person{name: "Alice", age: 30}
    println(person)
    println("  [PASS] println struct with string field")
    passed += 1

    // Test 7: println on struct with array field
    mut team = Team{name: "Eagles", scores: {90, 85, 92}}
    println(team)
    println("  [PASS] println struct with array field")
    passed += 1

    // Test 8: print (no newline) with array
    mut arr [int] = {10, 20}
    print(arr)
    println("")
    println("  [PASS] print array (no newline)")
    passed += 1

    // Test 9: empty array prints {}
    mut empty [int] = {}
    mut empty_str string = "${empty}"
    if empty_str == "{}" {
        println("  [PASS] empty array prints {}")
        passed += 1
    } otherwise {
        println("  [FAIL] empty array: got '${empty_str}'")
        failed += 1
    }

    // Test 10: empty map prints {:}
    mut empty_map map[string:int] = {:}
    mut map_str string = "${empty_map}"
    if map_str == "{:}" {
        println("  [PASS] empty map prints {:}")
        passed += 1
    } otherwise {
        println("  [FAIL] empty map: got '${map_str}'")
        failed += 1
    }

    // Test 11: zero-initialized empty map prints {:}
    mut zero_map map[int:string]
    mut zero_str string = "${zero_map}"
    if zero_str == "{:}" {
        println("  [PASS] zero-init map prints {:}")
        passed += 1
    } otherwise {
        println("  [FAIL] zero-init map: got '${zero_str}'")
        failed += 1
    }

    // Test 12: println on Error prints message
    mut err Error = error("something broke")
    mut err_str string = "${err}"
    if err_str == "something broke" {
        println("  [PASS] Error prints message")
        passed += 1
    } otherwise {
        println("  [FAIL] Error print: got '${err_str}'")
        failed += 1
    }

    // Test 13: println on nil Error prints nil
    mut ok Error = nil
    mut ok_str string = "${ok}"
    if ok_str == "nil" {
        println("  [PASS] nil Error prints nil")
        passed += 1
    } otherwise {
        println("  [FAIL] nil Error print: got '${ok_str}'")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
