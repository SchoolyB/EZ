/*
 * range_equal_start_end.gray - range(n, n) produces zero iterations (empty sequence)
 */

do main() {
    mut passed int = 0
    mut failed int = 0

    // range(0, 0) — zero iterations
    mut count int = 0
    for i in range(0, 0) {
        count += i + 1
    }
    if count == 0 {
        println("  [PASS] range(0, 0) iterates 0 times")
        passed += 1
    } otherwise {
        println("  [FAIL] range(0, 0): expected 0 iterations, got ${count}")
        failed += 1
    }

    // range(5, 5) — zero iterations
    mut count2 int = 0
    for i in range(5, 5) {
        count2 += i + 1
    }
    if count2 == 0 {
        println("  [PASS] range(5, 5) iterates 0 times")
        passed += 1
    } otherwise {
        println("  [FAIL] range(5, 5): expected 0 iterations, got ${count2}")
        failed += 1
    }

    // range(0, 1) — still one iteration as before
    mut count3 int = 0
    for i in range(0, 1) {
        count3 += i + 1
    }
    if count3 == 1 {
        println("  [PASS] range(0, 1) iterates 1 time")
        passed += 1
    } otherwise {
        println("  [FAIL] range(0, 1): expected 1 iteration, got ${count3}")
        failed += 1
    }

    println("Passed: ${passed}, Failed: ${failed}")
}
