/*
 * recursive_return.gray - Test recursion in return position works correctly
 */


do factorial(n int) -> int {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

do fibonacci(n int) -> int {
    if n <= 0 {
        return 0
    }
    if n == 1 {
        return 1
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

do main() {
    println("=== Recursive Return Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: factorial via return recursion
    mut f int = factorial(10)
    if f == 3628800 {
        println("  [PASS] factorial(10) == 3628800")
        passed += 1
    } otherwise {
        println("  [FAIL] factorial(10) expected 3628800, got ${f}")
        failed += 1
    }

    // Test 2: fibonacci via return recursion
    mut fib int = fibonacci(10)
    if fib == 55 {
        println("  [PASS] fibonacci(10) == 55")
        passed += 1
    } otherwise {
        println("  [FAIL] fibonacci(10) expected 55, got ${fib}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("SOME TESTS FAILED")
    }
}
