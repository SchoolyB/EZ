/*
 * Pass Test: recursive struct with two pointer-to-self fields (binary tree)
 * A struct can have multiple pointer fields referencing its own type.
 */

const Tree struct {
    value int
    left ^Tree
    right ^Tree
}

do main() {
    mut passed int = 0
    mut failed int = 0

    //      10
    //     /  \
    //    5    20
    mut root = new(Tree)
    root.value = 10
    root.left = nil
    root.right = nil

    mut left_node = new(Tree)
    left_node.value = 5
    left_node.left = nil
    left_node.right = nil

    mut right_node = new(Tree)
    right_node.value = 20
    right_node.left = nil
    right_node.right = nil

    root.left = left_node
    root.right = right_node

    // Test 1: root value
    if root.value == 10 {
        println("  [PASS] root value")
        passed += 1
    } otherwise {
        println("  [FAIL] root value: expected 10")
        failed += 1
    }

    // Test 2: left child value
    if root.left^.value == 5 {
        println("  [PASS] left child value")
        passed += 1
    } otherwise {
        println("  [FAIL] left child value: expected 5")
        failed += 1
    }

    // Test 3: right child value
    if root.right^.value == 20 {
        println("  [PASS] right child value")
        passed += 1
    } otherwise {
        println("  [FAIL] right child value: expected 20")
        failed += 1
    }

    // Test 4: leaf nodes have nil children
    if root.left^.left == nil {
        println("  [PASS] left leaf left-child nil")
        passed += 1
    } otherwise {
        println("  [FAIL] left leaf left-child should be nil")
        failed += 1
    }

    if root.right^.right == nil {
        println("  [PASS] right leaf right-child nil")
        passed += 1
    } otherwise {
        println("  [FAIL] right leaf right-child should be nil")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
