/* Test: ref() variable assigned to ^T pointer without auto-deref
 * codegen was auto-dereferencing ref
 * variables when assigning to explicit ^T pointer targets.
 * Expected: all tests pass
 */


const Point struct {
    x int
    y int
}

const Node struct {
    value int
    next ^Node
}

do main() {
    println("=== Ref Assign to Pointer Tests ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: ref to struct assigned to ^T pointer in declaration
    mut pt = Point{x: 5, y: 10}
    mut r1 = ref(pt)
    mut pp ^Point = r1
    if pp^.x == 5 && pp^.y == 10 {
        println("  [PASS] ref to struct pointer declaration")
        passed += 1
    } otherwise {
        println("  [FAIL] ref to struct pointer declaration")
        failed += 1
    }

    // Test 2: modify through pointer reflects in original struct
    pp^.x = 99
    if pt.x == 99 {
        println("  [PASS] modify through pointer updates original struct")
        passed += 1
    } otherwise {
        println("  [FAIL] modify through pointer updates original struct")
        failed += 1
    }

    // Test 3: reassign pointer variable from a different ref
    mut pt2 = Point{x: 42, y: 84}
    mut r2 = ref(pt2)
    pp = r2
    if pp^.x == 42 && pp^.y == 84 {
        println("  [PASS] reassign pointer from different ref")
        passed += 1
    } otherwise {
        println("  [FAIL] reassign pointer from different ref")
        failed += 1
    }

    // Test 4: modify original through reassigned pointer
    pp^.y = 200
    if pt2.y == 200 {
        println("  [PASS] modify through reassigned pointer updates original")
        passed += 1
    } otherwise {
        println("  [FAIL] modify through reassigned pointer updates original")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
