/*
 * Test: returning pointer from function with struct return type
 * Verifies that returning a pointer value when the function signature
 * expects a struct by value works correctly with the typetable guard.
 */

const Point struct {
    x int
    y int
}

do make_point(x int, y int) -> Point {
    mut p = new(Point)
    p.x = x
    p.y = y
    return p^
}

do get_origin() -> Point {
    return Point{x: 0, y: 0}
}

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: return dereferenced pointer as struct value
    mut p = make_point(10, 20)
    if p.x == 10 {
        println("  [PASS] returned struct x == 10")
        passed += 1
    } otherwise {
        println("  [FAIL] returned struct x: expected 10, got ${p.x}")
        failed += 1
    }

    // Test 2: second field correct
    if p.y == 20 {
        println("  [PASS] returned struct y == 20")
        passed += 1
    } otherwise {
        println("  [FAIL] returned struct y: expected 20, got ${p.y}")
        failed += 1
    }

    // Test 3: struct literal return
    mut o = get_origin()
    if o.x == 0 {
        println("  [PASS] struct literal return x == 0")
        passed += 1
    } otherwise {
        println("  [FAIL] struct literal return x: expected 0, got ${o.x}")
        failed += 1
    }

    // Test 4: use returned struct in expression
    mut sum int = p.x + p.y
    if sum == 30 {
        println("  [PASS] returned struct fields in expression == 30")
        passed += 1
    } otherwise {
        println("  [FAIL] returned struct expression: expected 30, got ${sum}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
