/*
 * scope_memory_if_blocks.ez - if/otherwise block scoping + null narrowing
 *
 * Feature #1521 phase 3: per-block arenas for if/otherwise/or chains
 * so temporaries inside conditional blocks are freed on block exit.
 * Values escaping to outer-scope variables are copied via the
 * existing escape machinery. Null-check narrowing allows ?^T deref
 * inside an `if ptr != nil` guard without warnings.
 */

import @strings

const Node struct {
    val int
}

do main() {
    println("=== Scope Memory If Blocks Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- if block: escape to outer variable --
    mut result string = ""
    mut flag bool = true
    if flag {
        mut upper string = strings.to_upper("hello")
        result = upper
    }
    if result == "HELLO" {
        println("  [PASS] if block escape to outer var")
        passed += 1
    } otherwise {
        println("  [FAIL] if block escape: got ${result}")
        failed += 1
    }

    // -- otherwise block: escape --
    mut other string = ""
    if !flag {
        other = "wrong"
    } otherwise {
        mut s string = strings.to_upper("world")
        other = s
    }
    if other == "WORLD" {
        println("  [PASS] otherwise block escape")
        passed += 1
    } otherwise {
        println("  [FAIL] otherwise block escape: got ${other}")
        failed += 1
    }

    // -- or block: escape --
    mut x int = 5
    mut label string = ""
    if x > 10 {
        label = "big"
    } or x > 3 {
        label = strings.to_upper("medium")
    } otherwise {
        label = "small"
    }
    if label == "MEDIUM" {
        println("  [PASS] or block escape")
        passed += 1
    } otherwise {
        println("  [FAIL] or block: got ${label}")
        failed += 1
    }

    // -- null-check narrowing: ?^T deref inside != nil guard --
    mut p ?^Node = new(Node)
    p^.val = 77
    if p != nil {
        if p^.val == 77 {
            println("  [PASS] null-check narrowing (?^T deref)")
            passed += 1
        } otherwise {
            println("  [FAIL] narrowed value wrong")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] p should not be nil")
        failed += 1
    }

    // -- null-check narrowing on == nil path --
    mut q ?^Node = nil
    if q == nil {
        println("  [PASS] null path: q is nil")
        passed += 1
    } otherwise {
        println("  [FAIL] q should be nil")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
