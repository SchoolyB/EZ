/*
 * scope_memory_phase2.gray - Phase 2 scope-based memory management
 *
 * phase 2: per-iteration loop arenas with escape-copy
 * for values that outlive the loop body, non-void function arenas
 * with return-value escape, and nested loop support.
 *
 * Covers the four gaps identified in the phase 1 QA report:
 *   1. Loop body escape to outer array
 *   2. Non-void function temporary cleanup (return survives)
 *   3. Loop body escape to outer map
 *   4. Loop body escape to outer variable
 *   + nested loops with escape
 */

import @strings
import @arrays

do get_first(csv_input string) -> string {
    mut upper string = strings.to_upper(csv_input)
    mut parts [string] = strings.split(upper, ",")
    return parts[0]
}

do main() {
    println("=== Scope Memory Phase 2 Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- loop escape to outer array --
    mut results [string] = {}
    mut names [string] = {"alice", "bob", "charlie"}
    for_each name in names {
        mut upper string = strings.to_upper(name)
        arrays.append(results, upper)
    }
    if len(results) == 3 && results[0] == "ALICE" && results[1] == "BOB" && results[2] == "CHARLIE" {
        println("  [PASS] loop escape to outer array")
        passed += 1
    } otherwise {
        println("  [FAIL] loop escape to outer array")
        failed += 1
    }

    // -- non-void function return survives, temporaries freed --
    mut first string = get_first("hello,world,test")
    if first == "HELLO" {
        println("  [PASS] non-void function return escape")
        passed += 1
    } otherwise {
        println("  [FAIL] non-void return: got ${first}")
        failed += 1
    }

    // -- loop escape to outer map --
    mut m map[string:string] = {:}
    mut keys [string] = {"a", "b", "c"}
    for_each k in keys {
        m[k] = strings.to_upper(k)
    }
    if m["a"] == "A" && m["b"] == "B" && m["c"] == "C" {
        println("  [PASS] loop escape to outer map")
        passed += 1
    } otherwise {
        println("  [FAIL] loop escape to outer map")
        failed += 1
    }

    // -- loop escape to outer variable --
    mut last string = ""
    for_each name in names {
        last = strings.to_upper(name)
    }
    if last == "CHARLIE" {
        println("  [PASS] loop escape to outer variable")
        passed += 1
    } otherwise {
        println("  [FAIL] loop escape: got ${last}")
        failed += 1
    }

    // -- nested loops with escape --
    mut nested_results [string] = {}
    mut rows [[int]] = {{1, 2}, {3, 4}, {5, 6}}
    for_each row in rows {
        for_each val in row {
            mut s string = strings.repeat("x", val)
            arrays.append(nested_results, s)
        }
    }
    if len(nested_results) == 6 && nested_results[0] == "x" && nested_results[5] == "xxxxxx" {
        println("  [PASS] nested loop escape")
        passed += 1
    } otherwise {
        println("  [FAIL] nested loop: len=${len(nested_results)}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
