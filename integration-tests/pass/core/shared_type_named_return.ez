/* Test: Named return values sharing a type
 * Expected: passes with output "John" and "Doe"
 */


do getNames() -> (first, last string) {
    mut first string = "John"
    mut last string = "Doe"
    return first, last
}

do main() {
    mut f string, l string = getNames()
    println(f)
    println(l)
    println("ALL TESTS PASSED")
}
