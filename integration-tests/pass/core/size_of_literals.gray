/*
 * size_of_literals.gray - Test size_of on literal expressions
 *
 * Covers: size_of applied to int, float, bool, string, char literals.
 * size_of should return the C sizeof of the underlying type.
 */

do main() {
    println("=== size_of Literals Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: size_of on int literal → 8 (int64_t)
    if size_of(42) == 8 {
        println("  [PASS] size_of(42) == 8")
        passed += 1
    } otherwise {
        println("  [FAIL] size_of(42) == ${size_of(42)}")
        failed += 1
    }

    // Test 2: size_of on float literal → 8 (double)
    if size_of(3.14) == 8 {
        println("  [PASS] size_of(3.14) == 8")
        passed += 1
    } otherwise {
        println("  [FAIL] size_of(3.14) == ${size_of(3.14)}")
        failed += 1
    }

    // Test 3: size_of on bool literal → 1 (bool/_Bool)
    if size_of(true) == 1 {
        println("  [PASS] size_of(true) == 1")
        passed += 1
    } otherwise {
        println("  [FAIL] size_of(true) == ${size_of(true)}")
        failed += 1
    }

    // Test 4: size_of on false literal → 1
    if size_of(false) == 1 {
        println("  [PASS] size_of(false) == 1")
        passed += 1
    } otherwise {
        println("  [FAIL] size_of(false) == ${size_of(false)}")
        failed += 1
    }

    // Test 5: size_of on negative int literal → 8
    if size_of(-100) == 8 {
        println("  [PASS] size_of(-100) == 8")
        passed += 1
    } otherwise {
        println("  [FAIL] size_of(-100) == ${size_of(-100)}")
        failed += 1
    }

    // Test 6: size_of on zero → 8
    if size_of(0) == 8 {
        println("  [PASS] size_of(0) == 8")
        passed += 1
    } otherwise {
        println("  [FAIL] size_of(0) == ${size_of(0)}")
        failed += 1
    }

    // Test 7: size_of on type names still works
    if size_of(int) == 8 && size_of(float) == 8 && size_of(bool) == 1 {
        println("  [PASS] size_of(type) still works")
        passed += 1
    } otherwise {
        println("  [FAIL] size_of(type) broken")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
