/*
 * Test: sized-type compound assignment correctness
 * Verifies that +=, -=, *= on sized types produce correct results.
 */

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: i32 +=
    mut a i32 = cast(10, i32)
    a += cast(5, i32)
    if cast(a, int) == 15 {
        println("  [PASS] i32 += produces 15")
        passed += 1
    } otherwise {
        println("  [FAIL] i32 +=: expected 15, got ${cast(a, int)}")
        failed += 1
    }

    // Test 2: u16 -=
    mut b u16 = cast(100, u16)
    b -= cast(30, u16)
    if cast(b, int) == 70 {
        println("  [PASS] u16 -= produces 70")
        passed += 1
    } otherwise {
        println("  [FAIL] u16 -=: expected 70, got ${cast(b, int)}")
        failed += 1
    }

    // Test 3: i16 *=
    mut c i16 = cast(7, i16)
    c *= cast(3, i16)
    if cast(c, int) == 21 {
        println("  [PASS] i16 *= produces 21")
        passed += 1
    } otherwise {
        println("  [FAIL] i16 *=: expected 21, got ${cast(c, int)}")
        failed += 1
    }

    // Test 4: u8 +=
    mut d u8 = cast(200, u8)
    d += cast(55, u8)
    if cast(d, int) == 255 {
        println("  [PASS] u8 += produces 255")
        passed += 1
    } otherwise {
        println("  [FAIL] u8 +=: expected 255, got ${cast(d, int)}")
        failed += 1
    }

    // Test 5: i64 -=
    mut e i64 = cast(1000, i64)
    e -= cast(1, i64)
    if cast(e, int) == 999 {
        println("  [PASS] i64 -= produces 999")
        passed += 1
    } otherwise {
        println("  [FAIL] i64 -=: expected 999, got ${cast(e, int)}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
