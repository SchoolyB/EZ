/*
 * string_enum_support.ez - Test string enum support (#1801)
 *
 * Covers: string enum in arrays, when/is blocks, comparison between
 * two enum values, comparison with string literals, assignment to
 * string variables, and string interpolation.
 */

const Status enum {
    PENDING   = "pending"
    ACTIVE    = "active"
    INACTIVE  = "inactive"
    DONE      = "done"
}

const Priority enum {
    LOW    = "low"
    MEDIUM = "medium"
    HIGH   = "high"
}

do get_status() -> string {
    return Status.ACTIVE
}

do describe(s string) -> string {
    when s {
        is Status.PENDING  { return "waiting" }
        is Status.ACTIVE   { return "running" }
        is Status.INACTIVE { return "paused" }
        default            { return "finished" }
    }
}

do main() {
    println("=== String Enum Support Test (#1801) ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: string enum comparison with string literal
    if Status.PENDING == "pending" {
        println("  [PASS] Status.PENDING == \"pending\"")
        passed += 1
    } otherwise {
        println("  [FAIL] Status.PENDING comparison with string literal")
        failed += 1
    }

    // Test 2: string enum != string literal
    if Status.ACTIVE != "pending" {
        println("  [PASS] Status.ACTIVE != \"pending\"")
        passed += 1
    } otherwise {
        println("  [FAIL] Status.ACTIVE != \"pending\" should be true")
        failed += 1
    }

    // Test 3: assign string enum to string variable
    mut current string = Status.ACTIVE
    if current == "active" {
        println("  [PASS] assigned string enum to string variable")
        passed += 1
    } otherwise {
        println("  [FAIL] string enum assignment: got ${current}")
        failed += 1
    }

    // Test 4: string enum in array
    mut statuses [Status] = {Status.PENDING, Status.ACTIVE, Status.DONE}
    if statuses[0] == "pending" && statuses[1] == "active" && statuses[2] == "done" {
        println("  [PASS] string enum array access")
        passed += 1
    } otherwise {
        println("  [FAIL] string enum array: [0]=${statuses[0]}, [1]=${statuses[1]}, [2]=${statuses[2]}")
        failed += 1
    }

    // Test 5: string enum in when/is
    mut result string = describe("active")
    if result == "running" {
        println("  [PASS] string enum in when/is")
        passed += 1
    } otherwise {
        println("  [FAIL] string enum when/is: got ${result}")
        failed += 1
    }

    // Test 6: when/is with non-matching value falls to default
    mut result2 string = describe("done")
    if result2 == "finished" {
        println("  [PASS] when/is default branch with string enum")
        passed += 1
    } otherwise {
        println("  [FAIL] when/is default: got ${result2}")
        failed += 1
    }

    // Test 7: return string enum from function
    mut s string = get_status()
    if s == "active" {
        println("  [PASS] string enum returned from function")
        passed += 1
    } otherwise {
        println("  [FAIL] returned string enum: got ${s}")
        failed += 1
    }

    // Test 8: string enum in string interpolation
    mut msg string = "status is ${Status.DONE}"
    if msg == "status is done" {
        println("  [PASS] string enum in string interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] interpolation: got ${msg}")
        failed += 1
    }

    // Test 9: multiple string enums, compare values
    mut p string = Priority.HIGH
    if p == "high" && Priority.LOW == "low" && Priority.MEDIUM == "medium" {
        println("  [PASS] multiple string enum values")
        passed += 1
    } otherwise {
        println("  [FAIL] multiple string enum values")
        failed += 1
    }

    // Test 10: string enum array element update
    statuses[0] = Status.DONE
    if statuses[0] == "done" {
        println("  [PASS] string enum array element update")
        passed += 1
    } otherwise {
        println("  [FAIL] string enum array update: ${statuses[0]}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
