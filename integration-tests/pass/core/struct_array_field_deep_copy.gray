/*
 * struct_array_field_deep_copy.gray
 * array fields read from a struct were not
 * deep-copied on assignment — the new variable shared backing storage with
 * the original struct field. Mutating the copy corrupted the original.
 * Covers primitive element types and struct element types.
 */

const Container struct {
    values [int]
    tags [string]
}

const Enemy struct {
    name string
    hp int
}

const Level struct {
    enemies [Enemy]
}

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: primitive [int] field — copy must be independent
    mut c Container
    c.values = {10, 20, 30}

    mut copy1 [int] = c.values
    copy1[0] = 999

    mut copy2 [int] = c.values
    if copy2[0] == 10 {
        println("  [PASS] [int] field: second copy unaffected by first copy mutation")
        passed += 1
    } otherwise {
        println("  [FAIL] [int] field: copy2[0]=${copy2[0]}, expected 10")
        failed += 1
    }

    // Test 2: original struct field unaffected by copy mutations
    if c.values[0] == 10 {
        println("  [PASS] [int] field: original struct field unaffected")
        passed += 1
    } otherwise {
        println("  [FAIL] [int] field: c.values[0]=${c.values[0]}, expected 10")
        failed += 1
    }

    // Test 3: [string] field — copy must be independent
    c.tags = {"alpha", "beta", "gamma"}
    mut tcopy1 [string] = c.tags
    tcopy1[0] = "MUTATED"

    mut tcopy2 [string] = c.tags
    if tcopy2[0] == "alpha" {
        println("  [PASS] [string] field: second copy unaffected by first copy mutation")
        passed += 1
    } otherwise {
        println("  [FAIL] [string] field: tcopy2[0]=${tcopy2[0]}, expected alpha")
        failed += 1
    }

    // Test 4: [StructType] field — copy must be independent
    mut lvl Level
    lvl.enemies = {Enemy{name: "goblin", hp: 100}, Enemy{name: "orc", hp: 200}}

    mut ecopy1 [Enemy] = lvl.enemies
    ecopy1[0].hp = 1

    mut ecopy2 [Enemy] = lvl.enemies
    if ecopy2[0].hp == 100 {
        println("  [PASS] [struct] field: second copy unaffected by first copy mutation")
        passed += 1
    } otherwise {
        println("  [FAIL] [struct] field: ecopy2[0].hp=${ecopy2[0].hp}, expected 100")
        failed += 1
    }

    // Test 5: original struct enemy field unaffected
    if lvl.enemies[0].hp == 100 {
        println("  [PASS] [struct] field: original struct field unaffected")
        passed += 1
    } otherwise {
        println("  [FAIL] [struct] field: lvl.enemies[0].hp=${lvl.enemies[0].hp}, expected 100")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 { println("SOME TESTS FAILED") } otherwise { println("ALL TESTS PASSED") }
}
