/*
 * struct_func_field.ez - Struct fields of type 'func' are visible
 * as data fields and callable through the field access.
 *
 * Regression for #1505 (bug reported during hunt):
 *   - `op.callback(3, 4)` fired E3042 ("must be called on the type")
 *   - `op.callback = ()sub` fired E3010 ("no field 'callback'")
 *   Both are now fixed: func-typed data fields are distinguished from
 *   struct functions (declared with `do`) and accessible via normal
 *   field syntax.
 */

do add(a int, b int) -> int { return a + b }
do sub(a int, b int) -> int { return a - b }
do mul(a int, b int) -> int { return a * b }

const Op struct {
    name string
    callback func
}

do main() {
    println("=== Struct func Field Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- call through func field --
    mut op Op = Op{name: "add", callback: ()add}
    if op.callback(3, 4) == 7 {
        println("  [PASS] op.callback(3, 4) = 7")
        passed += 1
    } otherwise {
        println("  [FAIL] op.callback(3, 4)")
        failed += 1
    }

    // -- reassign func field --
    op.callback = ()sub
    op.name = "sub"
    if op.callback(10, 3) == 7 {
        println("  [PASS] op.callback = ()sub, then call")
        passed += 1
    } otherwise {
        println("  [FAIL] reassigned callback")
        failed += 1
    }

    // -- read func field into a local, then call --
    mut f func = op.callback
    if f(20, 5) == 15 {
        println("  [PASS] mut f = op.callback; f(20, 5) = 15")
        passed += 1
    } otherwise {
        println("  [FAIL] f(20, 5)")
        failed += 1
    }

    // -- second struct instance with different callback --
    mut op2 Op = Op{name: "mul", callback: ()mul}
    if op2.callback(6, 7) == 42 {
        println("  [PASS] op2.callback(6, 7) = 42")
        passed += 1
    } otherwise {
        println("  [FAIL] op2.callback(6, 7)")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
