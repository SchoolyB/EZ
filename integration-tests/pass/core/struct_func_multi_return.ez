const Counter struct {
    value int

    do bounds(c Counter) -> (int, int) {
        return 0, c.value
    }

    do split(c Counter) -> (int, int, int) {
        return 0, c.value / 2, c.value
    }
}

const Range struct {
    lo int
    hi int

    do endpoints(r Range) -> (int, int) {
        return r.lo, r.hi
    }
}

do main() {
    mut passed int = 0
    mut failed int = 0

    mut c Counter = Counter{value: 10}

    // Test 1: two-value return via instance dispatch
    mut low, high = c.bounds()
    if low == 0 && high == 10 {
        println("  [PASS] struct func two-value return")
        passed += 1
    } otherwise {
        println("  [FAIL] struct func two-value return: expected 0, 10")
        failed += 1
    }

    // Test 2: two-value return via type-qualified call
    mut lo2, hi2 = Counter.bounds(c)
    if lo2 == 0 && hi2 == 10 {
        println("  [PASS] struct func two-value return (qualified)")
        passed += 1
    } otherwise {
        println("  [FAIL] struct func two-value return (qualified): expected 0, 10")
        failed += 1
    }

    // Test 3: three-value return
    mut a, b, d = c.split()
    if a == 0 && b == 5 && d == 10 {
        println("  [PASS] struct func three-value return")
        passed += 1
    } otherwise {
        println("  [FAIL] struct func three-value return: expected 0, 5, 10")
        failed += 1
    }

    // Test 4: multi-return on a different struct
    mut r Range = Range{lo: 3, hi: 7}
    mut rlo, rhi = r.endpoints()
    if rlo == 3 && rhi == 7 {
        println("  [PASS] second struct func multi-return")
        passed += 1
    } otherwise {
        println("  [FAIL] second struct func multi-return: expected 3, 7")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
