/*
 * struct_func_private_access.ez - Private struct functions are callable
 * from within the same struct but not from outside.
 *
 * Regression for #1599: private modifier was not enforced.
 */

const Calculator struct {
    value int

    private do internal_add(a int, b int) -> int {
        return a + b
    }

    private do internal_mul(a int, b int) -> int {
        return a * b
    }

    do add(a int, b int) -> int {
        return Calculator.internal_add(a, b)
    }

    do mul(a int, b int) -> int {
        return Calculator.internal_mul(a, b)
    }

    do combined(a int, b int) -> int {
        mut sum int = Calculator.internal_add(a, b)
        mut product int = Calculator.internal_mul(a, b)
        return Calculator.internal_add(sum, product)
    }
}

do main() {
    println("=== Private Struct Function Access Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: public function calls private internally
    mut r1 int = Calculator.add(3, 4)
    if r1 == 7 {
        println("  [PASS] Calculator.add(3, 4) = 7")
        passed += 1
    } otherwise {
        println("  [FAIL] Calculator.add(3, 4): expected 7, got ${r1}")
        failed += 1
    }

    // Test 2: public function calls different private internally
    mut r2 int = Calculator.mul(5, 6)
    if r2 == 30 {
        println("  [PASS] Calculator.mul(5, 6) = 30")
        passed += 1
    } otherwise {
        println("  [FAIL] Calculator.mul(5, 6): expected 30, got ${r2}")
        failed += 1
    }

    // Test 3: public function chains multiple private calls
    mut r3 int = Calculator.combined(2, 3)
    if r3 == 11 {
        println("  [PASS] Calculator.combined(2, 3) = 11")
        passed += 1
    } otherwise {
        println("  [FAIL] Calculator.combined(2, 3): expected 11, got ${r3}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
