/*
 * struct_functions.ez - Test struct-namespaced free functions
 *
 * Tests:
 *   - Functions declared inside struct blocks
 *   - Called as Type.func_name(args)
 *   - Private struct functions
 *   - No self/this — all parameters explicit
 */

import @math

const Point struct {
    x int
    y int

    do create(x int, y int) -> Point {
        return Point{x: x, y: y}
    }

    do distance(a Point, b Point) -> float {
        return math.sqrt(math.pow(float(a.x - b.x), 2) + math.pow(float(a.y - b.y), 2))
    }

    do origin() -> Point {
        return Point{x: 0, y: 0}
    }

    private do validate(p Point) -> bool {
        return p.x >= 0 && p.y >= 0
    }

    do is_valid(x int, y int) -> bool {
        mut p = Point.create(x, y)
        return Point.validate(p)
    }
}

const Counter struct {
    value int

    do zero() -> Counter {
        return Counter{value: 0}
    }

    do increment(c Counter) -> Counter {
        return Counter{value: c.value + 1}
    }
}

do main() {
    println("=== Struct-Namespaced Functions Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: Basic struct function call
    mut p1 = Point.create(3, 4)
    if p1.x == 3 && p1.y == 4 {
        println("  [PASS] Point.create(3, 4)")
        passed++
    } otherwise {
        println("  [FAIL] Point.create(3, 4)")
        failed++
    }

    // Test 2: Struct function with two struct params
    mut p2 = Point.create(0, 0)
    mut d = Point.distance(p1, p2)
    if d == 5.0 {
        println("  [PASS] Point.distance = 5.0")
        passed++
    } otherwise {
        println("  [FAIL] Point.distance = ${d}, expected 5.0")
        failed++
    }

    // Test 3: Zero-arg struct function
    mut o = Point.origin()
    if o.x == 0 && o.y == 0 {
        println("  [PASS] Point.origin()")
        passed++
    } otherwise {
        println("  [FAIL] Point.origin()")
        failed++
    }

    // Test 4: Public function calling private function
    if Point.is_valid(5, 10) {
        println("  [PASS] Point.is_valid(5, 10) = true")
        passed++
    } otherwise {
        println("  [FAIL] Point.is_valid(5, 10) should be true")
        failed++
    }

    if !Point.is_valid(-1, 5) {
        println("  [PASS] Point.is_valid(-1, 5) = false")
        passed++
    } otherwise {
        println("  [FAIL] Point.is_valid(-1, 5) should be false")
        failed++
    }

    // Test 5: Different struct with namespaced functions
    mut c = Counter.zero()
    c = Counter.increment(c)
    c = Counter.increment(c)
    if c.value == 2 {
        println("  [PASS] Counter.new() + 2x increment = 2")
        passed++
    } otherwise {
        println("  [FAIL] Counter value = ${c.value}, expected 2")
        failed++
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed == 0 {
        println("ALL TESTS PASSED")
    } otherwise {
        println("SOME TESTS FAILED")
    }
}
