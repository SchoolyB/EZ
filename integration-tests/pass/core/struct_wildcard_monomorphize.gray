const Box struct {
    value int

    do identity(val ?) -> ? {
        return val
    }

    do wrap(self Box, val ?) -> ? {
        return val
    }
}

const Pair struct {
    first int
    second int

    do pick(index int, a ?, b ?) -> ? {
        if index == 0 {
            return a
        }
        return b
    }
}

do main() {
    mut b = Box { value: 10 }

    // Type-qualified wildcard calls with different concrete types
    mut r1 int = Box.identity(42)
    mut r2 string = Box.identity("hello")
    mut r3 bool = Box.identity(true)
    mut r4 float = Box.identity(3.14)

    // Instance dispatch wildcard calls
    mut r5 int = b.wrap(99)
    mut r6 string = b.wrap("world")

    // Second struct with wildcard
    mut r7 int = Pair.pick(0, 10, 20)
    mut r8 string = Pair.pick(1, "left", "right")

    println(r1)
    println(r2)
    println(r3)
    println(r4)
    println(r5)
    println(r6)
    println(r7)
    println(r8)
    println("ALL TESTS PASSED")
}
