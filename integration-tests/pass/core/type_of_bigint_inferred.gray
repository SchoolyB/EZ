/*
 * type_of_bigint_inferred.gray - Test type_of on inferred wide integer variables
 *
 * Covers: type_of on variables declared with inferred types (mut a = i128(42))
 * should return the specific wide integer type name, not "int".
 */

do main() {
    println("=== type_of Inferred Wide Integer Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: inferred i128 type_of
    mut a = i128(42)
    if type_of(a) == "i128" {
        println("  [PASS] type_of inferred i128 == \"i128\"")
        passed += 1
    } otherwise {
        println("  [FAIL] type_of inferred i128: got \"${type_of(a)}\"")
        failed += 1
    }

    // Test 2: inferred u128 type_of
    mut b = u128(100)
    if type_of(b) == "u128" {
        println("  [PASS] type_of inferred u128 == \"u128\"")
        passed += 1
    } otherwise {
        println("  [FAIL] type_of inferred u128: got \"${type_of(b)}\"")
        failed += 1
    }

    // Test 3: inferred i256 type_of
    mut c = i256(999)
    if type_of(c) == "i256" {
        println("  [PASS] type_of inferred i256 == \"i256\"")
        passed += 1
    } otherwise {
        println("  [FAIL] type_of inferred i256: got \"${type_of(c)}\"")
        failed += 1
    }

    // Test 4: inferred u256 type_of
    mut d = u256(555)
    if type_of(d) == "u256" {
        println("  [PASS] type_of inferred u256 == \"u256\"")
        passed += 1
    } otherwise {
        println("  [FAIL] type_of inferred u256: got \"${type_of(d)}\"")
        failed += 1
    }

    // Test 5: inferred i128 from arithmetic
    mut e = i128(10) + i128(5)
    if type_of(e) == "i128" {
        println("  [PASS] type_of inferred i128 from arithmetic")
        passed += 1
    } otherwise {
        println("  [FAIL] type_of inferred i128 from arithmetic: got \"${type_of(e)}\"")
        failed += 1
    }

    // Test 6: explicitly declared i128 type_of (regression check)
    mut f i128 = i128(7)
    if type_of(f) == "i128" {
        println("  [PASS] type_of explicitly declared i128")
        passed += 1
    } otherwise {
        println("  [FAIL] type_of explicitly declared i128: got \"${type_of(f)}\"")
        failed += 1
    }

    // Test 7: type_of non-bigint inferred variable still works
    mut g = 42
    if type_of(g) == "int" {
        println("  [PASS] type_of inferred int still \"int\"")
        passed += 1
    } otherwise {
        println("  [FAIL] type_of inferred int: got \"${type_of(g)}\"")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
