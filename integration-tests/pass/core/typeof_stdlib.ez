/*
 * Test: type_of() for stdlib return types
 * Tests that stdlib functions return correct EZ type names
 */

import @random
import @strings
import @maps


do main() {
    // Test random module types
    mut rf float = random.rand_float()
    assert(type_of(rf) == "float", "random.rand_float() should return 'float'")

    mut ri int = random.rand_int(100)
    assert(type_of(ri) == "int", "random.rand_int() should return 'int'")

    mut rb bool = random.rand_bool()
    assert(type_of(rb) == "bool", "random.rand_bool() should return 'bool'")

    mut rc byte = random.rand_byte()
    assert(type_of(rc) == "byte", "random.rand_byte() should return 'byte'")

    mut rchar char = random.rand_char()
    assert(type_of(rchar) == "char", "random.rand_char() should return 'char'")

    // Test random array functions preserve element types
    mut arr [int] = {1, 2, 3, 4, 5}
    mut shuffled = random.shuffle(arr)
    assert(type_of(shuffled) == "[int]", "random.shuffle() should preserve '[int]' type")

    mut sampled = random.sample(arr, 2)
    assert(type_of(sampled) == "[int]", "random.sample() should preserve '[int]' type")

    mut choice = random.choice(arr)
    assert(type_of(choice) == "int", "random.choice() should return element type 'int'")

    // Test with string array
    mut strArr [string] = {"a", "b", "c"}
    mut strShuffled = random.shuffle(strArr)
    assert(type_of(strShuffled) == "[string]", "random.shuffle() should preserve '[string]' type")

    // Test Range type
    mut r = range(0, 10)
    assert(type_of(r) == "Range<int>", "range() should return 'Range<int>'")

    // Test string array from split
    mut parts = strings.split("a,b,c", ",")
    assert(type_of(parts) == "[string]", "strings.split() should return '[string]'")

    // Test map types
    mut m map[string:int] = {"a": 1, "b": 2}
    mut keys = maps.keys(m)
    assert(type_of(keys) == "[string]", "maps.keys() should return '[string]'")

    mut values = maps.values(m)
    assert(type_of(values) == "[int]", "maps.values() should return '[int]'")

    // Test with different map types
    mut m2 map[int:string] = {1: "one", 2: "two"}
    mut keys2 = maps.keys(m2)
    assert(type_of(keys2) == "[int]", "maps.keys() should return '[int]' for int keys")

    mut values2 = maps.values(m2)
    assert(type_of(values2) == "[string]", "maps.values() should return '[string]' for string values")

    println("PASS: type_of_stdlib")
}
