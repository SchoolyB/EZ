/*
 * using_new_stdlib.ez - Test new stdlib functions via 'using' directive
 *
 * Verifies that recently added functions (regex.is_valid, math float
 * variants) work through 'using' without module prefix.
 */

import @std
import @math
import @regex
using std, math, regex

do main() {
    println("=== Using Directive with New Stdlib Functions ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: regex.is_valid with module prefix (using doesn't dispatch is_valid yet)
    if regex.is_valid("[0-9]+") {
        println("  [PASS] regex.is_valid('[0-9]+') with using import")
        passed += 1
    } otherwise {
        println("  [FAIL] regex.is_valid")
        failed += 1
    }

    // Test 2: !regex.is_valid with module prefix
    if !regex.is_valid("[unclosed") {
        println("  [PASS] !regex.is_valid('[unclosed') with using import")
        passed += 1
    } otherwise {
        println("  [FAIL] !regex.is_valid")
        failed += 1
    }

    // Test 3: abs(float) via using
    mut a float = abs(-3.14)
    if a > 3.13 && a < 3.15 {
        println("  [PASS] abs(-3.14) returns float via using")
        passed += 1
    } otherwise {
        println("  [FAIL] abs float via using: got ${a}")
        failed += 1
    }

    // Test 4: min(float) via using
    mut b float = min(1.5, 2.7)
    if b > 1.49 && b < 1.51 {
        println("  [PASS] min(1.5, 2.7) returns float via using")
        passed += 1
    } otherwise {
        println("  [FAIL] min float via using: got ${b}")
        failed += 1
    }

    // Test 5: max(float) via using
    mut c float = max(1.5, 2.7)
    if c > 2.69 && c < 2.71 {
        println("  [PASS] max(1.5, 2.7) returns float via using")
        passed += 1
    } otherwise {
        println("  [FAIL] max float via using: got ${c}")
        failed += 1
    }

    // Test 6: clamp(float) via using
    mut d float = clamp(5.5, 0.0, 3.0)
    if d > 2.99 && d < 3.01 {
        println("  [PASS] clamp(5.5, 0.0, 3.0) returns float via using")
        passed += 1
    } otherwise {
        println("  [FAIL] clamp float via using: got ${d}")
        failed += 1
    }

    // Test 7: is_match via using (existing, regression check)
    if is_match("^hello", "hello world") {
        println("  [PASS] is_match via using")
        passed += 1
    } otherwise {
        println("  [FAIL] is_match via using")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
