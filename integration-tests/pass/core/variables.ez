/*
 * variables.ez - Test variable declarations (var, const, mut)
 */

import @std
using std

const TestResult struct {
    passed int
    failed int
}

do main() {
    println("=== Variables Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: mut - mutable variable
    mut counter int = 0
    counter = 1
    if counter == 1 {
        println("  [PASS] mut variable assignment")
        passed += 1
    } otherwise {
        println("  [FAIL] mut variable assignment: expected 1, got ${counter}")
        failed += 1
    }

    // Test 2: const - immutable constant
    const PI float = 3.14159
    if PI > 3.14 && PI < 3.15 {
        println("  [PASS] const declaration")
        passed += 1
    } otherwise {
        println("  [FAIL] const declaration: unexpected value ${PI}")
        failed += 1
    }

    // Test 3: mut reassignment
    mut local_val int = 42
    local_val = 43
    if local_val == 43 {
        println("  [PASS] mut reassignment")
        passed += 1
    } otherwise {
        println("  [FAIL] mut reassignment: expected 43, got ${local_val}")
        failed += 1
    }

    // Test 4: mut with different types
    mut str_var string = "hello"
    str_var = "world"
    if str_var == "world" {
        println("  [PASS] mut string reassignment")
        passed += 1
    } otherwise {
        println("  [FAIL] mut string reassignment: expected 'world', got '${str_var}'")
        failed += 1
    }

    // Test 5: mut bool
    mut flag bool = true
    flag = false
    if flag == false {
        println("  [PASS] mut bool reassignment")
        passed += 1
    } otherwise {
        println("  [FAIL] mut bool reassignment: expected false, got ${flag}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
