/*
 * when_is_branch_scope.gray - Each is/default branch has its own scope
 *
 * when/is branches shared a single scope,
 * causing false E4003 when the same variable name was declared in
 * multiple mutually exclusive branches.
 */

do classify(x int) -> (result string) {
    mut result string = ""
    when x {
        is 1 {
            mut msg string = "one"
            result = msg
        }
        is 2 {
            mut msg string = "two"
            result = msg
        }
        is 3 {
            mut msg string = "three"
            result = msg
        }
        default {
            mut msg string = "other"
            result = msg
        }
    }
    return result
}

do main() {
    println("=== When/Is Branch Scope Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: first branch
    if classify(1) == "one" {
        println("  [PASS] is 1 -> one")
        passed += 1
    } otherwise {
        println("  [FAIL] is 1")
        failed += 1
    }

    // Test 2: second branch (same var name, different scope)
    if classify(2) == "two" {
        println("  [PASS] is 2 -> two")
        passed += 1
    } otherwise {
        println("  [FAIL] is 2")
        failed += 1
    }

    // Test 3: third branch
    if classify(3) == "three" {
        println("  [PASS] is 3 -> three")
        passed += 1
    } otherwise {
        println("  [FAIL] is 3")
        failed += 1
    }

    // Test 4: default branch
    if classify(99) == "other" {
        println("  [PASS] default -> other")
        passed += 1
    } otherwise {
        println("  [FAIL] default")
        failed += 1
    }

    // Test 5: variable from is branch doesn't leak to outer scope
    mut x int = 5
    when x {
        is 5 {
            mut inner int = 100
        }
    }
    // 'inner' should not be accessible here — verified by the fact
    // that this compiles without using 'inner' outside the branch

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
