/*
 * when_range_negative_step.ez - Test when/is with negative step ranges
 */

import @std
using std

do main() {
    println("=== When Range Negative Step Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: Match even numbers counting down from 10
    mut x int = 8
    mut matched bool = false
    when x {
        is range(10, 0, -2) {
            matched = true
        }
        default {
            matched = false
        }
    }
    if matched {
        println("  [PASS] 8 matches range(10, 0, -2)")
        passed += 1
    } otherwise {
        println("  [FAIL] 8 should match range(10, 0, -2)")
        failed += 1
    }

    // Test 2: Non-matching value
    mut y int = 7
    mut matched2 bool = false
    when y {
        is range(10, 0, -2) {
            matched2 = true
        }
        default {
            matched2 = false
        }
    }
    if matched2 == false {
        println("  [PASS] 7 does not match range(10, 0, -2)")
        passed += 1
    } otherwise {
        println("  [FAIL] 7 should not match range(10, 0, -2)")
        failed += 1
    }

    // Test 3: Match counting down by 1
    mut z int = 3
    mut matched3 bool = false
    when z {
        is range(5, 0, -1) {
            matched3 = true
        }
        default {
            matched3 = false
        }
    }
    if matched3 {
        println("  [PASS] 3 matches range(5, 0, -1)")
        passed += 1
    } otherwise {
        println("  [FAIL] 3 should match range(5, 0, -1)")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("SOME TESTS FAILED")
    }
}
