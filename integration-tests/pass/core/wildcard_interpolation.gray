/*
 * wildcard_interpolation.gray - Wildcard (?) params in string interpolation
 *
 * when a wildcard-typed parameter was used inside
 * "${x}", codegen defaulted to TK_INT and emitted (long long)(x), causing
 * C compiler errors for non-integer types like string, float, bool.
 */

do show_int(x ?) -> string {
    return "value=${x}"
}

do show_float(x ?) -> string {
    return "value=${x}"
}

do show_string(x ?) -> string {
    return "value=${x}"
}

do show_bool(x ?) -> string {
    return "value=${x}"
}

do describe(x ?) -> string {
    return "item=${x}"
}

do main() {
    println("=== Wildcard Interpolation Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: int wildcard in interpolation
    mut r1 string = show_int(42)
    if r1 == "value=42" {
        println("  [PASS] wildcard int interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] wildcard int: got '${r1}'")
        failed += 1
    }

    // Test 2: float wildcard in interpolation
    mut r2 string = show_float(3.14)
    if r2 == "value=3.140000" || r2 == "value=3.14" {
        println("  [PASS] wildcard float interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] wildcard float: got '${r2}'")
        failed += 1
    }

    // Test 3: string wildcard in interpolation
    mut r3 string = show_string("hello")
    if r3 == "value=hello" {
        println("  [PASS] wildcard string interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] wildcard string: got '${r3}'")
        failed += 1
    }

    // Test 4: bool wildcard in interpolation
    mut r4 string = show_bool(true)
    if r4 == "value=true" {
        println("  [PASS] wildcard bool interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] wildcard bool: got '${r4}'")
        failed += 1
    }

    // Test 5: same generic fn reused with int then string
    mut r5a string = describe(99)
    mut r5b string = describe("abc")
    if r5a == "item=99" && r5b == "item=abc" {
        println("  [PASS] same generic fn, different concrete types")
        passed += 1
    } otherwise {
        println("  [FAIL] describe: got '${r5a}' and '${r5b}'")
        failed += 1
    }

    // Test 6: wildcard bool false interpolation
    mut r6 string = show_bool(false)
    if r6 == "value=false" {
        println("  [PASS] wildcard bool false interpolation")
        passed += 1
    } otherwise {
        println("  [FAIL] wildcard bool false: got '${r6}'")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
