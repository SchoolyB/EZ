/*
 * wildcard_multi_return.gray - Wildcard functions with named returns.
 *
 * the monomorphiser
 * applied the binding suffix to the GrayMulti struct name, producing
 * GrayMulti_pair__int which didn't exist. multi_base_name() now strips
 * the suffix so all instantiations share the one-time typedef.
 */

do pair(a ?, b ?) -> (first int, second int) {
    mut first int = a
    mut second int = b
    return first, second
}

do main() {
    println("=== Wildcard Multi-Return Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- same-type wildcard, both int --
    mut x int, y int = pair(42, 100)
    if x == 42 && y == 100 {
        println("  [PASS] pair(42, 100) = (42, 100)")
        passed += 1
    } otherwise {
        println("  [FAIL] pair(42, 100): got (${x}, ${y})")
        failed += 1
    }

    // -- reuse with different values, same binding --
    mut a int, b int = pair(1, 2)
    if a == 1 && b == 2 {
        println("  [PASS] pair(1, 2) = (1, 2)")
        passed += 1
    } otherwise {
        println("  [FAIL] pair(1, 2): got (${a}, ${b})")
        failed += 1
    }

    // -- non-regression: plain multi-return still works --
    mut q int, r int = divmod(17, 5)
    if q == 3 && r == 2 {
        println("  [PASS] divmod(17, 5) = (3, 2)")
        passed += 1
    } otherwise {
        println("  [FAIL] divmod(17, 5): got (${q}, ${r})")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}

do divmod(a int, b int) -> (q int, r int) {
    mut q int = a / b
    mut r int = a % b
    return q, r
}
