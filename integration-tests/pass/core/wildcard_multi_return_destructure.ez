/*
 * wildcard_multi_return_destructure.ez - Destructuring a generic function
 * whose return type carries '?' in multiple slots.
 *
 * Before the fix, `mut a, b = pair(42)` left the temp's slot types as
 * TK_UNKNOWN (the raw wildcard), the unannotated LHS vars never
 * registered, and every later use of `a`/`b` errored as undefined —
 * pointing at the wrong line. The typechecker now binds '?' from the
 * call's args and substitutes into each return slot.
 */

do pair(x ?) -> (?, ?) { return x, x }
do mixed(x ?) -> (?, int) { return x, 100 }
do triple(x ?) -> (?, ?, int) { return x, x, 7 }

do main() {
    println("=== wildcard multi-return destructure ===")
    mut passed int = 0
    mut failed int = 0

    // both slots wildcard, bound to int
    mut a1, b1 = pair(42)
    if a1 == 42 && b1 == 42 {
        println("  [PASS] (?, ?) -> int")
        passed += 1
    } otherwise {
        println("  [FAIL] (?, ?) -> int")
        failed += 1
    }

    // wildcard + concrete int
    mut a2, b2 = mixed("hi")
    if a2 == "hi" && b2 == 100 {
        println("  [PASS] (?, int) -> string/int")
        passed += 1
    } otherwise {
        println("  [FAIL] (?, int) -> string/int")
        failed += 1
    }

    // underscore in first slot (no binding consumed for _)
    mut _, b3 = pair(3.14)
    if b3 > 3.13 && b3 < 3.15 {
        println("  [PASS] underscore + wildcard slot")
        passed += 1
    } otherwise {
        println("  [FAIL] underscore + wildcard slot")
        failed += 1
    }

    // three slots — two wildcards, one concrete
    mut a4, b4, c4 = triple(5)
    if a4 == 5 && b4 == 5 && c4 == 7 {
        println("  [PASS] (?, ?, int) three-slot")
        passed += 1
    } otherwise {
        println("  [FAIL] (?, ?, int) three-slot")
        failed += 1
    }

    println("=== ${passed} passed, ${failed} failed ===")
    if failed > 0 {
        println("SOME TESTS FAILED")
    }
}
