/*
 * wildcard_named_return.ez - Named return with wildcard type -> (name ?)
 *
 * Regression for #1502 (bug reported during hunt):
 *   - Parser didn't accept TOK_QUESTION in named return type position,
 *     causing `-> (first ?, count int)` to misparse.
 *   - Codegen emitted a single EzMulti typedef but wildcard returns
 *     need per-instantiation structs (the fields change per binding).
 *
 * Exercises: wildcard named return with int binding, wildcard named
 * return with string binding, mixed wildcard + concrete named returns.
 */

do first_and_len(arr [?]) -> (first ?, count int) {
    first = arr[0]
    count = len(arr)
    return first, count
}

do main() {
    println("=== Wildcard Named Return Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- int binding --
    mut v int, n int = first_and_len({10, 20, 30})
    if v == 10 && n == 3 {
        println("  [PASS] first_and_len([int]) = (10, 3)")
        passed += 1
    } otherwise {
        println("  [FAIL] got (${v}, ${n})")
        failed += 1
    }

    // -- string binding (different instantiation) --
    mut s string, n2 int = first_and_len({"a", "b"})
    if s == "a" && n2 == 2 {
        println("  [PASS] first_and_len([string]) = (a, 2)")
        passed += 1
    } otherwise {
        println("  [FAIL] got (${s}, ${n2})")
        failed += 1
    }

    // -- float binding --
    mut f float, n3 int = first_and_len({1.5, 2.5, 3.5, 4.5})
    if f == 1.5 && n3 == 4 {
        println("  [PASS] first_and_len([float]) = (1.5, 4)")
        passed += 1
    } otherwise {
        println("  [FAIL] got (${f}, ${n3})")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
