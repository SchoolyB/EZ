/*
 * wildcard_nested_call.gray - A wildcard function calling another
 * wildcard function propagates the concrete binding.
 *
 * `double(x ?) ->
 * ? { return add(x, x) }` where `add` is also generic emitted
 * `gray_fn_add__unknown` because the inner call's binding wasn't
 * resolved through the outer's active binding. Fixed in both the
 * typechecker (re-check pass bypass + unknown rejection) and
 * codegen (wildcard_binding fallback for inner calls).
 */

do add(a ?, b ?) -> ? {
    return a + b
}

do double(x ?) -> ? {
    return add(x, x)
}

do triple(x ?) -> ? {
    return add(add(x, x), x)
}

do main() {
    println("=== Wildcard Nested Call Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- int binding --
    if double(5) == 10 {
        println("  [PASS] double(5) = 10")
        passed += 1
    } otherwise {
        println("  [FAIL] double(5)")
        failed += 1
    }

    // -- float binding --
    if double(1.5) == 3.0 {
        println("  [PASS] double(1.5) = 3.0")
        passed += 1
    } otherwise {
        println("  [FAIL] double(1.5)")
        failed += 1
    }

    // -- deeper nesting: add(add(x,x), x) --
    if triple(3) == 9 {
        println("  [PASS] triple(3) = 9")
        passed += 1
    } otherwise {
        println("  [FAIL] triple(3)")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
