do log_ln(x ?) {
    println(x)
}

do log(x ?) {
    print(x)
}

do err_ln(x ?) {
    eprintln(x)
}

do err(x ?) {
    eprint(x)
}

do main() {
    mut passed int = 0
    mut failed int = 0

    // println dispatch across instantiations
    log_ln(42)
    log_ln("hello")
    log_ln(3.14)
    log_ln(true)

    // print dispatch across instantiations
    log(1)
    log(" ")
    log("ok")
    println("")

    // eprintln dispatch across instantiations
    err_ln(2)
    err_ln("err")
    err_ln(1.5)
    err_ln(false)

    // eprint dispatch across instantiations
    err(9)
    err(" ")
    err("done")
    eprintln("")

    println("ALL TESTS PASSED")
}
