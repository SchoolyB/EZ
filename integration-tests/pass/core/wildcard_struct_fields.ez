/*
 * wildcard_struct_fields.ez - Generic structs via wildcard ? fields.
 *
 * Feature #1520: struct fields can use ? as their type, enabling
 * monomorphised struct instantiations per concrete binding at each
 * struct literal usage site. All ? fields in one struct bind to the
 * same concrete type per instantiation.
 */

const Pair struct {
    first ?
    second ?
}

const Wrapper struct {
    data ?
    label string
}

do main() {
    println("=== Wildcard Struct Fields Test ===")
    mut passed int = 0
    mut failed int = 0

    // -- int binding --
    mut p1 = Pair{first: 1, second: 2}
    if p1.first == 1 && p1.second == 2 {
        println("  [PASS] Pair{int, int}")
        passed += 1
    } otherwise {
        println("  [FAIL] Pair{int, int}")
        failed += 1
    }

    // -- string binding --
    mut p2 = Pair{first: "a", second: "b"}
    if p2.first == "a" && p2.second == "b" {
        println("  [PASS] Pair{string, string}")
        passed += 1
    } otherwise {
        println("  [FAIL] Pair{string, string}")
        failed += 1
    }

    // -- float binding --
    mut p3 = Pair{first: 1.5, second: 2.5}
    if p3.first == 1.5 && p3.second == 2.5 {
        println("  [PASS] Pair{float, float}")
        passed += 1
    } otherwise {
        println("  [FAIL] Pair{float, float}")
        failed += 1
    }

    // -- bool binding --
    mut p4 = Pair{first: true, second: false}
    if p4.first && !p4.second {
        println("  [PASS] Pair{bool, bool}")
        passed += 1
    } otherwise {
        println("  [FAIL] Pair{bool, bool}")
        failed += 1
    }

    // -- mixed wildcard + concrete fields --
    mut w1 = Wrapper{data: 42, label: "int"}
    mut w2 = Wrapper{data: 3.14, label: "float"}
    if w1.data == 42 && w1.label == "int" &&
       w2.data == 3.14 && w2.label == "float" {
        println("  [PASS] Wrapper with int + float bindings coexist")
        passed += 1
    } otherwise {
        println("  [FAIL] Wrapper coexistence")
        failed += 1
    }

    // -- multiple instantiations of same struct in one program --
    mut a = Pair{first: 100, second: 200}
    mut b = Pair{first: "x", second: "y"}
    if a.first == 100 && b.first == "x" {
        println("  [PASS] int + string Pair in same program")
        passed += 1
    } otherwise {
        println("  [FAIL] coexistence")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
