import "./utils.gray"
using utils

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: call with default param omitted via using
    mut r1 = greet("World")
    if r1 == "Hello, World!" {
        println("  [PASS] default param omitted via using")
        passed += 1
    } otherwise {
        println("  [FAIL] default param omitted: got ${r1}")
        failed += 1
    }

    // Test 2: call with default param overridden via using
    mut r2 = greet("World", "Hi")
    if r2 == "Hi, World!" {
        println("  [PASS] default param overridden via using")
        passed += 1
    } otherwise {
        println("  [FAIL] default param overridden: got ${r2}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
