import "./types.ez"
using types

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: cross-module enum value passed to function
    mut name = color_name(Color.RED)
    if name == "red" {
        println("  [PASS] cross-module enum arg")
        passed += 1
    } otherwise {
        println("  [FAIL] cross-module enum arg: got ${name}")
        failed += 1
    }

    // Test 2: cross-module enum comparison
    mut c Color = Color.GREEN
    if c == Color.GREEN {
        println("  [PASS] cross-module enum comparison")
        passed += 1
    } otherwise {
        println("  [FAIL] cross-module enum comparison")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
