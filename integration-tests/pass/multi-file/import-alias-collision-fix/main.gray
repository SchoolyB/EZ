import lib_server "./lib/server.gray"
import util_server "./utils/server.gray"

do main() {
    mut a string = lib_server.start()
    mut b string = util_server.connect()
    if a == "lib server" && b == "utils server" {
        println("ALL TESTS PASSED")
    } otherwise {
        println("SOME TESTS FAILED")
    }
}
