/*
 * Test: directory import with alias
 * import p "./pkg" aliases the directory module as "p"
 */
import p "./pkg"

do main() {
    mut passed int = 0
    mut failed int = 0

    if p.get_value() == 42 {
        println("  [PASS] aliased directory import")
        passed += 1
    } otherwise {
        println("  [FAIL] aliased directory import")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
