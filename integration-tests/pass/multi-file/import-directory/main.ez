/*
 * Test: directory import
 * import "./models" scans models/ for .ez files and merges them
 */
import "./models"

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: struct + function from user.ez
    mut u = models.create_user("Alice", 30)
    if u.name == "Alice" && u.age == 30 {
        println("  [PASS] directory import struct + function (user.ez)")
        passed += 1
    } otherwise {
        println("  [FAIL] directory import struct + function (user.ez)")
        failed += 1
    }

    // Test 2: constant from user.ez
    if models.DEFAULT_AGE == 25 {
        println("  [PASS] directory import constant (user.ez)")
        passed += 1
    } otherwise {
        println("  [FAIL] directory import constant (user.ez)")
        failed += 1
    }

    // Test 3: struct + function from task.ez
    mut t = models.create_task("Write tests")
    if t.title == "Write tests" && t.done == false {
        println("  [PASS] directory import struct + function (task.ez)")
        passed += 1
    } otherwise {
        println("  [FAIL] directory import struct + function (task.ez)")
        failed += 1
    }

    // Test 4: constant from task.ez
    if models.MAX_TASKS == 50 {
        println("  [PASS] directory import constant (task.ez)")
        passed += 1
    } otherwise {
        println("  [FAIL] directory import constant (task.ez)")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
