import and use "./models.ez"

do main() {
    mut passed int = 0

    // Test 1: unqualified enum access
    mut p int = Priority.HIGH
    if p == 2 {
        passed += 1
    }

    // Test 2: unqualified struct literal
    mut pt = Point{x: 10, y: 20}
    if pt.x == 10 && pt.y == 20 {
        passed += 1
    }

    if passed == 2 {
        println("ALL TESTS PASSED")
    } otherwise {
        println("SOME TESTS FAILED")
    }
}
