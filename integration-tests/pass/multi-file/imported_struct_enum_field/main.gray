/*
 * imported_struct_enum_field - Struct with enum field imported cross-module
 *
 * struct literal in imported module's factory failed
 * with 'expected types_Color, got types_Color' when struct has an enum field.
 */

import "./types.gray"

do main() {
    mut s types.Swatch = types.make_swatch("apple", types.Color.RED)
    if s.name == "apple" {
        println("ALL TESTS PASSED")
    } otherwise {
        println("SOME TESTS FAILED")
    }
}
