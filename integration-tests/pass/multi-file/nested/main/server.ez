const Request struct {
    method string
    path string
    body string
}

const Response struct {
    status int
    body string
}

do get_status_text(code int) -> string {
    if code == 200 {
        return "OK"
    }
    if code == 404 {
        return "Not Found"
    }
    if code == 500 {
        return "Internal Server Error"
    }
    return "Unknown"
}

do handle_home(req Request) -> Response {
    println("Handling: ${req.method} ${req.path}")
    mut resp Response = Response{status: 200, body: "Welcome home!"}
    return resp
}

do handle_not_found(req Request) -> Response {
    mut resp Response = Response{status: 404, body: "Page not found"}
    return resp
}

do start_server(port int) {
    println("Server starting on port ${port}...")
    println("Ready to handle requests!")
}

do process_request(method string, path string) -> Response {
    mut req Request = Request{method: method, path: path, body: ""}

    if path == "/" {
        return handle_home(req)
    }

    return handle_not_found(req)
}
