import "./types.gray"

do main() {
    mut passed int = 0
    mut failed int = 0

    mut items [Item] = {
        Item{name: "Sword", weight: 5},
        Item{name: "Hammer", weight: 8},
        Item{name: "Dagger", weight: 3}
    }

    mut best = find_heaviest(items)
    if best.weight == 8 {
        println("  [PASS] struct array param + return across files")
        passed += 1
    } otherwise {
        println("  [FAIL] expected weight 8, got ${best.weight}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
