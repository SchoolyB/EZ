import mylib"./mylib"
using mylib

do main() {
    mut passed int = 0
    mut failed int = 0

    mut fruits [Fruit] = get_fruits()
    mut total int = total_price(fruits)
    if total == 5 {
        println("  [PASS] struct array via directory import")
        passed += 1
    } otherwise {
        println("  [FAIL] expected total 5, got ${total}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
