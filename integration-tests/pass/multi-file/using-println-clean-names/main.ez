import "./types.ez"
using types

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: can use imported enum with using
    mut c Color = Color.RED
    if c == Color.RED {
        println("  [PASS] using enum value works")
        passed += 1
    } otherwise {
        println("  [FAIL] using enum value")
        failed += 1
    }

    // Test 2: can use imported struct with using
    mut p = Point{x: 1, y: 2}
    if p.x == 1 {
        println("  [PASS] using struct literal works")
        passed += 1
    } otherwise {
        println("  [FAIL] using struct literal")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
