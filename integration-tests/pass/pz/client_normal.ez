// pz template: client (normal)
// Requires network access to httpbun.com.

import @http
import @json

do main() {
    mut resp, err = http.get("http://httpbun.com/get")
    if err != nil {
        println("GET failed.")
        exit(1)
    }
    println("GET Status: ${resp.status}")
    println("GET Body: ${resp.body}")

    mut payload map[string:string] = {"title": "Hello from EZ!", "body": "This is a test post."}
    mut post_resp, post_err = http.post("http://httpbun.com/post", json.encode(payload))
    if post_err != nil {
        println("POST failed.")
        exit(1)
    }
    println("POST Status: ${post_resp.status}")
    println("POST Body: ${post_resp.body}")
}
