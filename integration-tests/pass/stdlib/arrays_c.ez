/*
 * arrays_c.ez - Comprehensive integration test for @arrays (compiler)
 * Tests ALL documented functions in the arrays module.
 */

import @arrays

do is_even(x int) -> bool { return x % 2 == 0 }

do main() {
    println("=== Arrays Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // --- Query Functions ---

    // is_empty
    mut empty_arr [int] = {}
    mut nonempty_arr [int] = {1}
    if arrays.is_empty(empty_arr) == true && arrays.is_empty(nonempty_arr) == false {
        println("  [PASS] is_empty")
        passed += 1
    } otherwise {
        println("  [FAIL] is_empty")
        failed += 1
    }

    // contains
    mut has_arr [int] = {1, 2, 3, 4, 5}
    if arrays.contains(has_arr, 3) == true && arrays.contains(has_arr, 99) == false {
        println("  [PASS] contains")
        passed += 1
    } otherwise {
        println("  [FAIL] contains")
        failed += 1
    }

    // index_of
    mut idx_arr [int] = {10, 20, 30, 40}
    mut idx int = arrays.index_of(idx_arr, 30)
    mut idx_missing int = arrays.index_of(idx_arr, 99)
    if idx == 2 && idx_missing == -1 {
        println("  [PASS] index_of")
        passed += 1
    } otherwise {
        println("  [FAIL] index_of: expected 2/-1, got ${idx}/${idx_missing}")
        failed += 1
    }

    // count
    mut count_arr [int] = {1, 2, 2, 3, 2, 4}
    mut cnt int = arrays.count(count_arr, 2)
    if cnt == 3 {
        println("  [PASS] count")
        passed += 1
    } otherwise {
        println("  [FAIL] count: expected 3, got ${cnt}")
        failed += 1
    }

    // --- Access Functions ---

    // get_first
    mut first_arr [int] = {10, 20, 30}
    mut first_val int = arrays.get_first(first_arr)
    if first_val == 10 {
        println("  [PASS] get_first")
        passed += 1
    } otherwise {
        println("  [FAIL] get_first: expected 10, got ${first_val}")
        failed += 1
    }

    // get_last
    mut last_val int = arrays.get_last(first_arr)
    if last_val == 30 {
        println("  [PASS] get_last")
        passed += 1
    } otherwise {
        println("  [FAIL] get_last: expected 30, got ${last_val}")
        failed += 1
    }

    // --- Modification Functions ---

    // append
    mut arr [int] = {1, 2, 3}
    arrays.append(arr, 4)
    if len(arr) == 4 && arr[3] == 4 {
        println("  [PASS] append")
        passed += 1
    } otherwise {
        println("  [FAIL] append")
        failed += 1
    }

    // prepend
    mut pre_arr [int] = {2, 3, 4}
    arrays.prepend(pre_arr, 1)
    if len(pre_arr) == 4 && pre_arr[0] == 1 && pre_arr[1] == 2 {
        println("  [PASS] prepend")
        passed += 1
    } otherwise {
        println("  [FAIL] prepend: got ${pre_arr}")
        failed += 1
    }

    // insert_at
    mut ins_arr [int] = {1, 2, 4, 5}
    arrays.insert_at(ins_arr, 2, 3)
    if len(ins_arr) == 5 && ins_arr[2] == 3 && ins_arr[3] == 4 {
        println("  [PASS] insert_at")
        passed += 1
    } otherwise {
        println("  [FAIL] insert_at: got ${ins_arr}")
        failed += 1
    }

    // remove_at
    mut rm_arr [int] = {10, 20, 30, 40}
    arrays.remove_at(rm_arr, 1)
    if len(rm_arr) == 3 && rm_arr[0] == 10 && rm_arr[1] == 30 {
        println("  [PASS] remove_at")
        passed += 1
    } otherwise {
        println("  [FAIL] remove_at: got ${rm_arr}")
        failed += 1
    }

    // remove_first
    mut rf_arr [int] = {100, 200, 300}
    mut removed_first int = arrays.remove_first(rf_arr)
    if removed_first == 100 && len(rf_arr) == 2 && rf_arr[0] == 200 {
        println("  [PASS] remove_first")
        passed += 1
    } otherwise {
        println("  [FAIL] remove_first: got ${removed_first}, arr=${rf_arr}")
        failed += 1
    }

    // remove_last
    mut rl_arr [int] = {100, 200, 300}
    mut removed_last int = arrays.remove_last(rl_arr)
    if removed_last == 300 && len(rl_arr) == 2 && rl_arr[1] == 200 {
        println("  [PASS] remove_last")
        passed += 1
    } otherwise {
        println("  [FAIL] remove_last: got ${removed_last}, arr=${rl_arr}")
        failed += 1
    }

    // clear
    mut cl_arr [int] = {1, 2, 3}
    arrays.clear(cl_arr)
    if len(cl_arr) == 0 {
        println("  [PASS] clear")
        passed += 1
    } otherwise {
        println("  [FAIL] clear: expected len 0, got ${len(cl_arr)}")
        failed += 1
    }

    // fill
    mut fill_arr [int] = {}
    arrays.fill(fill_arr, 7, 5)
    if len(fill_arr) == 5 && fill_arr[0] == 7 && fill_arr[4] == 7 {
        println("  [PASS] fill")
        passed += 1
    } otherwise {
        println("  [FAIL] fill: got ${fill_arr}")
        failed += 1
    }

    // sort_asc
    mut unsorted [int] = {5, 3, 1, 4, 2}
    arrays.sort_asc(unsorted)
    if unsorted[0] == 1 && unsorted[1] == 2 && unsorted[4] == 5 {
        println("  [PASS] sort_asc")
        passed += 1
    } otherwise {
        println("  [FAIL] sort_asc: got ${unsorted}")
        failed += 1
    }

    // sort_desc
    mut desc_arr [int] = {1, 4, 2, 5, 3}
    arrays.sort_desc(desc_arr)
    if desc_arr[0] == 5 && desc_arr[1] == 4 && desc_arr[4] == 1 {
        println("  [PASS] sort_desc")
        passed += 1
    } otherwise {
        println("  [FAIL] sort_desc: got ${desc_arr}")
        failed += 1
    }

    // --- Transformation Functions ---

    // reverse
    mut to_rev [int] = {1, 2, 3}
    mut rev [int] = arrays.reverse(to_rev)
    if rev[0] == 3 && rev[1] == 2 && rev[2] == 1 {
        println("  [PASS] reverse")
        passed += 1
    } otherwise {
        println("  [FAIL] reverse: got ${rev}")
        failed += 1
    }

    // slice
    mut sl_arr [int] = {0, 1, 2, 3, 4, 5}
    mut sliced [int] = arrays.slice(sl_arr, 2, 5)
    if len(sliced) == 3 && sliced[0] == 2 && sliced[2] == 4 {
        println("  [PASS] slice")
        passed += 1
    } otherwise {
        println("  [FAIL] slice: got ${sliced}")
        failed += 1
    }

    // concat
    mut ca [int] = {1, 2}
    mut cb [int] = {3, 4}
    mut cat [int] = arrays.concat(ca, cb)
    if len(cat) == 4 && cat[0] == 1 && cat[3] == 4 {
        println("  [PASS] concat")
        passed += 1
    } otherwise {
        println("  [FAIL] concat: got ${cat}")
        failed += 1
    }

    // deduplicate
    mut dup_arr [int] = {1, 2, 2, 3, 3, 3, 4}
    mut deduped [int] = arrays.deduplicate(dup_arr)
    if len(deduped) == 4 && deduped[0] == 1 && deduped[3] == 4 {
        println("  [PASS] deduplicate")
        passed += 1
    } otherwise {
        println("  [FAIL] deduplicate: got ${deduped}")
        failed += 1
    }

    // flatten
    mut nested [[int]] = {{1, 2}, {3, 4}, {5}}
    mut flat [int] = arrays.flatten(nested)
    if len(flat) == 5 && flat[0] == 1 && flat[4] == 5 {
        println("  [PASS] flatten")
        passed += 1
    } otherwise {
        println("  [FAIL] flatten: got ${flat}")
        failed += 1
    }

    // split_every
    mut split_arr [int] = {1, 2, 3, 4, 5, 6}
    mut chunks [[int]] = arrays.split_every(split_arr, 2)
    if len(chunks) == 3 && len(chunks[0]) == 2 && chunks[0][0] == 1 && chunks[2][1] == 6 {
        println("  [PASS] split_every")
        passed += 1
    } otherwise {
        println("  [FAIL] split_every: got ${chunks}")
        failed += 1
    }

    // pair
    mut pa [int] = {1, 2, 3}
    mut pb [int] = {4, 5, 6}
    mut paired [[int]] = arrays.pair(pa, pb)
    if len(paired) == 3 && paired[0][0] == 1 && paired[0][1] == 4 && paired[2][0] == 3 && paired[2][1] == 6 {
        println("  [PASS] pair")
        passed += 1
    } otherwise {
        println("  [FAIL] pair: got ${paired}")
        failed += 1
    }

    // --- Computation Functions ---

    // get_sum
    mut sum_arr [int] = {1, 2, 3, 4, 5}
    mut total int = arrays.get_sum(sum_arr)
    if total == 15 {
        println("  [PASS] get_sum")
        passed += 1
    } otherwise {
        println("  [FAIL] get_sum: expected 15, got ${total}")
        failed += 1
    }

    // get_min
    mut min_arr [int] = {5, 2, 8, 1, 9}
    mut min_val int = arrays.get_min(min_arr)
    if min_val == 1 {
        println("  [PASS] get_min")
        passed += 1
    } otherwise {
        println("  [FAIL] get_min: expected 1, got ${min_val}")
        failed += 1
    }

    // get_max
    mut max_arr [int] = {5, 2, 8, 1, 9}
    mut max_val int = arrays.get_max(max_arr)
    if max_val == 9 {
        println("  [PASS] get_max")
        passed += 1
    } otherwise {
        println("  [FAIL] get_max: expected 9, got ${max_val}")
        failed += 1
    }

    // any - at least one even
    mut any_arr [int] = {1, 3, 4, 7}
    if arrays.any(any_arr, ()is_even) == true {
        println("  [PASS] any (true)")
        passed += 1
    } otherwise {
        println("  [FAIL] any (true)")
        failed += 1
    }

    // any - none match
    mut any_arr2 [int] = {1, 3, 5, 7}
    if arrays.any(any_arr2, ()is_even) == false {
        println("  [PASS] any (false)")
        passed += 1
    } otherwise {
        println("  [FAIL] any (false)")
        failed += 1
    }

    // all - all even
    mut all_arr [int] = {2, 4, 6}
    if arrays.all(all_arr, ()is_even) == true {
        println("  [PASS] all (true)")
        passed += 1
    } otherwise {
        println("  [FAIL] all (true)")
        failed += 1
    }

    // all - not all even
    mut all_arr2 [int] = {2, 4, 5}
    if arrays.all(all_arr2, ()is_even) == false {
        println("  [PASS] all (false)")
        passed += 1
    } otherwise {
        println("  [FAIL] all (false)")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
        exit(1)
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
