/*
 * Pass Test: arrays.map(), arrays.filter(), arrays.reduce()
 * Tests higher-order array functions with function references.
 */

import @arrays

// --- map callbacks ---
do double_it(x int) -> int { return x * 2 }
do square(x float) -> float { return x * x }

// --- filter callbacks ---
do is_even(x int) -> bool { return x % 2 == 0 }

// --- reduce callbacks ---
do add(a int, b int) -> int { return a + b }
do multiply(a int, b int) -> int { return a * b }

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: map with int array (double each element)
    mut nums [int] = {1, 2, 3, 4}
    mut doubled [int] = arrays.map(nums, ()double_it)
    if len(doubled) == 4 {
        if doubled[0] == 2 {
            if doubled[1] == 4 {
                if doubled[2] == 6 {
                    if doubled[3] == 8 {
                        println("  [PASS] map: double int array")
                        passed += 1
                    } otherwise {
                        println("  [FAIL] map: doubled[3] expected 8")
                        failed += 1
                    }
                } otherwise {
                    println("  [FAIL] map: doubled[2] expected 6")
                    failed += 1
                }
            } otherwise {
                println("  [FAIL] map: doubled[1] expected 4")
                failed += 1
            }
        } otherwise {
            println("  [FAIL] map: doubled[0] expected 2")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] map: expected length 4")
        failed += 1
    }

    // Test 2: map with float array
    mut floats [float] = {1.0, 2.0, 3.0}
    mut squared [float] = arrays.map(floats, ()square)
    if len(squared) == 3 {
        if squared[0] == 1.0 {
            if squared[1] == 4.0 {
                if squared[2] == 9.0 {
                    println("  [PASS] map: square float array")
                    passed += 1
                } otherwise {
                    println("  [FAIL] map: squared[2] expected 9.0")
                    failed += 1
                }
            } otherwise {
                println("  [FAIL] map: squared[1] expected 4.0")
                failed += 1
            }
        } otherwise {
            println("  [FAIL] map: squared[0] expected 1.0")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] map: float expected length 3")
        failed += 1
    }

    // Test 3: map on empty array
    mut empty [int] = {}
    mut mapped_empty [int] = arrays.map(empty, ()double_it)
    if len(mapped_empty) == 0 {
        println("  [PASS] map: empty array -> empty")
        passed += 1
    } otherwise {
        println("  [FAIL] map: empty array should produce empty")
        failed += 1
    }

    // Test 4: filter with int array (even numbers)
    mut all_nums [int] = {1, 2, 3, 4, 5, 6}
    mut evens [int] = arrays.filter(all_nums, ()is_even)
    if len(evens) == 3 {
        if evens[0] == 2 {
            if evens[1] == 4 {
                if evens[2] == 6 {
                    println("  [PASS] filter: even numbers")
                    passed += 1
                } otherwise {
                    println("  [FAIL] filter: evens[2] expected 6")
                    failed += 1
                }
            } otherwise {
                println("  [FAIL] filter: evens[1] expected 4")
                failed += 1
            }
        } otherwise {
            println("  [FAIL] filter: evens[0] expected 2")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] filter: expected length 3")
        failed += 1
    }

    // Test 5: filter where nothing matches
    mut odds_only [int] = {1, 3, 5}
    mut no_evens [int] = arrays.filter(odds_only, ()is_even)
    if len(no_evens) == 0 {
        println("  [PASS] filter: nothing matches -> empty")
        passed += 1
    } otherwise {
        println("  [FAIL] filter: no matches should produce empty")
        failed += 1
    }

    // Test 6: filter where all match
    mut all_even [int] = {2, 4, 6}
    mut all_match [int] = arrays.filter(all_even, ()is_even)
    if len(all_match) == 3 {
        println("  [PASS] filter: all match -> full copy")
        passed += 1
    } otherwise {
        println("  [FAIL] filter: all match should return 3 elements")
        failed += 1
    }

    // Test 7: filter on empty array
    mut filter_empty [int] = arrays.filter(empty, ()is_even)
    if len(filter_empty) == 0 {
        println("  [PASS] filter: empty -> empty")
        passed += 1
    } otherwise {
        println("  [FAIL] filter: empty should produce empty")
        failed += 1
    }

    // Test 8: reduce sum of ints
    mut to_sum [int] = {1, 2, 3, 4, 5}
    mut total int = arrays.reduce(to_sum, 0, ()add)
    if total == 15 {
        println("  [PASS] reduce: sum = 15")
        passed += 1
    } otherwise {
        println("  [FAIL] reduce: expected 15, got ${total}")
        failed += 1
    }

    // Test 9: reduce product of ints
    mut to_prod [int] = {1, 2, 3, 4}
    mut product int = arrays.reduce(to_prod, 1, ()multiply)
    if product == 24 {
        println("  [PASS] reduce: product = 24")
        passed += 1
    } otherwise {
        println("  [FAIL] reduce: expected 24, got ${product}")
        failed += 1
    }

    // Test 10: reduce on empty array returns initial
    mut reduce_empty int = arrays.reduce(empty, 42, ()add)
    if reduce_empty == 42 {
        println("  [PASS] reduce: empty -> initial value")
        passed += 1
    } otherwise {
        println("  [FAIL] reduce: empty should return 42, got ${reduce_empty}")
        failed += 1
    }

    // Test 11: reduce on single element
    mut single [int] = {10}
    mut reduce_single int = arrays.reduce(single, 0, ()add)
    if reduce_single == 10 {
        println("  [PASS] reduce: single element")
        passed += 1
    } otherwise {
        println("  [FAIL] reduce: single expected 10, got ${reduce_single}")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
