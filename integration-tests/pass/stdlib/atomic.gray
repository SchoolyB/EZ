/*
 * atomic.gray - Test the atomic module (lock-free operations)
 *
 * Covers: store, load, add, sub, exchange, cas, fence, spinlock
 */

import @atomic

do main() {
    println("=== Atomic Module Test ===")
    mut passed int = 0
    mut failed int = 0

    mut val int = 0
    mut ptr ^int = addr(val)

    // store and load
    atomic.store(ptr, 100)
    if atomic.load(ptr) == 100 {
        println("  [PASS] store/load")
        passed += 1
    } otherwise {
        println("  [FAIL] store/load")
        failed += 1
    }

    // add returns previous value
    mut prev int = atomic.add(ptr, 25)
    if prev == 100 && atomic.load(ptr) == 125 {
        println("  [PASS] add")
        passed += 1
    } otherwise {
        println("  [FAIL] add")
        failed += 1
    }

    // sub returns previous value
    mut prev2 int = atomic.sub(ptr, 50)
    if prev2 == 125 && atomic.load(ptr) == 75 {
        println("  [PASS] sub")
        passed += 1
    } otherwise {
        println("  [FAIL] sub")
        failed += 1
    }

    // exchange returns old value
    mut old int = atomic.exchange(ptr, 999)
    if old == 75 && atomic.load(ptr) == 999 {
        println("  [PASS] exchange")
        passed += 1
    } otherwise {
        println("  [FAIL] exchange")
        failed += 1
    }

    // cas success
    mut ok bool = atomic.cas(ptr, 999, 1000)
    if ok && atomic.load(ptr) == 1000 {
        println("  [PASS] cas success")
        passed += 1
    } otherwise {
        println("  [FAIL] cas success")
        failed += 1
    }

    // cas failure
    mut fail bool = atomic.cas(ptr, 999, 2000)
    if !fail && atomic.load(ptr) == 1000 {
        println("  [PASS] cas failure")
        passed += 1
    } otherwise {
        println("  [FAIL] cas failure")
        failed += 1
    }

    // fence (no crash)
    atomic.fence()
    println("  [PASS] fence")
    passed += 1

    // spinlock
    mut lk = atomic.spinlock()
    atomic.spin_lock(lk)
    atomic.spin_unlock(lk)
    mut got bool = atomic.spin_trylock(lk)
    if got {
        atomic.spin_unlock(lk)
        println("  [PASS] spinlock")
        passed += 1
    } otherwise {
        println("  [FAIL] spinlock")
        failed += 1
    }

    // spinlock_destroy (no crash, frees malloc'd memory)
    atomic.spinlock_destroy(lk)
    println("  [PASS] spinlock_destroy")
    passed += 1

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
