/*
 * channels_param_type_c.ez - Test channels.Channel as function parameter type
 *
 * Covers: module-qualified Channel type in params, inferred receive type
 */

import @channels

do send_value(ch channels.Channel, val int) {
    channels.send(ch, val)
}

do receive_value(ch channels.Channel) -> int {
    return channels.receive(ch)
}

do main() {
    mut ch = channels.open(5)

    send_value(ch, 7)
    mut result = receive_value(ch)
    if result == 7 {
        println("[PASS] Channel param type and inferred receive")
    } otherwise {
        println("[FAIL] expected 7, got ${result}")
    }

    channels.close(ch)
}
