/*
 * encoding_c.ez - Comprehensive integration test for @encoding (compiler)
 * Tests ALL functions: base64_encode, base64_decode, hex_encode, hex_decode,
 *                      url_encode, url_decode
 */

import @encoding

do main() {
    println("=== Encoding Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // base64_encode
    mut b64 string = encoding.base64_encode("Hello, World!")
    if b64 == "SGVsbG8sIFdvcmxkIQ==" {
        println("  [PASS] base64_encode")
        passed += 1
    } otherwise {
        println("  [FAIL] base64_encode: got '${b64}'")
        failed += 1
    }

    // base64_decode
    mut b64_dec string = encoding.base64_decode(b64)
    if b64_dec == "Hello, World!" {
        println("  [PASS] base64_decode")
        passed += 1
    } otherwise {
        println("  [FAIL] base64_decode: got '${b64_dec}'")
        failed += 1
    }

    // base64 round-trip with different data
    mut b64_2 string = encoding.base64_encode("EZ lang")
    mut b64_dec2 string = encoding.base64_decode(b64_2)
    if b64_dec2 == "EZ lang" {
        println("  [PASS] base64 round-trip")
        passed += 1
    } otherwise {
        println("  [FAIL] base64 round-trip: got '${b64_dec2}'")
        failed += 1
    }

    // base64_encode empty string
    mut b64_empty string = encoding.base64_encode("")
    if b64_empty == "" {
        println("  [PASS] base64_encode (empty)")
        passed += 1
    } otherwise {
        println("  [FAIL] base64_encode (empty): got '${b64_empty}'")
        failed += 1
    }

    // hex_encode
    mut hex string = encoding.hex_encode("AB")
    if hex == "4142" {
        println("  [PASS] hex_encode")
        passed += 1
    } otherwise {
        println("  [FAIL] hex_encode: got '${hex}'")
        failed += 1
    }

    // hex_decode
    mut hex_dec string = encoding.hex_decode(hex)
    if hex_dec == "AB" {
        println("  [PASS] hex_decode")
        passed += 1
    } otherwise {
        println("  [FAIL] hex_decode: got '${hex_dec}'")
        failed += 1
    }

    // hex round-trip
    mut hex2 string = encoding.hex_encode("hello")
    mut hex_dec2 string = encoding.hex_decode(hex2)
    if hex_dec2 == "hello" {
        println("  [PASS] hex round-trip")
        passed += 1
    } otherwise {
        println("  [FAIL] hex round-trip: got '${hex_dec2}'")
        failed += 1
    }

    // url_encode
    mut url string = encoding.url_encode("hello world&foo=bar")
    if url == "hello%20world%26foo%3Dbar" {
        println("  [PASS] url_encode")
        passed += 1
    } otherwise {
        println("  [FAIL] url_encode: got '${url}'")
        failed += 1
    }

    // url_decode
    mut url_dec string = encoding.url_decode(url)
    if url_dec == "hello world&foo=bar" {
        println("  [PASS] url_decode")
        passed += 1
    } otherwise {
        println("  [FAIL] url_decode: got '${url_dec}'")
        failed += 1
    }

    // url round-trip with special chars
    mut url2 string = encoding.url_encode("a+b=c&d/e")
    mut url_dec2 string = encoding.url_decode(url2)
    if url_dec2 == "a+b=c&d/e" {
        println("  [PASS] url round-trip")
        passed += 1
    } otherwise {
        println("  [FAIL] url round-trip: got '${url_dec2}'")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
        exit(1)
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
