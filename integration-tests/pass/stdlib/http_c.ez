/*
 * http_c.ez - Integration test for @http (compiler)
 * Requires network access to httpbun.com
 */

import @http

do main() {
    mut pass int = 0
    mut fail int = 0
    mut headers map[string:string] = {:}

    // GET
    mut resp, _ = http.get("http://httpbun.com/get", headers)
    if resp.status == 200 { pass += 1 } otherwise { fail += 1 }
    if len(resp.body) > 0 { pass += 1 } otherwise { fail += 1 }

    // POST
    mut post_resp, _ = http.post("http://httpbun.com/post", "hello=world", headers)
    if post_resp.status == 200 { pass += 1 } otherwise { fail += 1 }

    // PATCH
    mut patch_resp, _ = http.patch("http://httpbun.com/patch", "update=true", headers)
    if patch_resp.status == 200 { pass += 1 } otherwise { fail += 1 }

    // 404
    mut not_found, _ = http.get("http://httpbun.com/status/404", headers)
    if not_found.status == 404 { pass += 1 } otherwise { fail += 1 }

    println("http: ${pass} passed, ${fail} failed")
    if fail > 0 { exit(1) }
    println("ALL TESTS PASSED")
}
