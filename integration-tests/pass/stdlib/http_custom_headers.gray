/*
 * http_custom_headers.gray - Verify custom headers are sent with requests
 * Requires network access to httpbun.com
 */

import @http

do main() {
    mut pass int = 0
    mut fail int = 0

    // GET with custom headers
    mut headers map[string:string] = {"X-Custom-Header": "hello-gray", "Accept": "application/json"}
    mut resp, err = http.get("http://httpbun.com/headers", headers)
    if err != nil {
        println("FAIL: unexpected error: ${err}")
        fail += 1
    } otherwise {
        if resp.status == 200 { pass += 1 } otherwise { fail += 1 }
    }

    // POST with custom Content-Type header
    mut post_headers map[string:string] = {"Content-Type": "application/json"}
    mut post_resp, post_err = http.post("http://httpbun.com/post", "{\"key\": \"value\"}", post_headers)
    if post_err != nil {
        println("FAIL: unexpected error: ${post_err}")
        fail += 1
    } otherwise {
        if post_resp.status == 200 { pass += 1 } otherwise { fail += 1 }
    }

    // Empty headers still works
    mut empty map[string:string] = {:}
    mut head_resp, head_err = http.head("http://httpbun.com/status/200", empty)
    if head_err != nil {
        println("FAIL: unexpected error: ${head_err}")
        fail += 1
    } otherwise {
        if head_resp.status == 200 { pass += 1 } otherwise { fail += 1 }
    }

    println("http custom headers: ${pass} passed, ${fail} failed")
    if fail > 0 { exit(1) }
    println("ALL TESTS PASSED")
}
