/*
 * io_c.ez - Integration test for @io (compiler)
 */

import @io

do main() {
    println("=== IO Module Test ===")
    mut passed int = 0
    mut failed int = 0

    mut test_file string = "/tmp/ez_io_c_test.txt"
    mut content string = "Hello from EZ compiler test!"

    // write_file
    mut w_ok = io.write_file(test_file, content)
    if io.file_exists(test_file) {
        println("  [PASS] write_file + file_exists")
        passed += 1
    } otherwise {
        println("  [FAIL] write_file + file_exists")
        failed += 1
    }

    // is_file
    if io.is_file(test_file) {
        println("  [PASS] is_file")
        passed += 1
    } otherwise {
        println("  [FAIL] is_file")
        failed += 1
    }

    // is_directory
    if io.is_directory("/tmp") {
        println("  [PASS] is_directory")
        passed += 1
    } otherwise {
        println("  [FAIL] is_directory")
        failed += 1
    }

    // file_size
    mut size int = io.file_size(test_file)
    if size > 0 {
        println("  [PASS] file_size > 0")
        passed += 1
    } otherwise {
        println("  [FAIL] file_size: got ${size}")
        failed += 1
    }

    // rename
    mut renamed string = "/tmp/ez_io_c_test_renamed.txt"
    mut rn_ok = io.rename_file(test_file, renamed)
    if io.file_exists(renamed) {
        println("  [PASS] rename")
        passed += 1
    } otherwise {
        println("  [FAIL] rename")
        failed += 1
    }

    // remove
    mut rm_ok = io.delete_file(renamed)
    if io.file_exists(renamed) == false {
        println("  [PASS] remove")
        passed += 1
    } otherwise {
        println("  [FAIL] remove: file still exists")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
}
