/*
 * Test: io module directory and file operations (#1446)
 * Tests make_dir, make_dir_all, copy_file, move_file, remove_dir, remove_dir_all
 */

import @io

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: make_dir creates a directory
    mut ok bool = io.make_dir("/tmp/ez_test_dir_1446")
    if ok == true {
        println("  [PASS] make_dir creates directory")
        passed += 1
    } otherwise {
        println("  [FAIL] make_dir returned false")
        failed += 1
    }

    // Test 2: is_directory confirms it exists
    if io.is_directory("/tmp/ez_test_dir_1446") == true {
        println("  [PASS] is_directory confirms created dir")
        passed += 1
    } otherwise {
        println("  [FAIL] is_directory returned false for created dir")
        failed += 1
    }

    // Test 3: remove_dir removes it
    mut rm bool = io.remove_dir("/tmp/ez_test_dir_1446")
    if rm == true {
        println("  [PASS] remove_dir removes directory")
        passed += 1
    } otherwise {
        println("  [FAIL] remove_dir returned false")
        failed += 1
    }

    // Test 4: make_dir_all creates nested directories
    mut ok2 bool = io.make_dir_all("/tmp/ez_test_1446/a/b/c")
    if ok2 == true {
        println("  [PASS] make_dir_all creates nested dirs")
        passed += 1
    } otherwise {
        println("  [FAIL] make_dir_all returned false")
        failed += 1
    }

    // Test 5: write a file then copy it
    mut _, _ = io.write_file("/tmp/ez_test_1446/a/test.txt", "hello")
    mut cp bool = io.copy_file("/tmp/ez_test_1446/a/test.txt", "/tmp/ez_test_1446/a/b/test_copy.txt")
    if cp == true {
        println("  [PASS] copy_file succeeds")
        passed += 1
    } otherwise {
        println("  [FAIL] copy_file returned false")
        failed += 1
    }

    // Test 6: verify copied file content
    mut content string = io.read_file("/tmp/ez_test_1446/a/b/test_copy.txt")
    if content == "hello" {
        println("  [PASS] copied file has correct content")
        passed += 1
    } otherwise {
        println("  [FAIL] copied file content: expected \"hello\", got \"${content}\"")
        failed += 1
    }

    // Test 7: move_file
    mut mv bool = io.move_file("/tmp/ez_test_1446/a/b/test_copy.txt", "/tmp/ez_test_1446/a/b/c/moved.txt")
    if mv == true {
        println("  [PASS] move_file succeeds")
        passed += 1
    } otherwise {
        println("  [FAIL] move_file returned false")
        failed += 1
    }

    // Test 8: verify moved file exists and original is gone
    if io.file_exists("/tmp/ez_test_1446/a/b/c/moved.txt") == true {
        println("  [PASS] moved file exists at new location")
        passed += 1
    } otherwise {
        println("  [FAIL] moved file not found at new location")
        failed += 1
    }

    // Test 9: remove_dir_all cleans up everything
    mut rma bool = io.remove_dir_all("/tmp/ez_test_1446")
    if rma == true {
        println("  [PASS] remove_dir_all cleans up nested dirs")
        passed += 1
    } otherwise {
        println("  [FAIL] remove_dir_all returned false")
        failed += 1
    }

    // Test 10: confirm cleanup
    if io.file_exists("/tmp/ez_test_1446") == false {
        println("  [PASS] directory fully removed")
        passed += 1
    } otherwise {
        println("  [FAIL] directory still exists after remove_dir_all")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
