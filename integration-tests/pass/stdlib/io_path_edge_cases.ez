/*
 * Test: io path function edge cases (#1446)
 * Verifies fixes for dotfile extension, trailing-slash dirname, absolute path_join
 */

import @io

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: extension of dotfile returns ""
    mut r1 string = io.extension(".gitignore")
    if r1 == "" {
        println("  [PASS] extension('.gitignore') = ''")
        passed += 1
    } otherwise {
        println("  [FAIL] extension('.gitignore'): expected '', got '${r1}'")
        failed += 1
    }

    // Test 2: extension of dotfile with extension
    mut r2 string = io.extension(".bashrc.bak")
    if r2 == ".bak" {
        println("  [PASS] extension('.bashrc.bak') = '.bak'")
        passed += 1
    } otherwise {
        println("  [FAIL] extension('.bashrc.bak'): expected '.bak', got '${r2}'")
        failed += 1
    }

    // Test 3: dirname strips trailing slash
    mut r3 string = io.dirname("/home/user/")
    if r3 == "/home" {
        println("  [PASS] dirname('/home/user/') = '/home'")
        passed += 1
    } otherwise {
        println("  [FAIL] dirname('/home/user/'): expected '/home', got '${r3}'")
        failed += 1
    }

    // Test 4: dirname with multiple trailing slashes
    mut r4 string = io.dirname("/home/user///")
    if r4 == "/home" {
        println("  [PASS] dirname('/home/user///') = '/home'")
        passed += 1
    } otherwise {
        println("  [FAIL] dirname('/home/user///'): expected '/home', got '${r4}'")
        failed += 1
    }

    // Test 5: path_join with absolute second arg replaces first
    mut r5 string = io.path_join({"/home", "/absolute/path"})
    if r5 == "/absolute/path" {
        println("  [PASS] path_join('/home', '/absolute/path') = '/absolute/path'")
        passed += 1
    } otherwise {
        println("  [FAIL] path_join absolute second: expected '/absolute/path', got '${r5}'")
        failed += 1
    }

    // Test 6: path_join with relative second arg still joins
    mut r6 string = io.path_join({"/home", "user"})
    if r6 == "/home/user" {
        println("  [PASS] path_join('/home', 'user') = '/home/user'")
        passed += 1
    } otherwise {
        println("  [FAIL] path_join relative: expected '/home/user', got '${r6}'")
        failed += 1
    }

    // Test 7: dirname of root with trailing slash
    mut r7 string = io.dirname("///")
    if r7 == "/" {
        println("  [PASS] dirname('///') = '/'")
        passed += 1
    } otherwise {
        println("  [FAIL] dirname('///'): expected '/', got '${r7}'")
        failed += 1
    }

    // Test 8: extension of path with dotfile in directory
    mut r8 string = io.extension("/home/.config/file.txt")
    if r8 == ".txt" {
        println("  [PASS] extension('/home/.config/file.txt') = '.txt'")
        passed += 1
    } otherwise {
        println("  [FAIL] extension('/home/.config/file.txt'): expected '.txt', got '${r8}'")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
