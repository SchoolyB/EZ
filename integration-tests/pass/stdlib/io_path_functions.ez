/*
 * Test: io module path manipulation functions (#1446)
 * Tests path_join, dirname, basename, extension, is_absolute, normalize
 */

import @io

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: path_join
    mut joined string = io.path_join("/home", "user")
    if joined == "/home/user" {
        println("  [PASS] path_join(\"/home\", \"user\") = \"/home/user\"")
        passed += 1
    } otherwise {
        println("  [FAIL] path_join: expected \"/home/user\", got \"${joined}\"")
        failed += 1
    }

    // Test 2: dirname
    mut dir string = io.dirname("/home/user/file.txt")
    if dir == "/home/user" {
        println("  [PASS] dirname(\"/home/user/file.txt\") = \"/home/user\"")
        passed += 1
    } otherwise {
        println("  [FAIL] dirname: expected \"/home/user\", got \"${dir}\"")
        failed += 1
    }

    // Test 3: basename
    mut base string = io.basename("/home/user/file.txt")
    if base == "file.txt" {
        println("  [PASS] basename(\"/home/user/file.txt\") = \"file.txt\"")
        passed += 1
    } otherwise {
        println("  [FAIL] basename: expected \"file.txt\", got \"${base}\"")
        failed += 1
    }

    // Test 4: extension
    mut ext string = io.extension("/home/user/file.txt")
    if ext == ".txt" {
        println("  [PASS] extension(\"/home/user/file.txt\") = \".txt\"")
        passed += 1
    } otherwise {
        println("  [FAIL] extension: expected \".txt\", got \"${ext}\"")
        failed += 1
    }

    // Test 5: extension on file with no extension
    mut ext2 string = io.extension("/home/user/Makefile")
    if ext2 == "" {
        println("  [PASS] extension(\"Makefile\") = \"\"")
        passed += 1
    } otherwise {
        println("  [FAIL] extension(\"Makefile\"): expected \"\", got \"${ext2}\"")
        failed += 1
    }

    // Test 6: is_absolute with absolute path
    mut abs bool = io.is_absolute("/usr/bin")
    if abs == true {
        println("  [PASS] is_absolute(\"/usr/bin\") = true")
        passed += 1
    } otherwise {
        println("  [FAIL] is_absolute(\"/usr/bin\"): expected true")
        failed += 1
    }

    // Test 7: is_absolute with relative path
    mut rel bool = io.is_absolute("src/main.ez")
    if rel == false {
        println("  [PASS] is_absolute(\"src/main.ez\") = false")
        passed += 1
    } otherwise {
        println("  [FAIL] is_absolute(\"src/main.ez\"): expected false")
        failed += 1
    }

    // Test 8: normalize removes trailing slash
    mut norm string = io.normalize("/home/user/")
    if norm == "/home/user" {
        println("  [PASS] normalize(\"/home/user/\") = \"/home/user\"")
        passed += 1
    } otherwise {
        println("  [FAIL] normalize: expected \"/home/user\", got \"${norm}\"")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
