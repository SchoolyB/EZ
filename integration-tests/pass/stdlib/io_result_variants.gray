/*
 * Test: io module _result variants for error handling
 * Verifies multi-var destructuring works for all fallible io functions.
 */

import @io

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: read_file error path
    mut content, err = io.read_file("/tmp/gray_nonexistent_99999.txt")
    if err != nil {
        println("  [PASS] read_file error caught on nonexistent file")
        passed += 1
    } otherwise {
        println("  [FAIL] read_file no error, content='${content}'")
        failed += 1
    }

    // Test 2: read_file success path
    mut _, _ = io.write_file("/tmp/gray_result_test_1547.txt", "hello")
    mut content2, err2 = io.read_file("/tmp/gray_result_test_1547.txt")
    if err2 == nil {
        if content2 == "hello" {
            println("  [PASS] read_file success, content correct")
            passed += 1
        } otherwise {
            println("  [FAIL] read_file content wrong: '${content2}'")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] read_file error on valid file")
        failed += 1
    }

    // Test 3: write_file error path
    mut wok, werr = io.write_file("/nonexistent_dir/file.txt", "data")
    if werr != nil {
        println("  [PASS] write_file error caught on invalid path")
        passed += 1
    } otherwise {
        println("  [FAIL] write_file no error, ok=${wok}")
        failed += 1
    }

    // Test 4: delete_file error path
    mut dok, derr = io.delete_file("/tmp/gray_nonexistent_delete_1547.txt")
    if derr != nil {
        println("  [PASS] delete_file error caught on nonexistent")
        passed += 1
    } otherwise {
        println("  [FAIL] delete_file no error, ok=${dok}")
        failed += 1
    }

    // Test 5: copy_file error path
    mut cok, cerr = io.copy_file("/tmp/gray_nonexistent_src", "/tmp/gray_dst")
    if cerr != nil {
        println("  [PASS] copy_file error caught on nonexistent src")
        passed += 1
    } otherwise {
        println("  [FAIL] copy_file no error, ok=${cok}")
        failed += 1
    }

    // Test 6: move_file error path
    mut mok, merr = io.move_file("/tmp/gray_nonexistent_move", "/tmp/gray_moved")
    if merr != nil {
        println("  [PASS] move_file error caught on nonexistent src")
        passed += 1
    } otherwise {
        println("  [FAIL] move_file no error, ok=${mok}")
        failed += 1
    }

    // Test 7: list_dir error path
    mut entries, lerr = io.list_dir("/tmp/gray_nonexistent_dir_1547")
    if lerr != nil {
        println("  [PASS] list_dir error caught on nonexistent dir")
        passed += 1
    } otherwise {
        println("  [FAIL] list_dir no error, len=${len(entries)}")
        failed += 1
    }

    // Test 8: make_dir success then error on duplicate
    mut mkok, mkerr = io.make_dir("/tmp/gray_result_mkdir_1547")
    if mkerr == nil {
        println("  [PASS] make_dir success on fresh dir")
        passed += 1
    } otherwise {
        println("  [FAIL] make_dir error on fresh dir")
        failed += 1
    }
    mut mkok2, mkerr2 = io.make_dir("/tmp/gray_result_mkdir_1547")
    if mkerr2 != nil {
        println("  [PASS] make_dir error caught on duplicate dir")
        passed += 1
    } otherwise {
        println("  [FAIL] make_dir no error on duplicate, ok=${mkok2}")
        failed += 1
    }

    // Test 10: walk error path
    mut files, walkerr = io.walk("/tmp/gray_nonexistent_walk_1547")
    if walkerr != nil {
        println("  [PASS] walk error caught on nonexistent dir")
        passed += 1
    } otherwise {
        println("  [FAIL] walk no error, len=${len(files)}")
        failed += 1
    }

    // Test 11: append_file error path
    mut aok, aerr = io.append_file("/nonexistent_dir/file.txt", "data")
    if aerr != nil {
        println("  [PASS] append_file error caught on invalid path")
        passed += 1
    } otherwise {
        println("  [FAIL] append_file no error, ok=${aok}")
        failed += 1
    }

    // Test 12: rename_file error path
    mut rok, rerr = io.rename_file("/tmp/gray_nonexistent_rename", "/tmp/gray_renamed")
    if rerr != nil {
        println("  [PASS] rename_file error caught on nonexistent")
        passed += 1
    } otherwise {
        println("  [FAIL] rename_file no error, ok=${rok}")
        failed += 1
    }

    // Test 13: remove_dir error path
    mut rdok, rderr = io.remove_dir("/tmp/gray_nonexistent_rmdir_1547")
    if rderr != nil {
        println("  [PASS] remove_dir error caught on nonexistent")
        passed += 1
    } otherwise {
        println("  [FAIL] remove_dir no error, ok=${rdok}")
        failed += 1
    }

    // Test 14: remove_dir_all error path
    mut raok, raerr = io.remove_dir_all("/tmp/gray_nonexistent_rmdirall_1547")
    if raerr != nil {
        println("  [PASS] remove_dir_all error caught on nonexistent")
        passed += 1
    } otherwise {
        println("  [FAIL] remove_dir_all no error, ok=${raok}")
        failed += 1
    }

    // Test 15: read_file_result on a directory returns error (not panic)
    mut dc, derr2 = io.read_file("/tmp")
    if derr2 != nil {
        println("  [PASS] read_file_result on directory returns error")
        passed += 1
    } otherwise {
        println("  [FAIL] read_file_result on directory: expected error, got content")
        failed += 1
    }

    // Test 16: write_file_result on a directory returns error (not panic)
    mut wdok, wderr = io.write_file("/tmp", "data")
    if wderr != nil {
        println("  [PASS] write_file_result on directory returns error")
        passed += 1
    } otherwise {
        println("  [FAIL] write_file_result on directory: expected error, ok=${wdok}")
        failed += 1
    }

    // Test 17: delete_file_result on a directory returns error (not panic)
    mut ddok, ddderr = io.delete_file("/tmp")
    if ddderr != nil {
        println("  [PASS] delete_file_result on directory returns error")
        passed += 1
    } otherwise {
        println("  [FAIL] delete_file_result on directory: expected error, ok=${ddok}")
        failed += 1
    }

    // Test 18: append_file_result on a directory returns error (not panic)
    mut adok, adderr = io.append_file("/tmp", "data")
    if adderr != nil {
        println("  [PASS] append_file_result on directory returns error")
        passed += 1
    } otherwise {
        println("  [FAIL] append_file_result on directory: expected error, ok=${adok}")
        failed += 1
    }

    // Test 19: copy_file_result with directory src returns error (not panic)
    mut cdok, cdderr = io.copy_file("/tmp", "/tmp/gray_dst_copy")
    if cdderr != nil {
        println("  [PASS] copy_file_result with directory src returns error")
        passed += 1
    } otherwise {
        println("  [FAIL] copy_file_result directory src: expected error, ok=${cdok}")
        failed += 1
    }

    // Cleanup
    mut _, _ = io.remove_dir("/tmp/gray_result_mkdir_1547")
    mut _, _ = io.delete_file("/tmp/gray_result_test_1547.txt")

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
