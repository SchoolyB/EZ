/*
 * json_c.ez - Integration test for @json (compiler)
 */

import @std
import @json
using std

do main() {
    println("=== JSON Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // is_valid with valid JSON object
    if json.is_valid("{\"key\": \"value\"}") == true {
        println("  [PASS] is_valid (object)")
        passed += 1
    } otherwise {
        println("  [FAIL] is_valid (object)")
        failed += 1
    }

    // is_valid with valid JSON array
    if json.is_valid("[1, 2, 3]") == true {
        println("  [PASS] is_valid (array)")
        passed += 1
    } otherwise {
        println("  [FAIL] is_valid (array)")
        failed += 1
    }

    // is_valid with valid JSON string
    if json.is_valid("\"hello\"") == true {
        println("  [PASS] is_valid (string)")
        passed += 1
    } otherwise {
        println("  [FAIL] is_valid (string)")
        failed += 1
    }

    // is_valid with empty string
    if json.is_valid("") == false {
        println("  [PASS] is_valid (empty)")
        passed += 1
    } otherwise {
        println("  [FAIL] is_valid (empty)")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
}
