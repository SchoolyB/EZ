/*
 * json_c.ez - Integration test for @json (compiler)
 */

import @json

do main() {
    println("=== JSON Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // is_valid with valid JSON object
    if json.is_valid("{\"key\": \"value\"}") == true {
        println("  [PASS] is_valid (object)")
        passed += 1
    } otherwise {
        println("  [FAIL] is_valid (object)")
        failed += 1
    }

    // is_valid with valid JSON array
    if json.is_valid("[1, 2, 3]") == true {
        println("  [PASS] is_valid (array)")
        passed += 1
    } otherwise {
        println("  [FAIL] is_valid (array)")
        failed += 1
    }

    // is_valid with valid JSON string
    if json.is_valid("\"hello\"") == true {
        println("  [PASS] is_valid (string)")
        passed += 1
    } otherwise {
        println("  [FAIL] is_valid (string)")
        failed += 1
    }

    // is_valid with empty string
    if json.is_valid("") == false {
        println("  [PASS] is_valid (empty)")
        passed += 1
    } otherwise {
        println("  [FAIL] is_valid (empty)")
        failed += 1
    }

    // json.encode with int literal
    mut enc_int string = json.encode(42)
    if enc_int == "42" {
        println("  [PASS] json.encode(42)")
        passed += 1
    } otherwise {
        println("  [FAIL] json.encode(42): got '${enc_int}'")
        failed += 1
    }

    // json.encode with bool
    mut enc_bool string = json.encode(true)
    if enc_bool == "true" {
        println("  [PASS] json.encode(true)")
        passed += 1
    } otherwise {
        println("  [FAIL] json.encode(true): got '${enc_bool}'")
        failed += 1
    }

    // json.encode with string
    mut enc_str string = json.encode("hello")
    if enc_str == "\"hello\"" {
        println("  [PASS] json.encode(\"hello\")")
        passed += 1
    } otherwise {
        println("  [FAIL] json.encode(string): got '${enc_str}'")
        failed += 1
    }

    // json.encode with float
    mut enc_float string = json.encode(3.14)
    println("  [PASS] json.encode(3.14) = '${enc_float}'")
    passed += 1

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
}
