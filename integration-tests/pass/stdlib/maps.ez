/*
 * maps.ez - Test @maps standard library with PROPER ASSERTIONS
 */

import @std, @maps
using std

do main() {
    println("=== @maps Standard Library Test ===")
    mut passed int = 0
    mut failed int = 0

    // ==================== maps.keys ====================
    println("  -- maps.keys --")

    mut m map[string:int] = {"a": 1, "b": 2, "c": 3}

    // Test 1: keys returns correct count
    mut keys [string] = maps.keys(m)
    if len(keys) == 3 {
        println("  [PASS] maps.keys() returns 3 keys")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.keys: expected 3 keys, got ${len(keys)}")
        failed += 1
    }

    // ==================== maps.values ====================
    println("  -- maps.values --")

    // Test 2: values returns correct count
    mut values [int] = maps.values(m)
    if len(values) == 3 {
        println("  [PASS] maps.values() returns 3 values")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.values: expected 3 values, got ${len(values)}")
        failed += 1
    }

    // ==================== maps.contains ====================
    println("  -- maps.contains --")

    // Test 3: contains - key exists
    if maps.has_key(m, "a") == true {
        println("  [PASS] maps.has_key(m, 'a') = true")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.has_key(m, 'a'): expected true")
        failed += 1
    }

    // Test 4: contains - key doesn't exist
    if maps.has_key(m, "z") == false {
        println("  [PASS] maps.has_key(m, 'z') = false")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.has_key(m, 'z'): expected false")
        failed += 1
    }

    // ==================== maps.remove_key ====================
    println("  -- maps.remove_key --")

    // Test 5: remove removes key
    mut del_map map[string:int] = {"x": 10, "y": 20, "z": 30}
    mut removed bool = maps.remove_key(del_map, "y")
    if len(del_map) == 2 && !maps.has_key(del_map, "y") && removed {
        println("  [PASS] maps.remove_key() removed key 'y'")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.remove_key: len=${len(del_map)}, contains_y=${maps.has_key(del_map, "y")}, removed=${removed}")
        failed += 1
    }

    // Test 6: remaining keys still accessible after remove
    if del_map["x"] == 10 && del_map["z"] == 30 {
        println("  [PASS] remaining keys still accessible after remove")
        passed += 1
    } otherwise {
        println("  [FAIL] remaining keys: x=${del_map["x"]}, z=${del_map["z"]}")
        failed += 1
    }

    // ==================== maps.clear ====================
    println("  -- maps.clear --")

    // Test 7: clear empties map
    mut clear_map map[string:int] = {"a": 1, "b": 2, "c": 3}
    maps.clear(clear_map)
    if len(clear_map) == 0 {
        println("  [PASS] maps.clear() empties map")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.clear: expected len 0, got ${len(clear_map)}")
        failed += 1
    }

    // ==================== maps.merge ====================
    println("  -- maps.merge --")

    // Test 8: merge two maps
    mut m1 map[string:int] = {"a": 1, "b": 2}
    mut m2 map[string:int] = {"c": 3, "d": 4}
    mut merged map[string:int] = maps.merge(m1, m2)
    if len(merged) == 4 && merged["a"] == 1 && merged["d"] == 4 {
        println("  [PASS] maps.merge() combines maps")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.merge: expected 4 entries, got ${len(merged)}")
        failed += 1
    }

    // Test 9: merge with overlapping keys (second overwrites)
    mut m3 map[string:int] = {"a": 100}
    mut merged_overlap map[string:int] = maps.merge(m1, m3)
    if merged_overlap["a"] == 100 {
        println("  [PASS] maps.merge() overwrites with second map's value")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.merge overlap: expected a=100, got ${merged_overlap["a"]}")
        failed += 1
    }

    // ==================== INT KEY MAPS ====================
    println("  -- Int Key Maps --")

    mut int_map map[int:string] = {1: "one", 2: "two", 3: "three"}

    // Test 10: int keys work
    if int_map[2] == "two" {
        println("  [PASS] int-keyed map: [2] = 'two'")
        passed += 1
    } otherwise {
        println("  [FAIL] int-keyed map: expected 'two', got '${int_map[2]}'")
        failed += 1
    }

    // Test 11: maps.contains with int key
    if maps.has_key(int_map, 1) == true && maps.has_key(int_map, 99) == false {
        println("  [PASS] maps.has_key() works with int keys")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.contains with int keys")
        failed += 1
    }

    // ==================== EMPTY MAP ====================
    println("  -- Empty Map --")

    mut empty_map map[string:int] = {}

    // Test 12: empty map has length 0
    if len(empty_map) == 0 {
        println("  [PASS] empty map len = 0")
        passed += 1
    } otherwise {
        println("  [FAIL] empty map len: expected 0, got ${len(empty_map)}")
        failed += 1
    }

    // Test 13: maps.keys on empty map
    mut empty_keys [string] = maps.keys(empty_map)
    if len(empty_keys) == 0 {
        println("  [PASS] maps.keys() on empty map returns []")
        passed += 1
    } otherwise {
        println("  [FAIL] maps.keys on empty: got ${empty_keys}")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")

    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
