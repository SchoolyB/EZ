/*
 * maps_c.ez - Integration test for @maps (compiler)
 */

import @std
import @maps
using std

do main() {
    println("=== Maps Module Test ===")
    mut passed int = 0
    mut failed int = 0

    mut m map[string:int] = {"a": 1, "b": 2, "c": 3}

    // keys
    mut k [string] = maps.keys(m)
    if len(k) == 3 {
        println("  [PASS] keys")
        passed += 1
    } otherwise {
        println("  [FAIL] keys: expected 3, got ${len(k)}")
        failed += 1
    }

    // values
    mut v [int] = maps.values(m)
    if len(v) == 3 {
        println("  [PASS] values")
        passed += 1
    } otherwise {
        println("  [FAIL] values: expected 3, got ${len(v)}")
        failed += 1
    }

    // has_key (exists)
    if maps.has_key(m, "a") == true {
        println("  [PASS] has_key (exists)")
        passed += 1
    } otherwise {
        println("  [FAIL] has_key (exists)")
        failed += 1
    }

    // has_key (missing)
    if maps.has_key(m, "z") == false {
        println("  [PASS] has_key (missing)")
        passed += 1
    } otherwise {
        println("  [FAIL] has_key (missing)")
        failed += 1
    }

    // remove (void) — verify side effect
    mut rm_map map[string:int] = {"x": 10, "y": 20, "z": 30}
    maps.remove(rm_map, "y")
    if len(rm_map) == 2 {
        println("  [PASS] remove")
        passed += 1
    } otherwise {
        println("  [FAIL] remove: expected len 2, got ${len(rm_map)}")
        failed += 1
    }

    // clear (void)
    mut cl_map map[string:int] = {"a": 1, "b": 2}
    maps.clear(cl_map)
    if len(cl_map) == 0 {
        println("  [PASS] clear")
        passed += 1
    } otherwise {
        println("  [FAIL] clear: expected len 0, got ${len(cl_map)}")
        failed += 1
    }

    // keys returns array
    mut iter_map map[string:int] = {"a": 1, "b": 2, "c": 3}
    mut ks [string] = maps.keys(iter_map)
    if len(ks) == 3 {
        println("  [PASS] keys length")
        passed += 1
    } otherwise {
        println("  [FAIL] keys length: ${len(ks)}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
}
