/*
 * math_c.ez - Integration test for @math (compiler)
 */

import @math

do main() {
    println("=== Math Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // abs
    if math.abs(-5) == 5 {
        println("  [PASS] abs")
        passed += 1
    } otherwise {
        println("  [FAIL] abs")
        failed += 1
    }

    // min
    if math.min(3, 7) == 3 {
        println("  [PASS] min")
        passed += 1
    } otherwise {
        println("  [FAIL] min")
        failed += 1
    }

    // max
    if math.max(3, 7) == 7 {
        println("  [PASS] max")
        passed += 1
    } otherwise {
        println("  [FAIL] max")
        failed += 1
    }

    // floor
    mut floor_val float = math.floor(3.7)
    if floor_val == 3.0 {
        println("  [PASS] floor")
        passed += 1
    } otherwise {
        println("  [FAIL] floor: expected 3.0, got ${floor_val}")
        failed += 1
    }

    // ceil
    mut ceil_val float = math.ceil(3.2)
    if ceil_val == 4.0 {
        println("  [PASS] ceil")
        passed += 1
    } otherwise {
        println("  [FAIL] ceil: expected 4.0, got ${ceil_val}")
        failed += 1
    }

    // sqrt
    mut sqrt_val float = math.sqrt(16.0)
    if sqrt_val == 4.0 {
        println("  [PASS] sqrt")
        passed += 1
    } otherwise {
        println("  [FAIL] sqrt: expected 4.0, got ${sqrt_val}")
        failed += 1
    }

    // pow
    mut pow_val float = math.pow(2.0, 8.0)
    if pow_val == 256.0 {
        println("  [PASS] pow")
        passed += 1
    } otherwise {
        println("  [FAIL] pow: expected 256.0, got ${pow_val}")
        failed += 1
    }

    // is_even / is_odd
    if math.is_even(4) == true && math.is_even(3) == false {
        println("  [PASS] is_even")
        passed += 1
    } otherwise {
        println("  [FAIL] is_even")
        failed += 1
    }

    if math.is_odd(3) == true && math.is_odd(4) == false {
        println("  [PASS] is_odd")
        passed += 1
    } otherwise {
        println("  [FAIL] is_odd")
        failed += 1
    }

    // clamp
    mut clamped int = math.clamp(15, 0, 10)
    if clamped == 10 {
        println("  [PASS] clamp (above)")
        passed += 1
    } otherwise {
        println("  [FAIL] clamp (above): expected 10, got ${clamped}")
        failed += 1
    }

    // factorial
    mut fact_val int = math.factorial(5)
    if fact_val == 120 {
        println("  [PASS] factorial")
        passed += 1
    } otherwise {
        println("  [FAIL] factorial: expected 120, got ${fact_val}")
        failed += 1
    }

    // round
    mut round_val float = math.round(3.5)
    if round_val == 4.0 {
        println("  [PASS] round")
        passed += 1
    } otherwise {
        println("  [FAIL] round: expected 4.0, got ${round_val}")
        failed += 1
    }

    // PI constant
    if math.PI > 3.14159 && math.PI < 3.14160 {
        println("  [PASS] PI")
        passed += 1
    } otherwise {
        println("  [FAIL] PI: got ${math.PI}")
        failed += 1
    }

    // E constant
    if math.E > 2.718 && math.E < 2.719 {
        println("  [PASS] E")
        passed += 1
    } otherwise {
        println("  [FAIL] E: got ${math.E}")
        failed += 1
    }

    // TAU constant
    if math.TAU > 6.28 && math.TAU < 6.29 {
        println("  [PASS] TAU")
        passed += 1
    } otherwise {
        println("  [FAIL] TAU: got ${math.TAU}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
}
