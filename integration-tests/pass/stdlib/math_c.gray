/*
 * math_c.ez - Comprehensive integration test for @math (compiler)
 * Tests ALL documented functions and constants in the math module.
 */

import @math

do main() {
    println("=== Math Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // --- Basic Arithmetic ---

    // abs
    if math.abs(-5) == 5 && math.abs(5) == 5 && math.abs(0) == 0 {
        println("  [PASS] abs")
        passed += 1
    } otherwise {
        println("  [FAIL] abs")
        failed += 1
    }

    // neg
    mut neg_val int = math.neg(5)
    mut neg_val2 int = math.neg(-3)
    if neg_val == -5 && neg_val2 == 3 {
        println("  [PASS] neg")
        passed += 1
    } otherwise {
        println("  [FAIL] neg: got ${neg_val}, ${neg_val2}")
        failed += 1
    }

    // sign
    mut sign_pos int = math.sign(42)
    mut sign_neg int = math.sign(-7)
    mut sign_zero int = math.sign(0)
    if sign_pos == 1 && sign_neg == -1 && sign_zero == 0 {
        println("  [PASS] sign")
        passed += 1
    } otherwise {
        println("  [FAIL] sign: got ${sign_pos}, ${sign_neg}, ${sign_zero}")
        failed += 1
    }

    // --- Min/Max/Clamp ---

    // min
    if math.min(3, 7) == 3 && math.min(7, 3) == 3 && math.min(5, 5) == 5 {
        println("  [PASS] min")
        passed += 1
    } otherwise {
        println("  [FAIL] min")
        failed += 1
    }

    // max
    if math.max(3, 7) == 7 && math.max(7, 3) == 7 && math.max(5, 5) == 5 {
        println("  [PASS] max")
        passed += 1
    } otherwise {
        println("  [FAIL] max")
        failed += 1
    }

    // clamp
    mut clamp_above int = math.clamp(15, 0, 10)
    mut clamp_below int = math.clamp(-5, 0, 10)
    mut clamp_in int = math.clamp(5, 0, 10)
    if clamp_above == 10 && clamp_below == 0 && clamp_in == 5 {
        println("  [PASS] clamp")
        passed += 1
    } otherwise {
        println("  [FAIL] clamp: got ${clamp_above}, ${clamp_below}, ${clamp_in}")
        failed += 1
    }

    // --- Rounding ---

    // floor
    mut floor_val float = math.floor(3.7)
    mut floor_neg float = math.floor(-2.3)
    if floor_val == 3.0 && floor_neg == -3.0 {
        println("  [PASS] floor")
        passed += 1
    } otherwise {
        println("  [FAIL] floor: got ${floor_val}, ${floor_neg}")
        failed += 1
    }

    // ceil
    mut ceil_val float = math.ceil(3.2)
    mut ceil_neg float = math.ceil(-2.7)
    if ceil_val == 4.0 && ceil_neg == -2.0 {
        println("  [PASS] ceil")
        passed += 1
    } otherwise {
        println("  [FAIL] ceil: got ${ceil_val}, ${ceil_neg}")
        failed += 1
    }

    // round
    mut round_up float = math.round(3.5)
    mut round_down float = math.round(3.4)
    if round_up == 4.0 && round_down == 3.0 {
        println("  [PASS] round")
        passed += 1
    } otherwise {
        println("  [FAIL] round: got ${round_up}, ${round_down}")
        failed += 1
    }

    // trunc
    mut trunc_pos float = math.trunc(3.9)
    mut trunc_neg float = math.trunc(-3.9)
    if trunc_pos == 3.0 && trunc_neg == -3.0 {
        println("  [PASS] trunc")
        passed += 1
    } otherwise {
        println("  [FAIL] trunc: got ${trunc_pos}, ${trunc_neg}")
        failed += 1
    }

    // --- Powers and Roots ---

    // pow
    mut pow_val float = math.pow(2.0, 8.0)
    if pow_val == 256.0 {
        println("  [PASS] pow")
        passed += 1
    } otherwise {
        println("  [FAIL] pow: expected 256.0, got ${pow_val}")
        failed += 1
    }

    // sqrt
    mut sqrt_val float = math.sqrt(16.0)
    mut sqrt_val2 float = math.sqrt(2.0)
    if sqrt_val == 4.0 && sqrt_val2 > 1.414 && sqrt_val2 < 1.415 {
        println("  [PASS] sqrt")
        passed += 1
    } otherwise {
        println("  [FAIL] sqrt: got ${sqrt_val}, ${sqrt_val2}")
        failed += 1
    }

    // cbrt
    mut cbrt_val float = math.cbrt(27.0)
    if cbrt_val > 2.999 && cbrt_val < 3.001 {
        println("  [PASS] cbrt")
        passed += 1
    } otherwise {
        println("  [FAIL] cbrt: expected ~3.0, got ${cbrt_val}")
        failed += 1
    }

    // hypot
    mut hypot_val float = math.hypot(3.0, 4.0)
    if hypot_val == 5.0 {
        println("  [PASS] hypot")
        passed += 1
    } otherwise {
        println("  [FAIL] hypot: expected 5.0, got ${hypot_val}")
        failed += 1
    }

    // exp
    mut exp_val float = math.exp(1.0)
    if exp_val > 2.718 && exp_val < 2.719 {
        println("  [PASS] exp")
        passed += 1
    } otherwise {
        println("  [FAIL] exp: expected ~2.718, got ${exp_val}")
        failed += 1
    }

    // exp2
    mut exp2_val float = math.exp2(3.0)
    if exp2_val == 8.0 {
        println("  [PASS] exp2")
        passed += 1
    } otherwise {
        println("  [FAIL] exp2: expected 8.0, got ${exp2_val}")
        failed += 1
    }

    // --- Logarithms ---

    // log (natural)
    mut log_val float = math.log(math.E)
    if log_val > 0.999 && log_val < 1.001 {
        println("  [PASS] log")
        passed += 1
    } otherwise {
        println("  [FAIL] log: expected ~1.0, got ${log_val}")
        failed += 1
    }

    // log2
    mut log2_val float = math.log2(8.0)
    if log2_val > 2.999 && log2_val < 3.001 {
        println("  [PASS] log2")
        passed += 1
    } otherwise {
        println("  [FAIL] log2: expected ~3.0, got ${log2_val}")
        failed += 1
    }

    // log10
    mut log10_val float = math.log10(1000.0)
    if log10_val > 2.999 && log10_val < 3.001 {
        println("  [PASS] log10")
        passed += 1
    } otherwise {
        println("  [FAIL] log10: expected ~3.0, got ${log10_val}")
        failed += 1
    }

    // log_base
    mut logb_val float = math.log_base(81.0, 3.0)
    if logb_val > 3.999 && logb_val < 4.001 {
        println("  [PASS] log_base")
        passed += 1
    } otherwise {
        println("  [FAIL] log_base: expected ~4.0, got ${logb_val}")
        failed += 1
    }

    // --- Trigonometry ---

    // sin
    mut sin_val float = math.sin(0.0)
    if sin_val > -0.001 && sin_val < 0.001 {
        println("  [PASS] sin")
        passed += 1
    } otherwise {
        println("  [FAIL] sin(0): expected ~0.0, got ${sin_val}")
        failed += 1
    }

    // cos
    mut cos_val float = math.cos(0.0)
    if cos_val > 0.999 && cos_val < 1.001 {
        println("  [PASS] cos")
        passed += 1
    } otherwise {
        println("  [FAIL] cos(0): expected ~1.0, got ${cos_val}")
        failed += 1
    }

    // tan
    mut tan_val float = math.tan(0.0)
    if tan_val > -0.001 && tan_val < 0.001 {
        println("  [PASS] tan")
        passed += 1
    } otherwise {
        println("  [FAIL] tan(0): expected ~0.0, got ${tan_val}")
        failed += 1
    }

    // asin
    mut asin_val float = math.asin(1.0)
    mut half_pi float = math.PI / 2.0
    if asin_val > half_pi - 0.001 && asin_val < half_pi + 0.001 {
        println("  [PASS] asin")
        passed += 1
    } otherwise {
        println("  [FAIL] asin(1): expected ~pi/2, got ${asin_val}")
        failed += 1
    }

    // acos
    mut acos_val float = math.acos(1.0)
    if acos_val > -0.001 && acos_val < 0.001 {
        println("  [PASS] acos")
        passed += 1
    } otherwise {
        println("  [FAIL] acos(1): expected ~0.0, got ${acos_val}")
        failed += 1
    }

    // atan
    mut atan_val float = math.atan(0.0)
    if atan_val > -0.001 && atan_val < 0.001 {
        println("  [PASS] atan")
        passed += 1
    } otherwise {
        println("  [FAIL] atan(0): expected ~0.0, got ${atan_val}")
        failed += 1
    }

    // atan2
    mut atan2_val float = math.atan2(1.0, 1.0)
    mut quarter_pi float = math.PI / 4.0
    if atan2_val > quarter_pi - 0.001 && atan2_val < quarter_pi + 0.001 {
        println("  [PASS] atan2")
        passed += 1
    } otherwise {
        println("  [FAIL] atan2(1,1): expected ~pi/4, got ${atan2_val}")
        failed += 1
    }

    // sinh
    mut sinh_val float = math.sinh(0.0)
    if sinh_val > -0.001 && sinh_val < 0.001 {
        println("  [PASS] sinh")
        passed += 1
    } otherwise {
        println("  [FAIL] sinh(0): expected ~0.0, got ${sinh_val}")
        failed += 1
    }

    // cosh
    mut cosh_val float = math.cosh(0.0)
    if cosh_val > 0.999 && cosh_val < 1.001 {
        println("  [PASS] cosh")
        passed += 1
    } otherwise {
        println("  [FAIL] cosh(0): expected ~1.0, got ${cosh_val}")
        failed += 1
    }

    // tanh
    mut tanh_val float = math.tanh(0.0)
    if tanh_val > -0.001 && tanh_val < 0.001 {
        println("  [PASS] tanh")
        passed += 1
    } otherwise {
        println("  [FAIL] tanh(0): expected ~0.0, got ${tanh_val}")
        failed += 1
    }

    // --- Statistical ---

    // factorial
    mut fact_val int = math.factorial(5)
    mut fact_zero int = math.factorial(0)
    if fact_val == 120 && fact_zero == 1 {
        println("  [PASS] factorial")
        passed += 1
    } otherwise {
        println("  [FAIL] factorial: got ${fact_val}, ${fact_zero}")
        failed += 1
    }

    // gcd
    mut gcd_val int = math.gcd(12, 8)
    if gcd_val == 4 {
        println("  [PASS] gcd")
        passed += 1
    } otherwise {
        println("  [FAIL] gcd: expected 4, got ${gcd_val}")
        failed += 1
    }

    // lcm
    mut lcm_val int = math.lcm(4, 6)
    if lcm_val == 12 {
        println("  [PASS] lcm")
        passed += 1
    } otherwise {
        println("  [FAIL] lcm: expected 12, got ${lcm_val}")
        failed += 1
    }

    // --- Number Properties ---

    // is_prime
    if math.is_prime(7) == true && math.is_prime(4) == false && math.is_prime(2) == true {
        println("  [PASS] is_prime")
        passed += 1
    } otherwise {
        println("  [FAIL] is_prime")
        failed += 1
    }

    // is_even
    if math.is_even(4) == true && math.is_even(3) == false {
        println("  [PASS] is_even")
        passed += 1
    } otherwise {
        println("  [FAIL] is_even")
        failed += 1
    }

    // is_odd
    if math.is_odd(3) == true && math.is_odd(4) == false {
        println("  [PASS] is_odd")
        passed += 1
    } otherwise {
        println("  [FAIL] is_odd")
        failed += 1
    }

    // is_infinite
    if math.is_infinite(math.INF) == true && math.is_infinite(1.0) == false {
        println("  [PASS] is_infinite")
        passed += 1
    } otherwise {
        println("  [FAIL] is_infinite")
        failed += 1
    }

    // is_finite
    if math.is_finite(1.0) == true && math.is_finite(math.INF) == false {
        println("  [PASS] is_finite")
        passed += 1
    } otherwise {
        println("  [FAIL] is_finite")
        failed += 1
    }

    // is_nan - use 0.0/0.0 trick won't work due to div-by-zero panic, use INF - INF
    // Actually we can't easily produce NaN in EZ without a math function that returns it
    // Let's just test the false case
    if math.is_nan(1.0) == false && math.is_nan(math.INF) == false {
        println("  [PASS] is_nan")
        passed += 1
    } otherwise {
        println("  [FAIL] is_nan")
        failed += 1
    }

    // deg_to_rad
    mut rad_val float = math.deg_to_rad(180.0)
    if rad_val > math.PI - 0.001 && rad_val < math.PI + 0.001 {
        println("  [PASS] deg_to_rad")
        passed += 1
    } otherwise {
        println("  [FAIL] deg_to_rad(180): expected ~PI, got ${rad_val}")
        failed += 1
    }

    // rad_to_deg
    mut deg_val float = math.rad_to_deg(math.PI)
    if deg_val > 179.999 && deg_val < 180.001 {
        println("  [PASS] rad_to_deg")
        passed += 1
    } otherwise {
        println("  [FAIL] rad_to_deg(PI): expected ~180, got ${deg_val}")
        failed += 1
    }

    // --- Utility ---

    // lerp
    mut lerp_val float = math.lerp(0.0, 10.0, 0.5)
    if lerp_val > 4.999 && lerp_val < 5.001 {
        println("  [PASS] lerp")
        passed += 1
    } otherwise {
        println("  [FAIL] lerp: expected ~5.0, got ${lerp_val}")
        failed += 1
    }

    // distance
    mut dist_val float = math.distance(0.0, 0.0, 3.0, 4.0)
    if dist_val > 4.999 && dist_val < 5.001 {
        println("  [PASS] distance")
        passed += 1
    } otherwise {
        println("  [FAIL] distance: expected ~5.0, got ${dist_val}")
        failed += 1
    }

    // --- Constants ---

    // PI
    if math.PI > 3.14159 && math.PI < 3.14160 {
        println("  [PASS] PI")
        passed += 1
    } otherwise {
        println("  [FAIL] PI: got ${math.PI}")
        failed += 1
    }

    // E
    if math.E > 2.718 && math.E < 2.719 {
        println("  [PASS] E")
        passed += 1
    } otherwise {
        println("  [FAIL] E: got ${math.E}")
        failed += 1
    }

    // PHI
    if math.PHI > 1.618 && math.PHI < 1.619 {
        println("  [PASS] PHI")
        passed += 1
    } otherwise {
        println("  [FAIL] PHI: got ${math.PHI}")
        failed += 1
    }

    // SQRT2
    if math.SQRT2 > 1.414 && math.SQRT2 < 1.415 {
        println("  [PASS] SQRT2")
        passed += 1
    } otherwise {
        println("  [FAIL] SQRT2: got ${math.SQRT2}")
        failed += 1
    }

    // LN2
    if math.LN2 > 0.693 && math.LN2 < 0.694 {
        println("  [PASS] LN2")
        passed += 1
    } otherwise {
        println("  [FAIL] LN2: got ${math.LN2}")
        failed += 1
    }

    // LN10
    if math.LN10 > 2.302 && math.LN10 < 2.303 {
        println("  [PASS] LN10")
        passed += 1
    } otherwise {
        println("  [FAIL] LN10: got ${math.LN10}")
        failed += 1
    }

    // TAU
    if math.TAU > 6.283 && math.TAU < 6.284 {
        println("  [PASS] TAU")
        passed += 1
    } otherwise {
        println("  [FAIL] TAU: got ${math.TAU}")
        failed += 1
    }

    // INF
    if math.INF > 999999999.0 {
        println("  [PASS] INF")
        passed += 1
    } otherwise {
        println("  [FAIL] INF")
        failed += 1
    }

    // NEG_INF
    if math.NEG_INF < -999999999.0 {
        println("  [PASS] NEG_INF")
        passed += 1
    } otherwise {
        println("  [FAIL] NEG_INF")
        failed += 1
    }

    // EPSILON
    if math.EPSILON > 0.0 && math.EPSILON < 0.001 {
        println("  [PASS] EPSILON")
        passed += 1
    } otherwise {
        println("  [FAIL] EPSILON: got ${math.EPSILON}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
        exit(1)
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
