/*
 * net_c.ez - Integration test for @net (compiler)
 */

import @std
import @net
using std

do main() {
    mut pass int = 0
    mut fail int = 0

    // DNS resolve
    mut ip = net.resolve("localhost")
    if ip == "127.0.0.1" { pass += 1 } otherwise { fail += 1 }

    // TCP listen and close (port 0 = any available)
    mut listener = net.listen(0)
    net.close(listener)
    pass += 1

    println("net: ${pass} passed, ${fail} failed")
    if fail > 0 { std.exit(1) }
}
