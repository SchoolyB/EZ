/*
 * Test: net module _result variants for error handling
 * Tests resolve, connect, and listen with multi-var destructuring.
 */

import @net

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: net.resolve success
    mut resolved, err = net.resolve("localhost")
    if err == nil {
        println("  [PASS] net.resolve success, addr='${resolved}'")
        passed += 1
    } otherwise {
        println("  [FAIL] net.resolve error on localhost")
        failed += 1
    }

    // Test 2: net.resolve error on invalid hostname
    mut addr2, err2 = net.resolve("this.host.definitely.does.not.exist.invalid")
    if err2 != nil {
        println("  [PASS] net.resolve error caught on invalid hostname")
        passed += 1
    } otherwise {
        println("  [FAIL] net.resolve no error, addr='${addr2}'")
        failed += 1
    }

    // Test 3: net.connect error on refused port
    mut fd, err3 = net.connect("127.0.0.1", 59999)
    if err3 != nil {
        println("  [PASS] net.connect error caught on refused port")
        passed += 1
    } otherwise {
        println("  [FAIL] net.connect no error")
        net.close(fd)
        failed += 1
    }

    // Test 4: net.listen success on ephemeral port
    mut sock, err4 = net.listen(0)
    if err4 == nil {
        println("  [PASS] net.listen success on ephemeral port")
        net.close(sock)
        passed += 1
    } otherwise {
        println("  [FAIL] net.listen error on ephemeral port")
        failed += 1
    }

    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
