/*
 * os_c.ez - Integration test for @os (compiler)
 */

import @os

do main() {
    println("=== OS Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // args returns an array
    mut args [string] = os.args()
    if len(args) >= 0 {
        println("  [PASS] args (${len(args)} entries)")
        passed += 1
    } otherwise {
        println("  [FAIL] args")
        failed += 1
    }

    // cwd returns a non-empty string
    mut cwd string = os.current_dir()
    if len(cwd) > 0 {
        println("  [PASS] cwd (${cwd})")
        passed += 1
    } otherwise {
        println("  [FAIL] cwd")
        failed += 1
    }

    // get_env — PATH exists on all systems
    mut path_val string = os.get_env("PATH")
    if len(path_val) > 0 {
        println("  [PASS] get_env PATH")
        passed += 1
    } otherwise {
        println("  [FAIL] get_env PATH")
        failed += 1
    }

    // hostname returns a non-empty string
    mut host string = os.hostname()
    if len(host) > 0 {
        println("  [PASS] hostname (${host})")
        passed += 1
    } otherwise {
        println("  [FAIL] hostname")
        failed += 1
    }

    // current_os returns an int
    mut os_val int = os.current_os()
    if os_val >= 0 {
        println("  [PASS] current_os (${os_val})")
        passed += 1
    } otherwise {
        println("  [FAIL] current_os: got ${os_val}")
        failed += 1
    }

    // arch returns a non-empty string
    mut arch_val string = os.arch()
    if len(arch_val) > 0 {
        println("  [PASS] arch (${arch_val})")
        passed += 1
    } otherwise {
        println("  [FAIL] arch")
        failed += 1
    }

    // pid returns a positive int
    mut pid_val int = os.pid()
    if pid_val > 0 {
        println("  [PASS] pid (${pid_val})")
        passed += 1
    } otherwise {
        println("  [FAIL] pid: got ${pid_val}")
        failed += 1
    }

    // exec: stdout capture — 'echo' writes to stdout
    mut code, stdout, _, ok = os.exec("echo", {"hello"})
    if ok && code == 0 && len(stdout) > 0 {
        println("  [PASS] exec stdout capture (captured ${len(stdout)} bytes)")
        passed += 1
    } otherwise {
        println("  [FAIL] exec stdout capture: code=${code} ok=${ok} stdout_len=${len(stdout)}")
        failed += 1
    }

    // exec: success — 'true' exits 0 with no output
    mut code2, _, _, ok2 = os.exec("true", {})
    if ok2 && code2 == 0 {
        println("  [PASS] exec success (code=0, ok=true)")
        passed += 1
    } otherwise {
        println("  [FAIL] exec success: code=${code2} ok=${ok2}")
        failed += 1
    }

    // exec: non-zero exit — 'false' exits 1, ok still true
    mut code3, _, _, ok3 = os.exec("false", {})
    if ok3 && code3 != 0 {
        println("  [PASS] exec non-zero exit (code=${code3}, ok=true)")
        passed += 1
    } otherwise {
        println("  [FAIL] exec non-zero exit: code=${code3} ok=${ok3}")
        failed += 1
    }

    // exec: stderr capture — ls on a nonexistent path writes to stderr
    mut code4, _, stderr4, ok4 = os.exec("ls", {"/nonexistent_ez_test_path_xyz"})
    if ok4 && code4 != 0 && len(stderr4) > 0 {
        println("  [PASS] exec stderr capture (captured ${len(stderr4)} bytes)")
        passed += 1
    } otherwise {
        println("  [FAIL] exec stderr capture: code=${code4} ok=${ok4} stderr_len=${len(stderr4)}")
        failed += 1
    }

    // exec: launch failure — command not found returns ok=false
    mut code5, _, _, ok5 = os.exec("this_cmd_does_not_exist_ez", {})
    if !ok5 {
        println("  [PASS] exec launch failure (ok=false)")
        passed += 1
    } otherwise {
        println("  [FAIL] exec launch failure: expected ok=false, got code=${code5}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
    println("ALL TESTS PASSED")
}
