/*
 * random_seed.ez - Test random.seed() explicit seeding
 * Covers: random.seed(int) wired in #1580
 */

import @random

do main() {
    println("=== random.seed Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: seed produces deterministic output
    random.seed(42)
    mut a int = random.rand_int(1000)
    random.seed(42)
    mut b int = random.rand_int(1000)
    if a == b {
        println("  [PASS] same seed produces same value")
        passed += 1
    } otherwise {
        println("  [FAIL] same seed: got ${a} vs ${b}")
        failed += 1
    }

    // Test 2: different seeds produce different output (statistical)
    random.seed(1)
    mut c int = random.rand_int(1000000)
    random.seed(999)
    mut d int = random.rand_int(1000000)
    if c != d {
        println("  [PASS] different seeds produce different values")
        passed += 1
    } otherwise {
        println("  [FAIL] different seeds produced same value: ${c}")
        failed += 1
    }

    // Test 3: seed with zero
    random.seed(0)
    mut e int = random.rand_int(100)
    if e >= 0 && e < 100 {
        println("  [PASS] seed(0) still produces valid rand_int")
        passed += 1
    } otherwise {
        println("  [FAIL] seed(0) rand_int out of range: ${e}")
        failed += 1
    }

    // Test 4: seed then rand_float still works
    random.seed(42)
    mut f float = random.rand_float()
    if f >= 0.0 && f < 1.0 {
        println("  [PASS] seed then rand_float in range")
        passed += 1
    } otherwise {
        println("  [FAIL] seed then rand_float: got ${f}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
