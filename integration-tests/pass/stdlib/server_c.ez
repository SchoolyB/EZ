/*
 * server_c.ez - Integration test for @server (compiler)
 * NOTE: Does not call server.listen() since that blocks.
 * Tests router creation and response helpers only.
 */

import @server

do handler() {
    // placeholder handler
}

do main() {
    println("=== Server Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // router creation
    mut r = server.add_router()
    println("  [PASS] router()")
    passed += 1

    // route registration (does not start server)
    server.add_route(r, "GET", "/test", ()handler)
    println("  [PASS] route()")
    passed += 1

    // text response helper
    mut resp = server.text(200, "hello")
    println("  [PASS] text()")
    passed += 1

    // json response helper
    mut resp2 = server.json(200, "{\"ok\": true}")
    println("  [PASS] json()")
    passed += 1

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
}
