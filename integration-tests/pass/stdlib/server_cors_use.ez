/*
 * server_cors_use.ez - Test server.cors()
 * Covers: server.cors() wired in #1580
 * NOTE: Does not call server.listen() since that blocks.
 *       server.use() requires EzMiddleware function signature
 *       not expressible in EZ user code, so only cors is tested here.
 */

import @server

do handler() {
    // placeholder
}

do main() {
    println("=== server.cors Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: cors with wildcard origin
    mut r = server.add_router()
    server.cors(r, "*")
    println("  [PASS] server.cors(router, \"*\")")
    passed += 1

    // Test 2: cors with specific origin
    mut r2 = server.add_router()
    server.cors(r2, "http://example.com")
    println("  [PASS] server.cors(router, specific origin)")
    passed += 1

    // Test 3: cors + route together
    mut r3 = server.add_router()
    server.cors(r3, "*")
    server.add_route(r3, "GET", "/health", ()handler)
    println("  [PASS] cors + route on same router")
    passed += 1

    // Test 4: cors with empty origin string
    mut r4 = server.add_router()
    server.cors(r4, "")
    println("  [PASS] server.cors with empty origin")
    passed += 1

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
