/*
 * std_c.ez - Integration test for @std (compiler)
 */

import @std
using std

do main() {
    println("=== Std Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // println works (if we get here, it works)
    println("  [PASS] println")
    passed += 1

    // to_string int
    mut s1 string = to_string(42)
    if s1 == "42" {
        println("  [PASS] to_string(int)")
        passed += 1
    } otherwise {
        println("  [FAIL] to_string(int): got ${s1}")
        failed += 1
    }

    // to_string bool
    mut s2 string = to_string(true)
    if s2 == "true" {
        println("  [PASS] to_string(bool)")
        passed += 1
    } otherwise {
        println("  [FAIL] to_string(bool): got ${s2}")
        failed += 1
    }

    // to_string float
    mut s3 string = to_string(3.14)
    if len(s3) > 0 {
        println("  [PASS] to_string(float)")
        passed += 1
    } otherwise {
        println("  [FAIL] to_string(float): empty")
        failed += 1
    }

    // assert (should not panic)
    assert(true, "this should not fail")
    println("  [PASS] assert(true)")
    passed += 1

    // typeof
    mut t1 string = typeof(42)
    if t1 == "int" {
        println("  [PASS] typeof(int)")
        passed += 1
    } otherwise {
        println("  [FAIL] typeof(int): got ${t1}")
        failed += 1
    }

    // len on string
    if len("hello") == 5 {
        println("  [PASS] len(string)")
        passed += 1
    } otherwise {
        println("  [FAIL] len(string)")
        failed += 1
    }

    // len on array
    mut arr [int] = {1, 2, 3}
    if len(arr) == 3 {
        println("  [PASS] len(array)")
        passed += 1
    } otherwise {
        println("  [FAIL] len(array)")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
}
