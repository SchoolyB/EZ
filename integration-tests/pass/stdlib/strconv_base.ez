/*
 * Test: strconv module base parameter for to_int/to_uint (#1603)
 * Verifies base conversion with constants and raw int values.
 */

import @strconv

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: base 16 with raw int
    mut hex, _ = strconv.to_int("FF", 16)
    if hex == 255 {
        println("  [PASS] to_int(\"FF\", 16) = 255")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"FF\", 16) = ${hex}")
        failed += 1
    }

    // Test 2: base 2 with raw int
    mut bin, _ = strconv.to_int("1010", 2)
    if bin == 10 {
        println("  [PASS] to_int(\"1010\", 2) = 10")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"1010\", 2) = ${bin}")
        failed += 1
    }

    // Test 3: base 8 with raw int
    mut oct, _ = strconv.to_int("77", 8)
    if oct == 63 {
        println("  [PASS] to_int(\"77\", 8) = 63")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"77\", 8) = ${oct}")
        failed += 1
    }

    // Test 4: BASE_16 constant
    mut h2, _ = strconv.to_int("1A", strconv.BASE_16)
    if h2 == 26 {
        println("  [PASS] to_int(\"1A\", BASE_16) = 26")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"1A\", BASE_16) = ${h2}")
        failed += 1
    }

    // Test 5: BASE_2 constant
    mut b2, _ = strconv.to_int("1111", strconv.BASE_2)
    if b2 == 15 {
        println("  [PASS] to_int(\"1111\", BASE_2) = 15")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"1111\", BASE_2) = ${b2}")
        failed += 1
    }

    // Test 6: BASE_8 constant
    mut b8, _ = strconv.to_int("17", strconv.BASE_8)
    if b8 == 15 {
        println("  [PASS] to_int(\"17\", BASE_8) = 15")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"17\", BASE_8) = ${b8}")
        failed += 1
    }

    // Test 7: BASE_36 constant
    mut b36, _ = strconv.to_int("Z", strconv.BASE_36)
    if b36 == 35 {
        println("  [PASS] to_int(\"Z\", BASE_36) = 35")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"Z\", BASE_36) = ${b36}")
        failed += 1
    }

    // Test 8: to_uint with base 16
    mut uhex, _ = strconv.to_uint("FF", strconv.BASE_16)
    if uhex == 255 {
        println("  [PASS] to_uint(\"FF\", BASE_16) = 255")
        passed += 1
    } otherwise {
        println("  [FAIL] to_uint(\"FF\", BASE_16) unexpected")
        failed += 1
    }

    // Test 9: default base (no second arg) = base 10
    mut dec, _ = strconv.to_int("42")
    if dec == 42 {
        println("  [PASS] to_int(\"42\") default = 42")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"42\") default = ${dec}")
        failed += 1
    }

    // Test 10: multi-var with base
    mut val, err = strconv.to_int("FF", strconv.BASE_16)
    if err == nil {
        if val == 255 {
            println("  [PASS] to_int result(\"FF\", BASE_16) = 255")
            passed += 1
        } otherwise {
            println("  [FAIL] to_int result(\"FF\", BASE_16) = ${val}")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] to_int result(\"FF\", BASE_16) returned error")
        failed += 1
    }

    // Test 11: multi-var error with base (invalid digit for base)
    mut val2, err2 = strconv.to_int("GG", strconv.BASE_16)
    if err2 != nil {
        println("  [PASS] to_int result(\"GG\", BASE_16) returned error")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int result(\"GG\", BASE_16) no error, val=${val2}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
