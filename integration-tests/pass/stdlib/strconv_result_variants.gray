/*
 * Test: strconv module _result variants for error handling (#1603)
 * Verifies multi-var destructuring works for all fallible strconv functions.
 */

import @strconv

do main() {
    mut passed int = 0
    mut failed int = 0

    // Test 1: to_int success path
    mut val1, err1 = strconv.to_int("123")
    if err1 == nil {
        if val1 == 123 {
            println("  [PASS] to_int(\"123\") success = 123")
            passed += 1
        } otherwise {
            println("  [FAIL] to_int(\"123\") value = ${val1}")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] to_int(\"123\") returned error")
        failed += 1
    }

    // Test 2: to_int error path
    mut val2, err2 = strconv.to_int("abc")
    if err2 != nil {
        println("  [PASS] to_int(\"abc\") returned error")
        passed += 1
    } otherwise {
        println("  [FAIL] to_int(\"abc\") no error, val=${val2}")
        failed += 1
    }

    // Test 3: to_uint success path
    mut val3, err3 = strconv.to_uint("456")
    if err3 == nil {
        if val3 == 456 {
            println("  [PASS] to_uint(\"456\") success = 456")
            passed += 1
        } otherwise {
            println("  [FAIL] to_uint(\"456\") unexpected value")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] to_uint(\"456\") returned error")
        failed += 1
    }

    // Test 4: to_uint error path (negative)
    mut val4, err4 = strconv.to_uint("-5")
    if err4 != nil {
        println("  [PASS] to_uint(\"-5\") returned error (negative)")
        passed += 1
    } otherwise {
        println("  [FAIL] to_uint(\"-5\") no error, val=${val4}")
        failed += 1
    }

    // Test 5: to_uint error path (non-numeric)
    mut val5, err5 = strconv.to_uint("xyz")
    if err5 != nil {
        println("  [PASS] to_uint(\"xyz\") returned error")
        passed += 1
    } otherwise {
        println("  [FAIL] to_uint(\"xyz\") no error, val=${val5}")
        failed += 1
    }

    // Test 6: to_float success path
    mut val6, err6 = strconv.to_float("2.718")
    if err6 == nil {
        if val6 > 2.71 {
            println("  [PASS] to_float(\"2.718\") success")
            passed += 1
        } otherwise {
            println("  [FAIL] to_float(\"2.718\") value too small")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] to_float(\"2.718\") returned error")
        failed += 1
    }

    // Test 7: to_float error path
    mut val7, err7 = strconv.to_float("not_a_number")
    if err7 != nil {
        println("  [PASS] to_float(\"not_a_number\") returned error")
        passed += 1
    } otherwise {
        println("  [FAIL] to_float(\"not_a_number\") no error, val=${val7}")
        failed += 1
    }

    // Test 8: to_bool success path (true)
    mut val8, err8 = strconv.to_bool("true")
    if err8 == nil {
        if val8 == true {
            println("  [PASS] to_bool(\"true\") success = true")
            passed += 1
        } otherwise {
            println("  [FAIL] to_bool(\"true\") value = false")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] to_bool(\"true\") returned error")
        failed += 1
    }

    // Test 9: to_bool success path (FALSE - case insensitive)
    mut val9, err9 = strconv.to_bool("FALSE")
    if err9 == nil {
        if val9 == false {
            println("  [PASS] to_bool(\"FALSE\") success = false")
            passed += 1
        } otherwise {
            println("  [FAIL] to_bool(\"FALSE\") value = true")
            failed += 1
        }
    } otherwise {
        println("  [FAIL] to_bool(\"FALSE\") returned error")
        failed += 1
    }

    // Test 10: to_bool error path
    mut val10, err10 = strconv.to_bool("maybe")
    if err10 != nil {
        println("  [PASS] to_bool(\"maybe\") returned error")
        passed += 1
    } otherwise {
        println("  [FAIL] to_bool(\"maybe\") no error, val=${val10}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
