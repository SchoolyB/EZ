/*
 * sync_c.gray - Integration test for the sync module (compiler)
 *
 * Covers: mutex(), lock, unlock, destroy
 */

import @sync

do main() {
    println("=== Sync Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: create mutex
    mut m = sync.mutex()
    println("  [PASS] sync.mutex() creates mutex")
    passed += 1

    // Test 2: lock and unlock
    sync.lock(m)
    sync.unlock(m)
    println("  [PASS] sync.lock/unlock")
    passed += 1

    // Test 3: lock, modify shared state, unlock
    mut counter int = 0
    sync.lock(m)
    counter += 1
    counter += 1
    counter += 1
    sync.unlock(m)
    if counter == 3 {
        println("  [PASS] protected counter increment")
        passed += 1
    } otherwise {
        println("  [FAIL] counter: expected 3, got ${counter}")
        failed += 1
    }

    // Test 4: re-lock after unlock
    sync.lock(m)
    counter = 0
    sync.unlock(m)
    if counter == 0 {
        println("  [PASS] re-lock and reset")
        passed += 1
    } otherwise {
        println("  [FAIL] re-lock: expected 0, got ${counter}")
        failed += 1
    }

    // Test 5: destroy mutex
    sync.destroy(m)
    println("  [PASS] sync.destroy")
    passed += 1

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
