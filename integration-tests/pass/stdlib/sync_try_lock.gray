/*
 * sync_try_lock.gray - Test sync.try_lock() non-blocking lock
 * Covers: sync.try_lock() wired + return type fixed (void->bool)
 */

import @sync

do main() {
    println("=== sync.try_lock Test ===")
    mut passed int = 0
    mut failed int = 0

    // Test 1: try_lock on unlocked mutex succeeds
    mut m = sync.mutex()
    mut got_lock bool = sync.try_lock(m)
    if got_lock == true {
        println("  [PASS] try_lock on unlocked mutex returns true")
        passed += 1
    } otherwise {
        println("  [FAIL] try_lock on unlocked mutex returned false")
        failed += 1
    }
    sync.unlock(m)

    // Test 2: try_lock returns bool (can use in if)
    if sync.try_lock(m) {
        println("  [PASS] try_lock usable as bool in if")
        passed += 1
        sync.unlock(m)
    } otherwise {
        println("  [FAIL] try_lock returned false unexpectedly")
        failed += 1
    }

    // Test 3: lock, then try_lock from same thread
    // Note: behavior is platform-dependent for recursive locks,
    // but we can at least verify it compiles and returns a bool
    sync.lock(m)
    mut second bool = sync.try_lock(m)
    // Whether this is true or false depends on mutex type, just verify it's a bool
    if second == true || second == false {
        println("  [PASS] try_lock on locked mutex returns bool")
        passed += 1
    } otherwise {
        println("  [FAIL] try_lock did not return bool")
        failed += 1
    }
    sync.unlock(m)

    // Test 4: try_lock after unlock succeeds
    mut after_unlock bool = sync.try_lock(m)
    if after_unlock == true {
        println("  [PASS] try_lock after unlock succeeds")
        passed += 1
    } otherwise {
        println("  [FAIL] try_lock after unlock returned false")
        failed += 1
    }
    sync.unlock(m)

    sync.destroy(m)

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
