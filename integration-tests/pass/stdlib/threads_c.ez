/*
 * threads_c.ez - Integration test for @threads (compiler)
 */

import @threads
import @sync
import @channels

do worker() {
    // simple worker function
}

do main() {
    println("=== Threads Module Test ===")
    mut passed int = 0
    mut failed int = 0

    // spawn and join
    mut t = threads.spawn(()worker)
    threads.join(t)
    println("  [PASS] spawn + join")
    passed += 1

    // mutex create, lock, unlock
    mut m = sync.mutex()
    sync.lock(m)
    sync.unlock(m)
    println("  [PASS] mutex lock/unlock")
    passed += 1

    // channel send/recv
    mut ch = channels.open(1)
    channels.send(ch, 42)
    mut val int = channels.receive(ch)
    if val == 42 {
        println("  [PASS] channel send/recv")
        passed += 1
    } otherwise {
        println("  [FAIL] channel: expected 42, got ${val}")
        failed += 1
    }

    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        panic("Some tests failed!")
    }
}
