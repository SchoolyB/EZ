/* Stress test: Boundary and degenerate cases (Section 12)
 * Expected: all tests pass
 */

import @arrays

// Empty function body
do noop() { }

do func1() -> int { return 1 }
do func2() -> int { return 2 }
do func3() -> int { return 3 }
do func4() -> int { return 4 }
do func5() -> int { return 5 }
do func6() -> int { return 6 }
do func7() -> int { return 7 }
do func8() -> int { return 8 }
do func9() -> int { return 9 }
do func10() -> int { return 10 }
do func11() -> int { return 11 }
do func12() -> int { return 12 }
do func13() -> int { return 13 }
do func14() -> int { return 14 }
do func15() -> int { return 15 }
do func16() -> int { return 16 }
do func17() -> int { return 17 }
do func18() -> int { return 18 }
do func19() -> int { return 19 }
do func20() -> int { return 20 }

do main() {
    println("=== Stress: Boundary Cases ===")
    mut passed int = 0
    mut failed int = 0

    // Empty function body
    noop()
    println("  [PASS] empty function body")
    passed += 1

    // File with 20+ functions
    mut sum int = func1() + func2() + func3() + func4() + func5() + func6() + func7() + func8() + func9() + func10()
    sum += func11() + func12() + func13() + func14() + func15() + func16() + func17() + func18() + func19() + func20()
    if sum == 210 {
        println("  [PASS] 20+ functions in file")
        passed += 1
    } otherwise { println("  [FAIL] 20 functions — got ${sum}") failed += 1 }

    // Deeply nested blocks: 10+ levels
    mut depth_ok bool = false
    if true {
        if true {
            if true {
                if true {
                    if true {
                        if true {
                            if true {
                                if true {
                                    if true {
                                        if true {
                                            depth_ok = true
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    if depth_ok {
        println("  [PASS] 10 levels deep nesting")
        passed += 1
    } otherwise { println("  [FAIL] deep nesting") failed += 1 }

    // Array with 1000 elements
    mut big_arr [int] = {}
    for i in range(0, 1000) {
        arrays.append(big_arr, i)
    }
    if len(big_arr) == 1000 && big_arr[999] == 999 {
        println("  [PASS] array with 1000 elements")
        passed += 1
    } otherwise { println("  [FAIL] 1000 element array") failed += 1 }

    // Long string
    mut long_str string = ""
    for i in range(0, 100) {
        long_str = "${long_str}abcdefghij"
    }
    if len(long_str) == 1000 {
        println("  [PASS] string with 1000 characters")
        passed += 1
    } otherwise { println("  [FAIL] long string — len ${len(long_str)}") failed += 1 }

    // Long identifier (Grayscale allows long names)
    mut this_is_a_very_long_variable_name_that_tests_the_compilers_ability_to_handle_long_identifiers int = 42
    if this_is_a_very_long_variable_name_that_tests_the_compilers_ability_to_handle_long_identifiers == 42 {
        println("  [PASS] long identifier (93 chars)")
        passed += 1
    } otherwise { println("  [FAIL] long identifier") failed += 1 }

    // Many statements in main
    mut acc int = 0
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    acc += 1
    if acc == 20 {
        println("  [PASS] many statements")
        passed += 1
    } otherwise { println("  [FAIL] many statements") failed += 1 }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 { println("SOME TESTS FAILED") } otherwise { println("ALL TESTS PASSED") }
}
