/* Stress test: Default and mutable parameters (Section 6.4-6.5)
 * Expected: all tests pass
 */

import @arrays

do greet(name string = "World") -> string {
    return "Hello, ${name}!"
}

do add(a int, b int = 10, c int = 100) -> int {
    return a + b + c
}

do modify_int(&n int) {
    n = n * 2
}

do modify_arr(&arr [int]) {
    arrays.append(arr, 99)
}

do main() {
    println("=== Stress: Default & Mutable Params ===")
    mut passed int = 0
    mut failed int = 0

    // Single default
    if greet() == "Hello, World!" && greet("Alice") == "Hello, Alice!" {
        println("  [PASS] single default param")
        passed += 1
    } otherwise { println("  [FAIL] single default") failed += 1 }

    // Multiple defaults
    if add(1) == 111 && add(1, 2) == 103 && add(1, 2, 3) == 6 {
        println("  [PASS] multiple default params")
        passed += 1
    } otherwise { println("  [FAIL] multiple defaults") failed += 1 }

    // Mutable int param
    mut x int = 5
    modify_int(x)
    if x == 10 {
        println("  [PASS] mutable int param (&n)")
        passed += 1
    } otherwise { println("  [FAIL] mutable int — got ${x}") failed += 1 }

    // Mutable array param
    mut arr [int] = {1, 2, 3}
    modify_arr(arr)
    if len(arr) == 4 && arr[3] == 99 {
        println("  [PASS] mutable array param (&arr)")
        passed += 1
    } otherwise { println("  [FAIL] mutable array") failed += 1 }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 { println("SOME TESTS FAILED") } otherwise { println("ALL TESTS PASSED") }
}
