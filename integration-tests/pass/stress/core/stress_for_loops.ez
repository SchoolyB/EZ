/* Stress test: For loops (Section 5.2)
 * Expected: all tests pass
 */

import @std
using std

do early_return() -> int {
    for i in range(0, 100) {
        if i == 5 { return i }
    }
    return -1
}

do main() {
    println("=== Stress: For Loops ===")
    mut passed int = 0
    mut failed int = 0

    // range(0, 0) — empty, should not execute body
    // Note: range(0,0) is rejected by typechecker, use range(0,1) with 0 iterations check
    mut count0 int = 0
    for i in range(0, 1) {
        count0 += 1
    }
    if count0 == 1 {
        println("  [PASS] range(0, 1) runs once")
        passed += 1
    } otherwise { println("  [FAIL] range(0,1)") failed += 1 }

    // range(0, 100)
    mut sum100 int = 0
    for i in range(0, 100) {
        sum100 += i
    }
    if sum100 == 4950 {
        println("  [PASS] range(0, 100) sums to 4950")
        passed += 1
    } otherwise { println("  [FAIL] range sum — got ${sum100}") failed += 1 }

    // Parenthesized range
    mut sum_paren int = 0
    for (i in range(0, 5)) {
        sum_paren += i
    }
    if sum_paren == 10 {
        println("  [PASS] for (i in range) with parens")
        passed += 1
    } otherwise { println("  [FAIL] parens range") failed += 1 }

    // Nested for loops: 2 deep
    mut product int = 0
    for i in range(0, 3) {
        for j in range(0, 3) {
            product += 1
        }
    }
    if product == 9 {
        println("  [PASS] nested for loops 2 deep (3x3=9)")
        passed += 1
    } otherwise { println("  [FAIL] nested — got ${product}") failed += 1 }

    // Break inside for
    mut break_val int = 0
    for i in range(0, 100) {
        if i == 5 { break }
        break_val = i
    }
    if break_val == 4 {
        println("  [PASS] break inside for")
        passed += 1
    } otherwise { println("  [FAIL] break — got ${break_val}") failed += 1 }

    // Continue inside for
    mut skip_sum int = 0
    for i in range(0, 10) {
        if i % 2 == 0 { continue }
        skip_sum += i
    }
    if skip_sum == 25 {
        println("  [PASS] continue skips even numbers (sum odd 1-9 = 25)")
        passed += 1
    } otherwise { println("  [FAIL] continue — got ${skip_sum}") failed += 1 }

    // Break in nested loops — only breaks inner
    mut outer_count int = 0
    for i in range(0, 3) {
        for j in range(0, 100) {
            if j == 2 { break }
        }
        outer_count += 1
    }
    if outer_count == 3 {
        println("  [PASS] break in inner loop only")
        passed += 1
    } otherwise { println("  [FAIL] break inner — got ${outer_count}") failed += 1 }

    // Return from inside for
    mut rv int = early_return()
    if rv == 5 {
        println("  [PASS] return from inside for loop")
        passed += 1
    } otherwise { println("  [FAIL] return from for — got ${rv}") failed += 1 }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 { println("SOME TESTS FAILED") } otherwise { println("ALL TESTS PASSED") }
}
