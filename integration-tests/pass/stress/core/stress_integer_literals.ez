/* Stress test: Integer literal edge cases (Section 1.1)
 * Tests decimal, hex, octal, binary, underscores, bigint
 * Expected: all tests pass
 */

import @std
using std

do main() {
    println("=== Stress: Integer Literals ===")
    mut passed int = 0
    mut failed int = 0

    // Decimal basics
    mut zero int = 0
    mut one int = 1
    mut neg int = -42
    if zero == 0 && one == 1 && neg == -42 {
        println("  [PASS] decimal basics")
        passed += 1
    } otherwise {
        println("  [FAIL] decimal basics")
        failed += 1
    }

    // Max i64
    mut max64 int = 9223372036854775807
    if max64 == 9223372036854775807 {
        println("  [PASS] max i64 value")
        passed += 1
    } otherwise {
        println("  [FAIL] max i64 value")
        failed += 1
    }

    // Underscored decimals
    mut million int = 1_000_000
    mut trillion int = 1_000_000_000_000
    if million == 1000000 && trillion == 1000000000000 {
        println("  [PASS] underscored decimals")
        passed += 1
    } otherwise {
        println("  [FAIL] underscored decimals")
        failed += 1
    }

    // Hex literals
    mut h0 int = 0x0
    mut hFF int = 0xFF
    mut hDEAD int = 0xDEAD_BEEF
    mut hCAP int = 0XFF
    if h0 == 0 && hFF == 255 && hDEAD == 3735928559 && hCAP == 255 {
        println("  [PASS] hex literals")
        passed += 1
    } otherwise {
        println("  [FAIL] hex literals")
        failed += 1
    }

    // Octal literals
    mut o0 int = 0o0
    mut o777 int = 0o777
    mut oCap int = 0O777
    mut oSep int = 0o1_2_3
    if o0 == 0 && o777 == 511 && oCap == 511 && oSep == 83 {
        println("  [PASS] octal literals")
        passed += 1
    } otherwise {
        println("  [FAIL] octal literals")
        failed += 1
    }

    // Binary literals
    mut b0 int = 0b0
    mut b10 int = 0b1010
    mut bSep int = 0b1111_0000
    if b0 == 0 && b10 == 10 && bSep == 240 {
        println("  [PASS] binary literals")
        passed += 1
    } otherwise {
        println("  [FAIL] binary literals")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
