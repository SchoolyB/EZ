/* Stress test: Type inference (Section 2.5)
 * Expected: all tests pass
 */

import @std
using std

const Color struct {
    r int
    g int
    b int
}

do get_int() -> int { return 42 }
do get_pair() -> (int, string) { return 1, "hello" }

do main() {
    println("=== Stress: Type Inference ===")
    mut passed int = 0
    mut failed int = 0

    // Inferred from literal
    mut a = 42
    if type_of(a) == "int" {
        println("  [PASS] inferred int from literal")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred int")
        failed += 1
    }

    // Inferred from float literal
    mut b = 3.14
    if type_of(b) == "float" {
        println("  [PASS] inferred float from literal")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred float")
        failed += 1
    }

    // Inferred from string literal
    mut c = "hello"
    if type_of(c) == "string" {
        println("  [PASS] inferred string from literal")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred string")
        failed += 1
    }

    // Inferred from bool literal
    mut d = true
    if type_of(d) == "bool" {
        println("  [PASS] inferred bool from literal")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred bool")
        failed += 1
    }

    // Inferred from function return
    mut e = get_int()
    if type_of(e) == "int" && e == 42 {
        println("  [PASS] inferred from function return")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred from function return")
        failed += 1
    }

    // Inferred from struct literal
    mut col = Color{r: 255, g: 0, b: 128}
    if col.r == 255 && col.g == 0 && col.b == 128 {
        println("  [PASS] inferred struct from literal")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred struct")
        failed += 1
    }

    // Inferred from array literal
    mut arr = {1, 2, 3}
    if len(arr) == 3 {
        println("  [PASS] inferred array from literal")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred array")
        failed += 1
    }

    // Inferred from multiple return values
    mut val, name = get_pair()
    if val == 1 && name == "hello" {
        println("  [PASS] inferred from multi-return")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred from multi-return")
        failed += 1
    }

    // Inferred from new(Type)
    mut ptr = new(Color)
    if ptr^.r == 0 {
        println("  [PASS] inferred from new(Type)")
        passed += 1
    } otherwise {
        println("  [FAIL] inferred from new()")
        failed += 1
    }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 {
        println("SOME TESTS FAILED")
    } otherwise {
        println("ALL TESTS PASSED")
    }
}
