/* Stress test: @io — file operations
 * Expected: all tests pass
 */

import @io

do main() {
    println("=== Stress: @io ===")
    mut passed int = 0
    mut failed int = 0

    mut test_path string = "/tmp/ez_stress_io_test.txt"

    // write_file
    mut w_ok, _ = io.write_file(test_path, "hello from EZ")
    if w_ok {
        println("  [PASS] write_file")
        passed += 1
    } otherwise { println("  [FAIL] write_file") failed += 1 }

    // read_file
    mut content, _ = io.read_file(test_path)
    if content == "hello from EZ" {
        println("  [PASS] read_file round-trip")
        passed += 1
    } otherwise { println("  [FAIL] read_file") failed += 1 }

    // file_exists
    if io.file_exists(test_path) {
        println("  [PASS] file_exists")
        passed += 1
    } otherwise { println("  [FAIL] file_exists") failed += 1 }

    // is_file
    if io.is_file(test_path) {
        println("  [PASS] is_file")
        passed += 1
    } otherwise { println("  [FAIL] is_file") failed += 1 }

    // is_directory
    if io.is_directory("/tmp") {
        println("  [PASS] is_directory")
        passed += 1
    } otherwise { println("  [FAIL] is_directory") failed += 1 }

    // delete_file
    mut d_ok, _ = io.delete_file(test_path)
    mut gone bool = io.file_exists(test_path)
    if !gone {
        println("  [PASS] delete_file")
        passed += 1
    } otherwise { println("  [FAIL] delete_file") failed += 1 }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 { println("SOME TESTS FAILED") } otherwise { println("ALL TESTS PASSED") }
}
