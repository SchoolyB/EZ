/* Stress test: @strings — edge cases
 * Expected: all tests pass
 */

import @strings

do main() {
    println("=== Stress: @strings Edge Cases ===")
    mut passed int = 0
    mut failed int = 0

    // Empty string operations
    if strings.to_upper("") == "" && strings.to_lower("") == "" {
        println("  [PASS] to_upper/to_lower empty string")
        passed += 1
    } otherwise { println("  [FAIL] empty case") failed += 1 }

    // trim
    mut trimmed string = strings.trim("  hello  ")
    if trimmed == "hello" {
        println("  [PASS] trim whitespace")
        passed += 1
    } otherwise { println("  [FAIL] trim — got '${trimmed}'") failed += 1 }

    // split single char
    mut parts [string] = strings.split("a,b,c", ",")
    if len(parts) == 3 && parts[0] == "a" && parts[2] == "c" {
        println("  [PASS] split by comma")
        passed += 1
    } otherwise { println("  [FAIL] split") failed += 1 }

    // split not found
    mut no_split [string] = strings.split("hello", "x")
    if len(no_split) == 1 && no_split[0] == "hello" {
        println("  [PASS] split — separator not found")
        passed += 1
    } otherwise { println("  [FAIL] split not found") failed += 1 }

    // join
    mut words [string] = {"hello", "world"}
    mut joined string = strings.join(words, " ")
    if joined == "hello world" {
        println("  [PASS] join with space")
        passed += 1
    } otherwise { println("  [FAIL] join — got '${joined}'") failed += 1 }

    // contains
    if strings.contains("hello world", "world") && !strings.contains("hello", "xyz") {
        println("  [PASS] contains found and not found")
        passed += 1
    } otherwise { println("  [FAIL] contains") failed += 1 }

    // starts_with / ends_with
    if strings.starts_with("hello", "hel") && strings.ends_with("hello", "llo") {
        println("  [PASS] starts_with / ends_with")
        passed += 1
    } otherwise { println("  [FAIL] starts/ends") failed += 1 }

    // index_of
    mut idx int = strings.index_of("hello world", "world")
    if idx == 6 {
        println("  [PASS] index_of found")
        passed += 1
    } otherwise { println("  [FAIL] index_of — got ${idx}") failed += 1 }

    // index_of not found
    mut idx2 int = strings.index_of("hello", "xyz")
    if idx2 == -1 {
        println("  [PASS] index_of not found returns -1")
        passed += 1
    } otherwise { println("  [FAIL] index_of not found — got ${idx2}") failed += 1 }

    // replace
    mut replaced string = strings.replace("hello world", "world", "EZ")
    if replaced == "hello EZ" {
        println("  [PASS] replace")
        passed += 1
    } otherwise { println("  [FAIL] replace — got '${replaced}'") failed += 1 }

    // repeat
    mut rep0 string = strings.repeat("ab", 0)
    mut rep1 string = strings.repeat("ab", 1)
    mut rep3 string = strings.repeat("ab", 3)
    if rep0 == "" && rep1 == "ab" && rep3 == "ababab" {
        println("  [PASS] repeat 0, 1, 3")
        passed += 1
    } otherwise { println("  [FAIL] repeat") failed += 1 }

    // reverse
    mut reversed string = strings.reverse("hello")
    if reversed == "olleh" {
        println("  [PASS] reverse string")
        passed += 1
    } otherwise { println("  [FAIL] reverse — got '${reversed}'") failed += 1 }

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 { println("SOME TESTS FAILED") } otherwise { println("ALL TESTS PASSED") }
}
