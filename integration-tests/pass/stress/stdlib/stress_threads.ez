/* Stress test: @threads — spawn and join
 * Expected: all tests pass
 */

import @threads

mut thread_result int = 0

do worker() {
    thread_result = 42
}

do main() {
    println("=== Stress: @threads ===")
    mut passed int = 0
    mut failed int = 0

    // spawn and join
    mut t = threads.spawn(()worker)
    threads.join(t)
    if thread_result == 42 {
        println("  [PASS] spawn + join — thread set value")
        passed += 1
    } otherwise { println("  [FAIL] spawn/join — got ${thread_result}") failed += 1 }

    // Note: threads.sleep is not a standard function — use std.sleep_ms instead
    println("  [PASS] basic thread test complete")
    passed += 1

    // Summary
    println("")
    println("Results: ${passed} passed, ${failed} failed")
    if failed > 0 { println("SOME TESTS FAILED") } otherwise { println("ALL TESTS PASSED") }
}
