/*
 * Warning Test: W2011 - named-return-unused
 * Expected: warning about named return variable not being used in return
 */


do getName() -> (name string) {
    mut other string = "Alice"
    return other  // Warning: returning 'other' instead of named return 'name'
}

do main() {
    mut result string = getName()
    println(result)
}
